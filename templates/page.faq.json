      "blocks": {
        "template--21744624894253__5105504b-9704-47a7-80d9-dedd99dba321-frequently_asked_question-1": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "custom_icon": "",
            "heading": "What is the best way to clean and care for my jewelry?",
            "row_content": "<p><em>To keep your jewelry looking its best, we recommend gently cleaning it with a soft, lint-free cloth. For more intricate pieces, a mild jewelry cleaner can be used. Avoid exposing your jewelry to harsh chemicals, perfumes, or extreme temperatures to maintain its shine and longevity.</em></p>"
          }
        },
        "template--21744624894253__5105504b-9704-47a7-80d9-dedd99dba321-frequently_asked_question-2": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "custom_icon": "",
            "heading": "Can I customize or personalize a piece of jewelry?",
            "row_content": "<p><em>Absolutely! We offer customization services for many of our pieces. Contact our customer service team to discuss your preferences, from engraving to choosing specific gemstones, and we'll work with you to create a personalized masterpiece.</em></p>"
          }
        },
        "template--21744624894253__5105504b-9704-47a7-80d9-dedd99dba321-frequently_asked_question-3": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "custom_icon": "",
            "heading": "What is the difference between white gold and platinum?",
            "row_content": "<p><em>White gold and platinum are both stunning choices. White gold is an alloy of gold and other metals, plated with rhodium for a bright white finish. Platinum, on the other hand, is a naturally white metal that develops a beautiful patina over time. Both are durable and elegant; the choice depends on your personal preferences and budget.</em></p>"
          }
        },
        "template--21744624894253__5105504b-9704-47a7-80d9-dedd99dba321-frequently_asked_question-4": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "custom_icon": "",
            "heading": "How can I determine my ring size for online purchases?",
            "row_content": "<p><em>To find your ring size at home, use our handy ring sizing guide available on our website. Alternatively, visit a local jeweler who can measure your ring size accurately. Keep in mind that fingers can swell in different temperatures, so it's advisable to measure at various times of the day.</em></p>"
          }
        },
        "f1015c68-0f33-4136-ad63-a6875f15266b": {
          "type": "frequently_asked_question",
          "settings": {
            "icon": "none",
            "another_icon": "",
            "custom_icon": "",
            "heading": "What is your return policy?",
            "row_content": "<p><em>We want you to be delighted with your purchase. If for any reason you're not satisfied, you can return your unworn and undamaged jewelry within 30 days of purchase for a full refund or exchange. Please refer to our detailed return policy for more information on the process.</em></p>"
          }
        }
