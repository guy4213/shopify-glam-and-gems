{%- liquid
  assign heading = section.settings.heading
  assign body = section.settings.body
  assign btn1_label = section.settings.button1_label
  assign btn1_link = section.settings.button1_link
  assign btn2_label = section.settings.button2_label
  assign btn2_link = section.settings.button2_link
  assign image = section.settings.image
  assign section_bg = section.settings.section_bg
  assign text_color = section.settings.text_color
  assign btn_primary_bg = section.settings.btn_primary_bg
  assign btn_primary_text = section.settings.btn_primary_text
  assign btn_outline = section.settings.btn_outline
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

<style>
  #refine-design-{{ section.id }} {
    background: {{ section_bg }};
    color: {{ text_color }};
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    box-sizing: border-box;
  }

  #refine-design-{{ section.id }} .refine-design__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  #refine-design-{{ section.id }} .refine-design__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #refine-design-{{ section.id }} .refine-design__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 2rem;
    line-height: 1.2;
    margin: 0 0 16px 0;
    color: {{ text_color }};
    font-weight: 500;
  }

  #refine-design-{{ section.id }} .refine-design__body {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 24px 0;
    color: {{ text_color }};
  }

  #refine-design-{{ section.id }} .refine-design__body p {
    margin: 0 0 12px 0;
  }

  #refine-design-{{ section.id }} .refine-design__body p:last-child {
    margin-bottom: 0;
  }

  #refine-design-{{ section.id }} .refine-design__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  #refine-design-{{ section.id }} .refine-design__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 48px;
    padding: 0 20px;
    font-weight: 600;
    letter-spacing: 0.02em;
    font-size: 0.95rem;
    text-decoration: none;
    box-sizing: border-box;
    transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
    cursor: pointer;
    border-radius: 0;
  }

  #refine-design-{{ section.id }} .refine-design__btn--primary {
    background: {{ btn_primary_bg }};
    color: {{ btn_primary_text }};
    border: 1px solid {{ btn_primary_bg }};
  }

  #refine-design-{{ section.id }} .refine-design__btn--primary:hover {
    opacity: 0.9;
  }

  #refine-design-{{ section.id }} .refine-design__btn--outline {
    background: transparent;
    color: {{ btn_outline }};
    border: 1px solid {{ btn_outline }};
  }

  #refine-design-{{ section.id }} .refine-design__btn--outline:hover {
    background: {{ btn_outline }};
    color: {{ section_bg }};
  }

  #refine-design-{{ section.id }} .refine-design__media {
    width: 100%;
  }

  #refine-design-{{ section.id }} .refine-design__image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  #refine-design-{{ section.id }} .refine-design__placeholder {
    width: 100%;
    height: 360px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.35);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 767px) {
    #refine-design-{{ section.id }} .refine-design__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    #refine-design-{{ section.id }} .refine-design__content {
      order: 1;
    }

    #refine-design-{{ section.id }} .refine-design__media {
      order: 2;
    }

    #refine-design-{{ section.id }} .refine-design__heading {
      font-size: 1.6rem;
    }

    #refine-design-{{ section.id }} .refine-design__image,
    #refine-design-{{ section.id }} .refine-design__placeholder {
      max-height: 300px;
      height: auto;
    }

    #refine-design-{{ section.id }} .refine-design__placeholder {
      height: 260px;
    }
  }
</style>

<section id="refine-design-{{ section.id }}" class="refine-design">
  <div class="refine-design__inner">
    <div class="refine-design__content">
      {%- if heading != blank -%}
        <h2 class="refine-design__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if body != blank -%}
        <div class="refine-design__body">{{ body }}</div>
      {%- endif -%}

      <div class="refine-design__buttons">
        {%- if btn1_label != blank -%}
          <a href="{{ btn1_link | default: '#' }}" class="refine-design__btn refine-design__btn--primary">
            {{ btn1_label }}
          </a>
        {%- endif -%}

        {%- if btn2_label != blank -%}
          <a href="{{ btn2_link | default: '#' }}" class="refine-design__btn refine-design__btn--outline">
            {{ btn2_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="refine-design__media">
      {%- if image != blank -%}
        <img
          src="{{ image | image_url: width: 1100 }}"
          alt="{{ image.alt | escape }}"
          class="refine-design__image"
          loading="lazy"
          width="{{ image.width }}"
          height="{{ image.height }}"
        >
      {%- else -%}
        <div class="refine-design__placeholder">Image</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Refine design",
  "settings": [
    { "type": "text",         "id": "heading",         "label": "Heading",    "default": "Refine This Design" },
    { "type": "richtext",     "id": "body",            "label": "Body text",
      "default": "<p>Looking for personalized variation? Our team can help refine setting details, hidden halos, matching bands, and other custom adjustments while preserving the balance and beauty of the original design.</p>" },
    { "type": "text",         "id": "button1_label",   "label": "Primary button label",   "default": "Book a Free Private Consultation" },
    { "type": "url",          "id": "button1_link",    "label": "Primary button link" },
    { "type": "text",         "id": "button2_label",   "label": "Secondary button label", "default": "Request Customization" },
    { "type": "url",          "id": "button2_link",    "label": "Secondary button link" },
    { "type": "image_picker", "id": "image",           "label": "Image (ring sketches)" },
    { "type": "color",        "id": "section_bg",      "label": "Background",        "default": "#fffef3" },
    { "type": "color",        "id": "text_color",      "label": "Text color",        "default": "#1a1a1a" },
    { "type": "color",        "id": "btn_primary_bg",  "label": "Primary button bg", "default": "#111111" },
    { "type": "color",        "id": "btn_primary_text","label": "Primary button text","default": "#ffffff" },
    { "type": "color",        "id": "btn_outline",     "label": "Outlined button border", "default": "#111111" },
    { "type": "number",       "id": "padding_top",     "label": "Top padding (px)",    "default": 56 },
    { "type": "number",       "id": "padding_bottom",  "label": "Bottom padding (px)", "default": 56 }
  ],
  "presets": [
    { "name": "Refine design" }
  ]
}
{% endschema %}
