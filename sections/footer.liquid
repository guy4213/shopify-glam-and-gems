<style>
  .gg-footer {
    background: #000000;
    color: #ffffff;
    padding: 72px 48px 40px;
    box-sizing: border-box;
    width: 100%;
  }

  .gg-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    align-items: start;
  }

  .gg-footer__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 28px;
    line-height: 1.4;
  }

  .gg-footer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .gg-footer__nav li a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  .gg-footer__nav li a:hover {
    color: #ffffff;
  }

  .gg-footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .gg-footer__consult {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 2px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .gg-footer__consult:hover {
    border-color: #ffffff;
  }

  .gg-footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .gg-footer__contact-icon {
    width: 15px;
    height: 15px;
    min-width: 15px;
    margin-top: 3px;
    color: rgba(255, 255, 255, 0.55);
    flex-shrink: 0;
  }

  .gg-footer__contact-item a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  .gg-footer__contact-item a:hover {
    color: #ffffff;
  }

  .gg-footer__bottom {
    max-width: 1280px;
    margin: 56px auto 0;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.06em;
  }

  /* Plus icon hidden on desktop/tablet */
  .gg-footer__plus-icon {
    display: none;
  }

  @media (max-width: 900px) {
    .gg-footer {
      padding: 56px 32px 36px;
    }
    .gg-footer__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }

  @media (max-width: 600px) {
    .gg-footer {
      padding: 48px 0 32px;
    }
    .gg-footer__inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Accordion borders */
    .gg-footer__col--accordion {
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }
    .gg-footer__col--accordion-last {
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    /* Accordion title row */
    .gg-footer__col--accordion .gg-footer__col-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0px 8px;
      margin: 0;
      cursor: pointer;
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: none;
    }

    /* Show + icon on mobile */
    .gg-footer__plus-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 50px;
      height: 50px;
      font-size: 2rem;
      font-weight: 900;
      line-height: 1;
      flex-shrink: 0;
      transition: transform 0.35s ease;
    }

    /* Rotate + to × when open */
    .gg-footer__col--accordion.is-open .gg-footer__plus-icon {
      transform: rotate(90deg);
    }

    /* Accordion body: hidden by default on mobile */
    .gg-footer__col--accordion .gg-footer__accordion-body {
      display: none;
      padding: 4px 24px 24px;
    }
    .gg-footer__col--accordion.is-open .gg-footer__accordion-body {
      display: block;
    }

    /* Contact info: restore horizontal padding and add spacing */
    .gg-footer__col:not(.gg-footer__col--accordion) {
      padding: 0 24px;
      margin-top: 36px;
    }

    /* Footer bottom bar: restore horizontal padding */
    .gg-footer__bottom {
      margin: 36px 24px 0;
      max-width: none;
    }
  }
</style>

{%- assign menu_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'menu' -%}{%- assign menu_count = menu_count | plus: 1 -%}{%- endif -%}
{%- endfor -%}

<footer class="gg-footer" role="contentinfo">
  <div class="gg-footer__inner">
    {%- assign menu_index = 0 -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'menu' -%}
          {%- assign menu_index = menu_index | plus: 1 -%}
          <div class="gg-footer__col gg-footer__col--accordion{% if menu_index == menu_count %} gg-footer__col--accordion-last{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="gg-footer__col-title">
                {{ block.settings.title }}
                <span class="gg-footer__plus-icon" aria-hidden="true">+</span>
              </h3>
            {%- endif -%}
            <div class="gg-footer__accordion-body">
              <ul class="gg-footer__nav" role="list">
                {%- if block.settings.link_1_text != blank -%}
                  <li><a href="{{ block.settings.link_1_url | default: '#' }}">{{ block.settings.link_1_text }}</a></li>
                {%- endif -%}
                {%- if block.settings.link_2_text != blank -%}
                  <li><a href="{{ block.settings.link_2_url | default: '#' }}">{{ block.settings.link_2_text }}</a></li>
                {%- endif -%}
                {%- if block.settings.link_3_text != blank -%}
                  <li><a href="{{ block.settings.link_3_url | default: '#' }}">{{ block.settings.link_3_text }}</a></li>
                {%- endif -%}
                {%- if block.settings.link_4_text != blank -%}
                  <li><a href="{{ block.settings.link_4_url | default: '#' }}">{{ block.settings.link_4_text }}</a></li>
                {%- endif -%}
                {%- if block.settings.link_5_text != blank -%}
                  <li><a href="{{ block.settings.link_5_url | default: '#' }}">{{ block.settings.link_5_text }}</a></li>
                {%- endif -%}
                {%- if block.settings.link_6_text != blank -%}
                  <li><a href="{{ block.settings.link_6_url | default: '#' }}">{{ block.settings.link_6_text }}</a></li>
                {%- endif -%}
              </ul>
            </div>
          </div>

        {%- when 'contact_info' -%}
          <div class="gg-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="gg-footer__col-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            <div class="gg-footer__contact-list">

              {%- if block.settings.consultation_text != blank -%}
                <a
                  class="gg-footer__consult"
                  href="{{ block.settings.consultation_url | default: '#' }}"
                >
                  {{- block.settings.consultation_text -}}
                </a>
              {%- endif -%}

              {%- if block.settings.phone_text != blank -%}
                <div class="gg-footer__contact-item">
                  <svg class="gg-footer__contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.57 3.41 2 2 0 0 1 3.55 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6.29 6.29l1.07-1.07a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  <a href="{{ block.settings.phone_url }}">{{- block.settings.phone_text -}}</a>
                </div>
              {%- endif -%}

              {%- if block.settings.email_text != blank -%}
                <div class="gg-footer__contact-item">
                  <svg class="gg-footer__contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  <a href="{{ block.settings.email_url }}">{{- block.settings.email_text -}}</a>
                </div>
              {%- endif -%}

              {%- if block.settings.address_text != blank -%}
                <div class="gg-footer__contact-item">
                  <svg class="gg-footer__contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <a href="{{ block.settings.address_url }}" target="_blank" rel="noopener noreferrer">
                    {{- block.settings.address_text -}}
                  </a>
                </div>
              {%- endif -%}

            </div>
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>

  <div class="gg-footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
  </div>
</footer>

<script>
(function() {
  var BREAKPOINT = 600;

  document.querySelectorAll('.gg-footer__col--accordion .gg-footer__col-title').forEach(function(title) {
    title.addEventListener('click', function() {
      if (window.innerWidth > BREAKPOINT) return;
      this.closest('.gg-footer__col--accordion').classList.toggle('is-open');
    });
  });
})();
</script>

