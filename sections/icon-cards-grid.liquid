{%- style -%}
  /* === Mobile base === */
  .icon-cards-section-{{ section.id }} {
    background-color: {{ section.settings.mobile_background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .icon-cards-section-{{ section.id }} .icon-cards__heading {
    text-align: center;
    margin-bottom: 32px;
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
  }

  {% assign _mob_cols = section.settings.mobile_columns %}
  {% assign _mob_gaps = _mob_cols | minus: 1 %}

  .icon-cards-grid-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: {{ section.settings.gap_mobile }}px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.section_horizontal_padding_mobile }}px;
  }

  .icon-cards-grid-{{ section.id }} .icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    flex: 0 0 calc((100% - {{ section.settings.gap_mobile }}px * {{ _mob_gaps }}) / {{ _mob_cols }});
    padding: {{ section.settings.card_padding_mobile }}px;
    border: 1px solid {{ section.settings.border_color }};
    border-radius: {{ section.settings.border_radius_mobile }}px;
    background-color: {{ section.settings.card_background_color }};
    text-align: center;
    box-sizing: border-box;
  }

  .icon-cards-grid-{{ section.id }} .icon-card__image-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ section.settings.icon_label_gap_mobile }}px;
    width: 100%;
  }

  .icon-cards-grid-{{ section.id }} .icon-card__image {
    object-fit: contain;
    display: block;
    height: auto;
  }

  .icon-cards-grid-{{ section.id }} .icon-card__placeholder {
    background-color: #ddd;
    border-radius: 4px;
    display: block;
  }

  .icon-cards-grid-{{ section.id }} .icon-card__label {
    font-size: {{ section.settings.label_font_size_mobile }}px;
    color: {{ section.settings.label_color }};
    line-height: 1.3;
    margin: 0;
    font-weight: {{ section.settings.label_font_weight_mobile }};
  }

  /* === Desktop (640px+) === */
  @media (min-width: 640px) {
    .icon-cards-section-{{ section.id }} {
      background-color: {{ section.settings.background_color }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .icon-cards-section-{{ section.id }} .icon-cards__heading {
      font-size: {{ section.settings.heading_size }}px;
    }

    .icon-cards-grid-{{ section.id }} {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: {{ section.settings.gap }}px;
      padding: 0 {{ section.settings.section_horizontal_padding }}px;
    }

    .icon-cards-grid-{{ section.id }} .icon-card {
      padding: {{ section.settings.card_padding }}px;
      border-radius: {{ section.settings.border_radius }}px;
    }

    .icon-cards-grid-{{ section.id }} .icon-card__image-wrapper {
      margin-bottom: {{ section.settings.icon_label_gap }}px;
    }

    .icon-cards-grid-{{ section.id }} .icon-card__label {
      font-size: {{ section.settings.label_font_size }}px;
      font-weight: {{ section.settings.label_font_weight }};
    }
  }

  @media (min-width: 1024px) {
    .icon-cards-grid-{{ section.id }} {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  /* === Per-block overrides === */
  {% for block in section.blocks %}
    .icon-card-{{ block.id }} .icon-card__image,
    .icon-card-{{ block.id }} .icon-card__placeholder {
      width: {{ block.settings.image_width_mobile }}px;
      height: {{ block.settings.image_width_mobile }}px;
    }
    @media (min-width: 640px) {
      .icon-card-{{ block.id }} .icon-card__image,
      .icon-card-{{ block.id }} .icon-card__placeholder {
        width: {{ block.settings.image_width }}px;
        height: {{ block.settings.image_width }}px;
      }
    }
    .icon-card-{{ block.id }} {
      background-color: {{ block.settings.card_bg_color }};
    }
  {% endfor %}
{%- endstyle -%}

<div class="icon-cards-section-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="icon-cards__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="icon-cards-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="icon-card icon-card-{{ block.id }}" {{ block.shopify_attributes }}>

        <div class="icon-card__image-wrapper">
          {%- if block.settings.icon != blank -%}
            <img
              src="{{ block.settings.icon | image_url: width: 400 }}"
              alt="{{ block.settings.label | escape }}"
              class="icon-card__image"
              loading="lazy"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_width }}"
            >
          {%- else -%}
            <div class="icon-card__placeholder"></div>
          {%- endif -%}
        </div>

        {%- if block.settings.label != blank -%}
          <p class="icon-card__label">{{ block.settings.label }}</p>
        {%- endif -%}

      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
