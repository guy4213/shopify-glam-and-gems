<div id="cart-icon-bubble" >
  <div 
    class="count_item h-5 w-5 rounded-full absolute text-center place-content-center -top-0.5 right-0 bg-[rgba(var(--colors-cart))] text-[rgba(var(--colors-cart-text))] font-medium text-[9px]{% if cart == empty %} hidden{% endif %}"
    :class="{'left-0 lg:left-auto lg:right-0 rtl:lg:right-auto rtl:lg:left-0': $store.xHeaderMenu.mobileHeaderLayout.includes('right'), 'right-0': $store.xHeaderMenu.mobileHeaderLayout.includes('right')}"
  >
    {%- if cart.item_count < 100 -%}{{ cart.item_count }}{%- else -%}99+{%- endif -%}
  </div>
</div>