{%- liquid
  assign c1_link = section.settings.c1_cta_link
  assign c2_link = section.settings.c2_cta_link
  assign c3_link = section.settings.c3_cta_link
  if c1_link == blank
    assign c1_link = '#'
  endif
  if c2_link == blank
    assign c2_link = '#'
  endif
  if c3_link == blank
    assign c3_link = '#'
  endif

  assign c1_label = section.settings.c1_cta_label
  if c1_label == blank
    assign c1_label = 'Explore'
  endif
  assign c2_label = section.settings.c2_cta_label
  if c2_label == blank
    assign c2_label = 'Explore'
  endif
  assign c3_label = section.settings.c3_cta_label
  if c3_label == blank
    assign c3_label = 'Explore'
  endif
-%}

<section id="buyers-guide-{{ section.id }}" class="buyers-guide">
  <style>
    #buyers-guide-{{ section.id }} {
      background: {{ section.settings.section_bg }};
      color: {{ section.settings.text_color }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      --bg-color: {{ section.settings.section_bg }};
      --text-color: {{ section.settings.text_color }};
      --icon-color: {{ section.settings.icon_color }};
      --cta-bg: {{ section.settings.cta_bg }};
      --cta-text: {{ section.settings.cta_text }};
    }
    #buyers-guide-{{ section.id }} .buyers-guide__inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__heading {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 1.8rem;
      font-weight: 500;
      text-align: center;
      margin: 0 0 16px;
      color: var(--text-color);
    }
    #buyers-guide-{{ section.id }} .buyers-guide__subtitle {
      max-width: 640px;
      margin: 0 auto 40px;
      text-align: center;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--text-color);
      opacity: 0.85;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__subtitle p {
      margin: 0;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__col {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      background: rgba(255, 255, 255, 0.5);
      padding: 24px;
      border-radius: 6px;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__icon {
      margin-bottom: 16px;
      color: var(--icon-color);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__icon svg {
      width: 48px;
      height: 48px;
      color: var(--icon-color);
    }
    #buyers-guide-{{ section.id }} .buyers-guide__title {
      font-weight: 700;
      font-size: 1.05rem;
      margin: 0 0 8px;
      color: var(--text-color);
    }
    #buyers-guide-{{ section.id }} .buyers-guide__body {
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--text-color);
      opacity: 0.75;
      margin: 0 0 24px;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__cta {
      margin-top: auto;
      width: 100%;
      height: 44px;
      border-radius: 4px;
      background: var(--cta-bg);
      color: var(--cta-text);
      font-weight: 600;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 18px;
      text-decoration: none;
      box-sizing: border-box;
      transition: opacity 0.2s ease;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__cta:hover {
      opacity: 0.88;
    }
    #buyers-guide-{{ section.id }} .buyers-guide__cta svg {
      flex-shrink: 0;
    }
    @media (max-width: 767px) {
      #buyers-guide-{{ section.id }} .buyers-guide__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="buyers-guide__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="buyers-guide__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <div class="buyers-guide__subtitle">{{ section.settings.subtitle }}</div>
    {%- endif -%}

    <div class="buyers-guide__grid">
      {%- comment -%} Column 1 — Shop By Carat {%- endcomment -%}
      <div class="buyers-guide__col">
        <span class="buyers-guide__icon" aria-hidden="true">
          <svg viewBox="0 0 64 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
            <polygon points="8,28 10,24 12,28 10,32"/>
            <polygon points="20,28 24,22 28,28 24,34"/>
            <polygon points="36,28 42,18 48,28 42,38"/>
            <polygon points="50,28 56,16 62,28 56,40"/>
          </svg>
        </span>
        {%- if section.settings.c1_title != blank -%}
          <h3 class="buyers-guide__title">{{ section.settings.c1_title }}</h3>
        {%- endif -%}
        {%- if section.settings.c1_body != blank -%}
          <p class="buyers-guide__body">{{ section.settings.c1_body }}</p>
        {%- endif -%}
        <a href="{{ c1_link }}" class="buyers-guide__cta">
          <span>{{ c1_label }}</span>
          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      {%- comment -%} Column 2 — Shop By Budget {%- endcomment -%}
      <div class="buyers-guide__col">
        <span class="buyers-guide__icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="24,6 28,10 24,14 20,10"/>
            <line x1="24" y1="14" x2="24" y2="18"/>
            <path d="M12 18h24a2 2 0 0 1 2 2v18a4 4 0 0 1 -4 4h-20a4 4 0 0 1 -4 -4v-18 a2 2 0 0 1 2 -2 z"/>
            <text x="24" y="34" text-anchor="middle" font-family="serif" font-size="14" font-weight="700" stroke="none" fill="currentColor">$</text>
          </svg>
        </span>
        {%- if section.settings.c2_title != blank -%}
          <h3 class="buyers-guide__title">{{ section.settings.c2_title }}</h3>
        {%- endif -%}
        {%- if section.settings.c2_body != blank -%}
          <p class="buyers-guide__body">{{ section.settings.c2_body }}</p>
        {%- endif -%}
        <a href="{{ c2_link }}" class="buyers-guide__cta">
          <span>{{ c2_label }}</span>
          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      {%- comment -%} Column 3 — Create something Unique {%- endcomment -%}
      <div class="buyers-guide__col">
        <span class="buyers-guide__icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="18,12 26,12 30,18 22,32 14,18"/>
            <line x1="18" y1="18" x2="26" y2="18"/>
            <path d="M30 30 L40 20 L44 24 L34 34 Z"/>
            <line x1="40" y1="20" x2="44" y2="24"/>
          </svg>
        </span>
        {%- if section.settings.c3_title != blank -%}
          <h3 class="buyers-guide__title">{{ section.settings.c3_title }}</h3>
        {%- endif -%}
        {%- if section.settings.c3_body != blank -%}
          <p class="buyers-guide__body">{{ section.settings.c3_body }}</p>
        {%- endif -%}
        <a href="{{ c3_link }}" class="buyers-guide__cta">
          <span>{{ c3_label }}</span>
          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Buyer's guide",
  "settings": [
    { "type": "text",     "id": "heading",  "label": "Heading",  "default": "Engagement Ring Buyer's Guide" },
    { "type": "richtext", "id": "subtitle", "label": "Subtitle",
      "default": "<p>Buying an engagement ring is a meaningful decision. Our guide was created to help you understand what truly matters — from diamond size and value to design.</p>" },

    { "type": "header", "content": "Column 1 — Shop By Carat" },
    { "type": "text", "id": "c1_title", "label": "Title", "default": "Shop By Carat" },
    { "type": "textarea", "id": "c1_body", "label": "Body",
      "default": "Understand how carats size actually looks, how it affects price, and where you get the best value for your budget" },
    { "type": "text", "id": "c1_cta_label", "label": "CTA label", "default": "Explore" },
    { "type": "url",  "id": "c1_cta_link",  "label": "CTA link" },

    { "type": "header", "content": "Column 2 — Shop By Budget" },
    { "type": "text", "id": "c2_title", "label": "Title", "default": "Shop By Budget" },
    { "type": "textarea", "id": "c2_body", "label": "Body",
      "default": "Learn how to prioritize size, design, and diamond quality to get the most for your budget without compromising" },
    { "type": "text", "id": "c2_cta_label", "label": "CTA label", "default": "Explore" },
    { "type": "url",  "id": "c2_cta_link",  "label": "CTA link" },

    { "type": "header", "content": "Column 3 — Create something Unique" },
    { "type": "text", "id": "c3_title", "label": "Title", "default": "Create something Unique" },
    { "type": "textarea", "id": "c3_body", "label": "Body",
      "default": "Understand which design details truly change the look and value of a ring before creating your own" },
    { "type": "text", "id": "c3_cta_label", "label": "CTA label", "default": "Explore" },
    { "type": "url",  "id": "c3_cta_link",  "label": "CTA link" },

    { "type": "header", "content": "Style" },
    { "type": "color",  "id": "section_bg",     "label": "Background",        "default": "#fffef3" },
    { "type": "color",  "id": "text_color",     "label": "Text",              "default": "#1a1a1a" },
    { "type": "color",  "id": "icon_color",     "label": "Icon",              "default": "#1a1a1a" },
    { "type": "color",  "id": "cta_bg",         "label": "CTA background",    "default": "#111111" },
    { "type": "color",  "id": "cta_text",       "label": "CTA text",          "default": "#ffffff" },
    { "type": "number", "id": "padding_top",    "label": "Top padding (px)",    "default": 72 },
    { "type": "number", "id": "padding_bottom", "label": "Bottom padding (px)", "default": 72 }
  ],
  "presets": [
    { "name": "Buyer's guide" }
  ]
}
{% endschema %}
