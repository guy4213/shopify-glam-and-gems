{{ 'product-grid.css' | asset_url | stylesheet_tag }}
{% style %}
  .section-padding-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 768px) { 
    .section-padding-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.sticky_filtering %}
    :root{
      --height-sticky-filter: 50px;
    }
  {% endif %}
  .gap-{{ section.id }} {
    column-gap: {{ section.settings.spacing_col_mobile }}px;
    row-gap: {{ section.settings.spacing_row_mobile }}px;
  }
  @media (min-width: 768px) {
    .gap-{{ section.id }} {
      column-gap: {{ section.settings.spacing_col }}px;
      row-gap: {{ section.settings.spacing_row }}px;
    }
  }
{% endstyle %} 
{% liquid
  assign show_filter = true
  if collection.filters.size < 1
    assign show_filter = false
  endif
  for filter in collection.filters
    if filter.type == 'price_range' and collection.filters.size <= 1
      assign max = filter.range_max
      if filter.max_value.value
         assign max = filter.max_value.value
      endif
      if max == null or max == 0
        assign show_filter = false
      endif
    endif
  endfor
  assign filter_used = ""
%}
{% if product and settings.enable_combined %}
  {%- paginate pages by 1 -%}
    {% liquid
      assign index_param = section.index | plus: 0 
      assign product_card_id = paginate.current_page | plus: 0
      assign column_mobile = section.settings.products_per_row_on_mobile | plus: 0
      
      assign disable_quickview = true
      if section.settings.show_quickview
        assign disable_quickview = false
      endif 
    %}
    <div id="card-product-clone-{{ section.id }}" class="hidden product-card-cbl-clone">
      {% render 'card-product-list-layout',
        index_param: index_param,
        card_product: product,
        media_aspect_ratio: section.settings.image_ratio,
        show_highlighted_features: section.settings.show_highlighted_features,
        show_highlighted_attributes: section.settings.show_highlighted_attributes,
        show_vendor: section.settings.show_vendor,
        show_rating: section.settings.show_rating,
        loading: 'lazy',
        show_quick_add: section.settings.enable_quick_add,
        section_id: section.id,
        block_id: product_card_id,
        collection: collection,
        columns_desktop: section.settings.products_per_row_on_desktop,
        column_mobile: column_mobile,
        disable_quickview: disable_quickview,
        collection_page: true,
        show_description: section.settings.show_description,
        product_card_id: product_card_id,
        animation_loading: true,
        show_price_range: true
      %}
    </div>
  {% endpaginate %}
{% else %}
<div {% if section.settings.enable_filtering or section.settings.enable_sorting or section.settings.enable_advanced_filter %}x-data="xFiltersAndSortby('{{ section.id }}')" :class="!showFilterAside && 'filter-aside'"{% endif %} class="section-padding-{{ section.id }}">
  {%- assign _cfb_si_blocks = section.blocks | where: "type", "shape_image" -%}
  {%- if _cfb_si_blocks.size > 0 -%}
    <script type="application/json" id="CfbShapeImages-{{ section.id }}">
      [
        {%- for _b in _cfb_si_blocks -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {"label":{{ _b.settings.label | json }},"url":{{ _b.settings.image | image_url: width: 200 | json | default: "null" }},"filterValue":{{ _b.settings.filter_value | json }}}
        {%- endfor -%}
      ]
    </script>
  {%- endif -%}
  {%- render 'collection-filter-board', section: section -%}
  {%- render 'mobile-collection-pill-strip', section: section -%}
  {%- liquid
    assign _cfb_l1 = collection.metafields.custom.visual_filter_label_1 | strip
    assign _cfb_l2 = collection.metafields.custom.visual_filter_label_2 | strip
    assign _cfb_l3 = collection.metafields.custom.visual_filter_label_3 | strip
    assign _cfb_l4 = collection.metafields.custom.visual_filter_label_4 | strip
    if _cfb_l1 != blank
      assign filter_used = filter_used | append: _cfb_l1 | append: ";"
    endif
    if _cfb_l2 != blank
      assign filter_used = filter_used | append: _cfb_l2 | append: ";"
    endif
    if _cfb_l3 != blank
      assign filter_used = filter_used | append: _cfb_l3 | append: ";"
    endif
    if _cfb_l4 != blank
      assign filter_used = filter_used | append: _cfb_l4 | append: ";"
    endif
    if _cfb_l3 != blank or _cfb_l4 != blank
      assign filter_used = filter_used | append: 'Metal;Price;'
    endif
  -%}
  <div class="hidden md:block {% if section.settings.full_width %}full-width{% else %}x-pgw page-width mr-auto ml-auto{% endif %}{% if section.settings.sticky_filtering %} sticky top-[var(--height-header)] duration-300 z-[19] bg-[rgba(var(--colors-background),1)]{% endif %} empty:min-h-[50px]{% if section.settings.enable_filtering == false and section.settings.enable_sorting == false %} invisible h-0{% endif %}{% if section.settings.enable_filtering == false and section.settings.enable_sorting == false and section.settings.enable_advanced_filter == false %} hidden{% endif %}" id="header-filter"></div>
  {%- liquid
    assign mf_label_1 = collection.metafields.custom.visual_filter_label_1 | strip
    assign mf_label_2 = collection.metafields.custom.visual_filter_label_2 | strip
    assign mf_label_3 = collection.metafields.custom.visual_filter_label_3 | strip
    assign mf_label_4 = collection.metafields.custom.visual_filter_label_4 | strip
    assign use_mf_filter_labels = false
    if mf_label_1 != blank or mf_label_2 != blank or mf_label_3 != blank or mf_label_4 != blank
      assign use_mf_filter_labels = true
    endif
    assign show_advanced_filter = false
    if section.settings.enable_advanced_filter
      if section.settings.key_value != blank or use_mf_filter_labels
        assign show_advanced_filter = true
      endif
    endif
  -%}
  {% if show_advanced_filter %}
    <div class="hidden md:block">
    {% liquid
      if use_mf_filter_labels
        assign key_value = mf_label_1 | append: "~" | append: mf_label_2 | append: "~" | append: mf_label_3 | append: "~" | append: mf_label_4 | split: "~"
      else
        assign key_value = section.settings.key_value | newline_to_br | strip_newlines | split: '<br />'
      endif
      assign filter_advanced_count = 0
      for filter_label in key_value
        if filter_advanced_count < 2
          if filter_advanced_count < 1
            assign columns_desktop = "columns_desktop_1"
            assign desktop_image_width = "desktop_image_width_1"
          else
            assign columns_desktop = "columns_desktop_2"
            assign desktop_image_width = "desktop_image_width_2"
          endif
          for filter in collection.filters
            assign sorted_values = filter.values

            assign filter_index = forloop.index
            unless filter_label != filter.label or filter_used contains filter.label
              assign filter_advanced_count = filter_advanced_count | plus: 1
              assign filter_used = filter_used | append: filter.label | append: ";"
              render 'advanced-filter', filter: filter, index: filter_index, sorted_values: sorted_values, filter_type: section.settings.filter_type, filter_advanced_count: filter_advanced_count, enable_desktop_slider: section.settings.enable_desktop_slider, columns_desktop: section.settings[columns_desktop], hide_unavaiable_filter: section.settings.hide_unavaiable_filter, image_ratio: section.settings.image_ratio_filter, full_width: section.settings.full_width, desktop_image_width: section.settings[desktop_image_width], advanced_filter_image_ratio: section.settings.advanced_filter_image_ratio
            endunless
          endfor
        endif
      endfor

      assign only_show_advanded_filter = false
      if collection.filters.size == filter_advanced_count
        assign only_show_advanded_filter = true
      endif
      if section.settings.enable_filtering == false and filter_advanced_count > 0
        assign only_show_advanded_filter = true
      endif
    %}
    </div>
  {% endif %}
  <div 
    class="{% if section.settings.full_width %}full-width{% else %}x-pgw page-width mr-auto ml-auto{% endif %}{% if section.settings.filter_type == 'aside' and section.settings.enable_filtering and show_filter %} grid {% if section.settings.default_hide_filtering %} md:grid-cols-2 filter-aside:md:grid-cols-3 filter-aside:lg:grid-cols-4{% else %} md:grid-cols-3{% endif %} lg:grid-cols-4 md:gap-7 md:pt-7{% endif %}"
    {% if section.settings.filter_type == 'above' %} :class="showFilterAside ? 'md:pt-0' : 'md:pt-3'"{% endif %}
  >
      {% liquid
        assign products_per_page = 20
        assign columns_desktop = section.settings.products_per_page | split: ";"
        assign number_products = blank
        assign param = blank
        if cart.attributes.collection-pagination != blank
          assign param = cart.attributes.collection-pagination
        endif
        for column in columns_desktop
          assign check  = column | remove: "0" | remove: "1" | remove: "2" | remove: "3" | remove: "4" | remove: "5" | remove: "6" | remove: "7" | remove : "8" | remove: "9"
          if check == ''
            assign number_products = number_products | append: column | append: ";"
          endif
        endfor 
        if number_products != blank
          assign number_products = number_products | split: ";"
          assign products_per_page = number_products[0]
        endif
        if number_products != blank and param != blank and number_products contains param
          assign products_per_page = param
        endif

        assign disable_quickview = true
        if section.settings.show_quickview
          assign disable_quickview = false
        endif 
      %}
      <div class="col-span-1{% if section.settings.default_hide_filtering %}{% if section.settings.filter_type != 'drawer' %} md:hidden{% endif %} filter-aside:md:block{% else %} filter-aside:md:hidden{% endif %}{% if section.settings.sticky_filtering and section.settings.filter_type == 'above' %} md:sticky duration-300 top-[calc(var(--height-header)+var(--height-sticky-filter))] z-[19] bg-[rgba(var(--colors-background),1)]{% endif %}{% if section.settings.filter_type == 'above' and show_filter %} md:pt-4{% endif %}">
        {% render 'facets',
          results: collection,
          enable_filtering: section.settings.enable_filtering,
          enable_sorting: section.settings.enable_sorting,
          number_products: number_products,
          products_per_page: products_per_page,
          collection_page: true,
          filter_type: section.settings.filter_type,
          sticky_filter: section.settings.sticky_filtering,
          show_filter: show_filter,
          expand_filter: section.settings.expand_filter,
          filter_used: filter_used,
          only_show_advanded_filter: only_show_advanded_filter,
          enable_collection_count: section.settings.enable_collection_count
        %}
      </div>
      <div
        class="x-auto-focus pb-[80px] md:pb-0 {% if section.settings.filter_type == 'above' %}mt-6 md:mt-7{% elsif section.settings.filter_type == 'aside' %}md:col-span-2{% if section.settings.default_hide_filtering %} lg:col-span-4 filter-aside:lg:col-span-3{% else %} lg:col-span-3 filter-aside:md:col-span-3 filter-aside:lg:col-span-4{% endif %}{% endif %}"
        id="ProductGridContainer"
        x-intersect.once='$store.xCustomerEvent.fire("list_product_viewed", $el, {
          "list": {
            "id": "collection",
            "title": "{{ collection.title | escape }}" 
          }
        })'
        {% if request.design_mode and section.settings.pagination != "pagination" %}
          x-data="xPagination('{{ section.id }}')"
        {% endif %}
      >
        {%- if section.settings.enable_collection_count -%}
          <p id="ProductCount" class="hidden">
            {%- if collection.products_count == collection.all_products_count -%}
              {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
            {%- else -%}
              {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
            {%- endif -%}
          </p>
        {%- endif -%}
        {%- paginate collection.products by products_per_page -%}
          <div class="relative" :class="listLayout ? 'list-layout' : 'grid-layout'">
            {% if section.settings.enable_filtering or section.settings.enable_sorting %}
              <div class="loading-cover left-0 absolute{% if section.settings.full_width %} full-width{% else %} x-pgw page-width{% endif %} -top-6" x-show="loading" x-cloak>
                <span class="loading-bar"></span>
              </div>
            {% endif %}
            {%- if collection.products.size == 0 -%}
              <div id="product-grid">
                {% if collection.filters != blank %}
                  <p class="text-center">
                    {{ 'sections.collection_template.empty' | t }}<br>
                    {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: "text-[rgb(var(--colors-text-link))]" }}
                  </p>
                {%- else -%}
                  <p class="text-center">{{ 'sections.collection_template.no_product_collection' | t }} </p>
                {% endif %}
                <div class="hidden" id="perpage-collection"></div>
              </div>
            {%- else -%}
              <div class="md:hidden flex justify-end items-center gap-2 px-4 mb-3">
                <label for="MobileSortBy" class="text-sm">{{ 'products.facets.sort_by_label' | t }}</label>
                <div class="relative eurus">
                  {%- assign mobile_sort_by = collection.sort_by | default: collection.default_sort_by -%}
                  <select
                    id="MobileSortBy"
                    name="sort_by"
                    form="FacetFiltersForm"
                    aria-label="Sort by"
                    class="cursor-pointer pt-1 pb-1 pl-2 pr-7 focus:outline-none bg-transparent border border-solid"
                    @change="onSubmit(0)"
                  >
                    {%- for option in collection.sort_options -%}
                      <option value="{{ option.value | escape }}"{% if option.value == mobile_sort_by %} selected="selected"{% endif %}>{{ option.name | escape }}</option>
                    {%- endfor -%}
                  </select>
                  <span class="w-3 absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none">{% render 'icon-alls', icon: 'icon-caret' %}</span>
                </div>
              </div>
              <div id="items-grid" class="grid grid-cols-{{ section.settings.products_per_row_on_mobile }} md:grid-cols-2 lg:grid-cols-{{ section.settings.products_per_row_on_desktop }} gap-{{ section.id }} md:list-layout:grid-cols-1{% if section.settings.pagination == 'pagination' %} pb-10 border-b border-solid{% endif %}{% if request.design_mode and section.settings.pagination != 'pagination' %} opacity-0{% endif %}" {% if request.design_mode and section.settings.pagination != 'pagination' %} :class="loading ? 'opacity-0' : 'opacity-100'"{% endif %}>
                  {% liquid 
                    assign curent_page = paginate.current_page | minus: 1
                    assign total_product = products_per_page | times: curent_page
                  %}
                  {%- for product in collection.products -%}
                    {% liquid 
                      assign index = forloop.index | plus: total_product
                      if forloop.index < 3 or settings.enable_lazy_loading_image == false
                        assign loading = 'eager'
                      else
                        assign loading = 'lazy'
                      endif
                    %}
                    {% for block in section.blocks %}
                      {% if block.settings.position == index %}
                        {% liquid
                          assign col_span = block.settings.number_of_columns
                          if col_span > section.settings.products_per_row_on_desktop
                            assign col_span = section.settings.products_per_row_on_desktop
                          endif
                          assign col_span_mobile = block.settings.number_of_columns_mobile
                          if col_span_mobile > section.settings.products_per_row_on_mobile
                            assign col_span_mobile = section.settings.products_per_row_on_mobile
                          endif
                          assign class_tall_mobile = 'col-span-' | append: col_span_mobile | append: ' row-span-' | append: block.settings.number_of_row_mobile
                          assign class_tall_desktop = 'grid-item lg:col-span-' | append: col_span | append: ' lg:row-span-' | append: block.settings.number_of_row
                          assign col_span = col_span | times: 1.0
                          assign columns_desktop = section.settings.products_per_row_on_desktop | divided_by: col_span
                          assign columns_mobile = section.settings.products_per_row_on_mobile | divided_by: col_span_mobile
                        %}
                        {% render 'promotion-block',
                          blockID: block.id,
                          image_ratio: section.settings.image_ratio,
                          ratio: 100,
                          columns_desktop: columns_desktop,
                          columns_mobile: columns_mobile,
                          block: block,
                          enable_desktop_slider: false,
                          image: block.settings.image,
                          button_label: block.settings.button_label,
                          button_link: block.settings.button_link,
                          open_new_window: block.settings.open_new_window,
                          content_position: block.settings.content_position,
                          alignment: block.settings.alignment,
                          heading: block.settings.heading,
                          content: block.settings.content,
                          image_overlay_opacity: block.settings.image_overlay_opacity,
                          title_size: block.settings.title_size,
                          text_size: block.settings.text_size,
                          list_layout: true,
                          show_button_style: block.settings.show_button_style,
                          color_button: block.settings.color_button,
                          color_text_button: block.settings.color_text_button,
                          color_button_hover: block.settings.color_button_hover,
                          color_text_button_hover: block.settings.color_text_button_hover,
                          color_button_secondary: block.settings.color_button_secondary,
                          secondary_button_text: block.settings.secondary_button_text,
                          colors_text_link: block.settings.colors_text_link,
                          class_tall_mobile: class_tall_mobile,
                          class_tall_desktop: class_tall_desktop,
                          collection_page: true,
                          loading: loading,
                          icon: 'none',
                          subheading: block.settings.subheading,
                          heading_highlight: true,
                          color_heading_highlight_dark: block.settings.color_heading_highlight_dark,
                          color_heading_highlight_light: block.settings.color_heading_highlight_light,
                          highlight_type: block.settings.highlight_type
                        %}
                      {% endif %}
                    {% endfor %}
                    {% liquid
                      assign index_param = section.index | append: forloop.index 
                      assign product_card_id = paginate.current_page | append: forloop.index
                    %}
                    <div class="grid-item">
                      {% assign column_mobile = section.settings.products_per_row_on_mobile | plus: 0 %}
                      {% render 'card-product-list-layout',
                        index_param: index_param,
                        card_product: product,
                        media_aspect_ratio: section.settings.image_ratio,
                        show_highlighted_features: section.settings.show_highlighted_features,
                        show_highlighted_attributes: section.settings.show_highlighted_attributes,
                        show_vendor: section.settings.show_vendor,
                        show_rating: section.settings.show_rating,
                        loading: loading,
                        show_quick_add: section.settings.enable_quick_add,
                        section_id: section.id,
                        block_id: product_card_id,
                        collection: collection,
                        columns_desktop: section.settings.products_per_row_on_desktop,
                        column_mobile: column_mobile,
                        disable_quickview: disable_quickview,
                        collection_page: true,
                        show_description: section.settings.show_description,
                        product_card_id: product_card_id,
                        animation_loading: true,
                        show_price_range: true
                      %}
                    </div>
                    {% for block in section.blocks %}
                      {% if block.settings.position > index and index == collection.products_count and collection.products_count == collection.all_products_count %}
                        {% liquid
                          assign col_span = block.settings.number_of_columns
                          if col_span > section.settings.products_per_row_on_desktop
                            assign col_span = section.settings.products_per_row_on_desktop
                          endif
                          assign col_span_mobile = block.settings.number_of_columns_mobile
                          if col_span_mobile > section.settings.products_per_row_on_mobile
                            assign col_span_mobile = section.settings.products_per_row_on_mobile
                          endif
                          assign class_tall_mobile = 'col-span-' | append: col_span_mobile | append: ' row-span-' | append: block.settings.number_of_row_mobile
                          assign class_tall_desktop = 'grid-item lg:col-span-' | append: col_span | append: ' lg:row-span-' | append: block.settings.number_of_row
                          assign col_span = col_span | times: 1.0
                          assign columns_desktop = section.settings.products_per_row_on_desktop | divided_by: col_span
                          assign columns_mobile = section.settings.products_per_row_on_mobile | divided_by: col_span_mobile
                          assign ratio = block.settings.image.aspect_ratio | times: 100
                        %}
                        {% render 'promotion-block',
                          blockID: block.id,
                          image_ratio: 'last-promo',
                          ratio: ratio,
                          columns_desktop: columns_desktop,
                          columns_mobile: columns_mobile,
                          block: block,
                          enable_desktop_slider: false,
                          image: block.settings.image,
                          button_label: block.settings.button_label,
                          button_link: block.settings.button_link,
                          open_new_window: block.settings.open_new_window,
                          content_position: block.settings.content_position,
                          alignment: block.settings.alignment,
                          heading: block.settings.heading,
                          content: block.settings.content,
                          image_overlay_opacity: block.settings.image_overlay_opacity,
                          title_size: block.settings.title_size,
                          text_size: block.settings.text_size,
                          list_layout: true,
                          show_button_style: block.settings.show_button_style,
                          color_button: block.settings.color_button,
                          color_text_button: block.settings.color_text_button,
                          color_button_hover: block.settings.color_button_hover,
                          color_text_button_hover: block.settings.color_text_button_hover,
                          color_button_secondary: block.settings.color_button_secondary,
                          secondary_button_text: block.settings.secondary_button_text,
                          colors_text_link: block.settings.colors_text_link,
                          class_tall_mobile: class_tall_mobile,
                          class_tall_desktop: class_tall_desktop,
                          collection_page: true,
                          loading: loading,
                          icon: 'none',
                          subheading: block.settings.subheading,
                          heading_highlight: true,
                          color_heading_highlight_dark: block.settings.color_heading_highlight_dark,
                          color_heading_highlight_light: block.settings.color_heading_highlight_light,
                          highlight_type: block.settings.highlight_type
                        %}
                      {% endif %}
                    {% endfor %}
                  {%- endfor -%}
                </div>
              <div class="flex{% if number_products != blank and number_products.size > 1 and section.settings.pagination == 'pagination' %} justify-between{% else %} justify-center{% endif %} items-center mt-3 md:mt-7 mb-7 flex-col-reverse lg:flex-row">
                {%- if paginate.pages > 1 -%}
                  {% render 'pagination', paginate: paginate, anchor: '', paginate_type: section.settings.paginate_type, pagination: section.settings.pagination, products_per_page: products_per_page, focus_product: true %}
                {%- else -%}
                  <div class="w-auto"></div>
                {%- endif -%}
                {% if number_products != blank %}
                  <div class="{% if section.settings.pagination != 'pagination' %}hidden{% endif %}" id="perpage-collection"></div>
                {% endif %}
              </div>
            {%- endif -%}
          </div>
        {%- endpaginate -%}
      </div>
  </div>
</div>
{% if section.settings.enable_micro_schema %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "CollectionPage",
      "name": {{ collection.title | json }},
      {% if collection.image -%}
        "image":{{ collection.image | image_url: width: 1920 | prepend: "https:" | json }},
      {%- endif %}
      "url": {{ request.origin | append: collection.url | json }},
      "description": {{ collection.description | strip_html | json }},
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          {%- for product in collection.products -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": {{ request.origin | append: collection.url | json }},
              "name": {{ product.title | json }},
              {% if product.featured_media -%}
                "image": {{ product.featured_media | image_url: width: 1920 | prepend: "https:" | json }},
              {%- endif %}
              "description": {{ product.description | strip_html | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      }
    }
  </script>
{% endif %}
{% endif %}
{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section x-section-product-grid",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.user_guide_link.section_and_blocks.product_grid"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
