            {%- else -%}
              --gg-search-font-family: var(--font-body-family);
            {%- endif -%}
            {%- if section.settings.consultation_font_family == 'heading' -%}
              --gg-consult-font-family: var(--font-heading-family);
            {%- else -%}
              --gg-consult-font-family: var(--font-body-family);
            {%- endif -%}
          }
          #x-header-custom-left form {
            max-width: var(--gg-search-max-width);
          }
          #x-header-custom-left .gg-search-input {
            background-color: var(--gg-search-bg);
            color: var(--gg-search-text);
            border-color: var(--gg-search-border);
            border-radius: var(--gg-search-radius);
            font-size: var(--gg-search-font-size);
            font-weight: var(--gg-search-font-weight);
            font-family: var(--gg-search-font-family);
          }
          #x-header-custom-left .gg-search-input::placeholder {
            color: var(--gg-search-ph-color);
            font-family: var(--gg-search-font-family);
          }
          #x-header-custom-left .gg-consult-text {
            font-size: var(--gg-consult-font-size);
            font-weight: var(--gg-consult-font-weight);
            font-family: var(--gg-consult-font-family);
          }
          .x-header-wishlist-badge {
            background-color: {{ section.settings.wishlist_badge_bg_color }};
            color: {{ section.settings.wishlist_badge_text_color }};
          }
