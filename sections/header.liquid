{%- liquid
  if section.settings.header_show_currency_selector or section.settings.show_social_icons or section.settings.header_show_language_selector
    assign header_top = true 
  else 
    assign header_top = false
  endif
  assign show_theme_mode_on_header = false
  if settings.theme_mode_enabled and settings.mobile_theme_mode_position != 'navigation'
    assign show_theme_mode_on_header = true
  endif
  assign search_on_header = false
  if settings.search_enabled and section.settings.search_on_header
    assign search_on_header = true
  endif
  assign areas = "heading navigation icons"
  assign areas_2 =  ". . ."
  assign class_grid = "col-span-full col-start-1 order-1 lg:pb-3"
  assign class = 'w-full justify-end'
  assign logo_above = false
  assign logo_center = false
  assign columns = 'auto 1fr auto'

  assign enable_compact_menu = false
  if section.settings.enable_hamburger_menu or section.settings.enable_hamburger_menu == false and section.settings.enable_drawer_menu
    assign enable_compact_menu = true
  endif

  if section.settings.logo_position == 'above-center'
    assign areas =  "iconsRight heading icons" 
    assign areas_2 =  "navigation navigation navigation"
    assign class_grid = '[grid-area:iconsRight] hidden lg:block'
    if enable_compact_menu
      assign class_grid = '[grid-area:iconsRight] hidden lg:block lg:pb-3'
    else 
      assign logo_above = true
    endif
    assign class = 'w-full'
    assign columns = '4fr 2fr 4fr'
  elsif section.settings.logo_position == 'left-center'
    assign columns = '1fr 4fr 1fr'
  elsif section.settings.logo_position == 'center-left'
    assign columns = '4fr 2fr 4fr'
    assign areas = ". . ."
    assign areas_2 =  "navigation heading icons"
    assign logo_center = true
  endif
  if enable_compact_menu
    if header_top
      if search_on_header
        assign areas = "iconsRight iconsRight iconsRight iconsRight"
        if logo_center
          assign columns = "150px 1fr 1fr auto"
          assign areas_2 = "navigation heading search icons"
        else
          assign columns = "auto auto 1fr auto"
          assign areas_2 = ". navigation search ."
          if section.settings.logo_position == "above-center"
            assign areas_2 = "heading navigation search icons"
          endif
        endif
      else
        assign areas = "iconsRight iconsRight iconsRight"
        if logo_center
          assign columns = "150px 1fr auto"
          assign areas_2 = "navigation heading icons"
        else
          assign columns = "auto 1fr auto"
          assign areas_2 = ". navigation ."
        endif
      endif
    else
      if search_on_header
        assign areas_2 = ". . . ."
        if logo_center
          assign columns = "150px 1fr 1fr auto"
          assign areas = "navigation heading search icons"
        else
          assign columns = "auto 150px 1fr auto"
          assign areas = ". navigation search ."
          if section.settings.logo_position == "above-center"
            assign areas = "heading navigation search icons"
          endif
        endif
      else
        assign areas_2 = ". . ."
        if logo_center
          assign columns = "150px 1fr auto"
          assign areas = "navigation heading icons"
        else
          assign columns = "auto 1fr auto"
          assign areas = ". navigation ."
        endif
      endif
    endif
  endif
  if search_on_header and enable_compact_menu == false
    assign columns = "2fr 6fr 2fr auto"
    assign areas = "heading search icons toolbar"
    assign areas_2 = "navigation navigation navigation navigation"
    assign class_grid = "col-span-full lg:col-span-1 lg:col-start-4 lg:justify-end"
    assign class = "lg:[grid-area:toolbar] w-full flex justify-end"
    assign logo_above = true
    assign logo_center = false
  endif
  assign transparent = false
  if section.settings.enable_on_homepage and template.name == "index"
    assign transparent = true
  endif
  if section.settings.enable_on_collection_page and template.name == "collection"
    assign transparent = true
  endif
  assign logo_name = settings.heading_base_size | times: 0.0225

  if section.settings.mobile_header_layout == 'center-left'
    assign mobile_layout = 'drawer heading icons'
  elsif section.settings.mobile_header_layout == 'center-right'
    assign mobile_layout = 'icons heading drawer'
  else
    assign mobile_layout = 'heading drawer'
  endif
-%}
{%- style -%}
  {% if section.settings.sticky_header_type != "none" %}
    #x-header-container {
      contain: style layout;
    }
  {% endif %}
  {% if section.settings.primary_menu_label_animation %}
    .back{
      position: absolute;
      top: 50%;
      left: 50%;
      white-space: nowrap;
      opacity: 0;
      transform: translate(-50%, -50%) translateY(100%) translateZ(0);
      transition-behavior: normal, normal;
      transition-duration: 0.6s, 0.6s;
      transition-timing-function: cubic-bezier(0.165, 0.84, 0.44, 1), cubic-bezier(0.165, 0.84, 0.44, 1);
      transition-delay: 0s, 0s;
      transition-property: transform, opacity;
    }
    .front{
      transform: translateZ(0);
      transition-behavior: normal, normal;
      transition-duration: 0.6s, 0.6s;
      transition-timing-function: cubic-bezier(0.165, 0.84, 0.44, 1), cubic-bezier(0.165, 0.84, 0.44, 1);
      transition-delay: 0s, 0s;
      transition-property: transform, opacity;
      border-bottom: 1px solid transparent;
    }
    .flip-container:hover .front{
      opacity: 0;
      transform: translateY(-100%) translateZ(0);
    }
    .flip-container:hover .back{
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0%) translateZ(0);
      border-bottom: 1px solid rgba(var(--colors-text-link));
    }
  {% endif %}
  .w-logo-header {
    width: {{ section.settings.logo_width_mobile }}px;
    min-width: {{ section.settings.logo_width_mobile }}px;
  }
  @media(min-width: 768px) {
    .w-logo-header {
      width: {{ section.settings.logo_width }}px;
      min-width: {{ section.settings.logo_width }}px;
    }
  }
  :root {
    --gg-icon-size: {{ section.settings.header_icon_size_mobile | default: 24 }}px;
    --gg-wishlist-scale: {{ section.settings.header_wishlist_icon_scale_mobile | default: 100 | divided_by: 100.0 }};
    --gg-account-scale: {{ section.settings.header_account_icon_scale_mobile | default: 100 | divided_by: 100.0 }};
    --gg-cart-scale: {{ section.settings.header_cart_icon_scale_mobile | default: 100 | divided_by: 100.0 }};
    --gg-mobile-right-scale: {{ section.settings.mobile_icons_scale | default: 100 | divided_by: 100.0 }};
  }
  @media (max-width: 1023px) {
    .x-container-header-icons {
      --gg-cart-scale: var(--gg-mobile-right-scale);
      --gg-account-scale: var(--gg-mobile-right-scale);
    }
  }
  @media(min-width: 1024px) {
    :root {
      --gg-icon-size: {{ section.settings.header_icon_size | default: 32 }}px;
      --gg-wishlist-scale: {{ section.settings.header_wishlist_icon_scale | default: 100 | divided_by: 100.0 }};
      --gg-account-scale: {{ section.settings.header_account_icon_scale | default: 100 | divided_by: 100.0 }};
      --gg-cart-scale: {{ section.settings.header_cart_icon_scale | default: 100 | divided_by: 100.0 }};
    }
  }
  {% if section.settings.sticky_header_type == "reduce-logo-size" or section.settings.sticky_header_type == "always" %}
    .section-header {
      position: sticky;
      z-index: 50;
      top: var(--announcement-height);
    }
    #x-header-container.is-scrolled {
      box-shadow: 0 5px 15px rgba(var(--colors-text), .1);
    }
    {% if section.settings.sticky_header_type == "reduce-logo-size" %}
      #x-header-container .header-logo {
        width: 100%;
        transition: width 0.4s ease-in-out 0.1s;
      }
      #x-header-container.reduce-logo-size .header-logo {
        width: 75%;
      }
    {% endif %}
  {% endif %}
  {% if section.settings.sticky_header_type == "on-scroll-up" %}
    .section-header.is-sticky {
      position: sticky;
      z-index: 50;
      top: var(--announcement-height);
    }
    .is-sticky #x-header-container:not(.on-scroll-up-animation) {
      box-shadow: 0 5px 15px rgba(var(--colors-text), .1);
    }
    #x-header-container {
      transform: translateY(0);
      transition: transform 0.4s ease-in-out 0.1s;
      will-change: transform;
    }
    #x-header-container.on-scroll-up-animation {
      transform: translateY(var(--header-sticky-transform));
    }
    .section-header:has(#x-header-container.on-scroll-up-animation) {
      pointer-events: none
    }
    {% if transparent %}
      @media (min-width: 768px) {
        .scroll-sticky-popup-cart {
          transform: translateY(calc(var(--header-sticky-transform) * -1));
          transition: transform 0.4s ease-in-out 0.1s;
        }
        .section-header:has(#x-header-container.on-scroll-up-animation) .scroll-sticky-popup-cart {
          transform: translateY(0);
        }
      }
    {% else %}
      @media (min-width: 768px) {
        .scroll-sticky-popup-cart {
          transform: translateY(0);
          transition: transform 0.4s ease-in-out 0.1s;
        }
        .section-header:has(#x-header-container.on-scroll-up-animation) .scroll-sticky-popup-cart {
          transform: translateY(var(--header-sticky-transform));
        }
      }
    {% endif %}
  {% endif %}
  {%- if transparent -%}
    section:first-child {
      margin-top: 0;
    }
    #sticky-header-content {
      background: linear-gradient(to top, transparent 0%, rgba({{ section.settings.shadow_color.red }},{{ section.settings.shadow_color.green }},{{ section.settings.shadow_color.blue }}, {{ section.settings.shadow }}%) 100%);
      {% unless section.settings.textlink_color_light.alpha == 0.0 %}
        --colors-text-link: {{ section.settings.textlink_color_light.red }},{{ section.settings.textlink_color_light.green }},{{ section.settings.textlink_color_light.blue }};
      {% endunless %}
    }
    .dark #sticky-header-content {
      {% if section.settings.shadow_color_dark.alpha != 0.0 %}
        background: linear-gradient(to top, transparent 0%, rgba({{ section.settings.shadow_color_dark.red }},{{ section.settings.shadow_color_dark.green }},{{ section.settings.shadow_color_dark.blue }}, {{ section.settings.shadow }}%) 100%);
      {% else %}
        background: transparent;
      {% endif %}
      {%- unless section.settings.textlink_color_dark.alpha == 0.0 -%}
        --colors-text-link: {{ section.settings.textlink_color_dark.red }},{{ section.settings.textlink_color_dark.green }},{{ section.settings.textlink_color_dark.blue }};
      {% endunless %}
    }
    .is-sticky #sticky-header-content.background-header,
    .is-scrolled #sticky-header-content.background-header,
    #sticky-header-content.background-header:has(.open-menu),
    #sticky-header-content.background-header.is-touched,
    #sticky-header-content:hover {
      background: rgb(var(--background-color-header));
      --colors-text-link: {{ settings.colors_text_link.red }}, {{ settings.colors_text_link.green }}, {{ settings.colors_text_link.blue }};
    }
    .dark .is-sticky #sticky-header-content.background-header,
    .dark .is-scrolled #sticky-header-content.background-header,
    .dark #sticky-header-content.background-header:has(.open-menu),
    .dark #sticky-header-content.background-header.is-touched,
    .dark #sticky-header-content:hover {
      --colors-text-link: {{ settings.colors_dark_text_link.red }}, {{ settings.colors_dark_text_link.green }}, {{ settings.colors_dark_text_link.blue }};
    }
    @media (min-width: 768px) {
      #sticky-header-content:hover,
      #sticky-header-content:hover header,
      #sticky-header-content:has(.hamburger-menu-container.h-hamburger) {
        background: rgba(var(--background-color-header));
      }
    }
    #sticky-header-content:hover .divider {
      --colors-line-and-border: var(--background-color-header);
      --colors-line-header: var(--background-color-header);
    }
    {% unless section.settings.text_color_light.alpha == 0.0 %}
      .transparent-header .logo-name, .transparent-header header {
        color: {{ section.settings.text_color_light }};
      }
      .is-scrolled.transparent-header .logo-name, .is-scrolled.transparent-header header {
        color: rgba(var(--colors-text));
      }
    {% endunless %}
    .dark .transparent-header .logo-name, .dark .transparent-header header {
      {% unless section.settings.text_color_dark.alpha == 0.0 %}
        color: {{ section.settings.text_color_dark }};
      {% else %}
        color: rgba(var(--colors-text));
      {% endunless %}
    }
    .dark .is-scrolled.transparent-header .logo-name, .dark .is-scrolled.transparent-header header {
      color: rgba(var(--colors-text));
    }
  {%- endif -%}
  .logo-name {
    font-size: {{ logo_name | times: 0.5 }}rem;
  }
  header {
    grid-template-areas: "{{ mobile_layout }}"{% if settings.mobile_search_position == 'header' %}{% if search_on_header and section.settings.mobile_header_layout == "left-right" %} "search search"{% elsif search_on_header and section.settings.mobile_header_layout != "left-right" %} "search search search"{% endif %}{% endif %};
    {% if section.settings.mobile_header_layout == 'left-right' -%}
      grid-template-columns: 3fr 3fr;
    {%- endif %}
  }
  @media (min-width: 1024px) {
    header {
      grid-template-areas: "{{ areas }}" "{{ areas_2 }}";
      grid-template-columns: {{ columns }};
    } 
    .logo-name {
      font-size: {{ logo_name }}rem;
    }
    .pt-header {
      padding-top: {{ section.settings.padding_top }}px;
    }
    .pb-header {
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .h-hamburger {
    height: var(--hamburger-menu-height);
  }
  @media (max-width: 1023px) {
    .section-padding-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  } 
{%- endstyle -%} 
<div x-show="$store.xHeaderMenu.overlay" 
  x-transition:enter="ease-in-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition-all ease-in-out duration-300"
  x-transition:leave-end="opacity-0"
  class="bg-[rgba(0,0,0,0.4)] hidden lg:flex fixed top-0 right-0 bottom-0 left-0" x-cloak></div>
<div
  id="x-header-container"
  class="relative text-[rgb(var(--colors-text-header))]{% if transparent %} transparent-header h-0{% else %} background-header{% endif %}"
  {% if request.design_mode %}
    x-intersect="window.addEventListener('announcement:sticky-change', () => {document.getElementById('x-announcement')?.dataset.isSticky == 'true' && $el.classList.add('z-[60]')});"
  {% endif %}
  {% if section.settings.sticky_header_type != "none" %}
    data-is-sticky="true"
    data-section-index="{{ section.index }}"
  {% endif %}
  x-init='() => {
    $store.xHeaderMenu.sectionId = "{{ section.id }}";
    $store.xHeaderMenu.mobileHeaderLayout = "{{ section.settings.mobile_header_layout }}";
    $store.xHeaderMenu.initSticky($el, "{{ section.settings.sticky_header_type }}"{% if transparent %}, true{% endif %});
    {% if request.design_mode %}
      Alpine.store("xHelper").cancelEvent(`eurus:editor-header-init-event`);
      const editorHeaderInitController = new AbortController();
      Alpine.store("xHelper").eventControllers.set(`eurus:editor-header-init-event`, editorHeaderInitController);
      document.addEventListener("shopify:section:load", function(event) {
        $store.xHeaderMenu.reset();
        if (!event.target.id.includes("__header")) {
          $store.xHeaderMenu.sectionId = "{{ section.id }}";
          $store.xHeaderMenu.mobileHeaderLayout = "{{ section.settings.mobile_header_layout }}";
          $store.xHeaderMenu.initSticky($el, "{{ section.settings.sticky_header_type }}"{% if transparent %}, true{% endif %});
        }
      }, { signal: editorHeaderInitController.signal });
    {% endif %}
  }'
  {% if section.settings.sticky_header_type != "none" or settings.cart_type == 'drawer' %}
    :class="($store.xMiniCart.open || $store.xHeaderMenu.show) && 'z-[60]'"
  {% elsif settings.cart_type == 'popup' %}
    :class="($store.xMiniCart.open || $store.xHeaderMenu.show) && 'z-[60] md:z-50'"
  {% else %}
    :class="$store.xHeaderMenu.show && 'z-50'"
  {% endif %}
  @click.away="$store.xHeaderMenu.openHamburgerMenu = false;"
  {% if section.settings.sticky_header_type == 'on-scroll-up' and section.settings.enable_hamburger_menu %}
    @scroll.window="if($store.xHeaderMenu.scrollDir == 'down') {
      setTimeout(() => {
        requestAnimationFrame(() => {
          const submenuEls = $el.getElementsByClassName('toggle-menu');
          const visible = Array.from(submenuEls).filter(el => !el.classList.contains('toggle-menu-hidden'));
          if (visible.length == 0) {
            $store.xHeaderMenu.openHamburgerMenu = false; 
          }
        });
      }, 400);
      $store.xHeaderMenu.overlay = false;
    }"
  {% endif %}
>
  <div
    id="sticky-header-content"
    class="sticky-header-content background-header sticky-header-active z-20 w-full top-0{% if transparent %} absolute disable-tranparent-collection{% endif %}
    {% if section.settings.full_width %} header-full-width{% endif %}"
    :class="{ 'padding-scrollbar-header': $store.xHeaderMenu.isSticky && ($store.xPopup.open || $store.xPopup.openVideoShopping), 'static': $store.xHeaderMenu.overlay, 'relative': !$store.xHeaderMenu.overlay}"
    {% if transparent %}
      @click="if (!window.matchMedia('(min-width: 768px)').matches) $el.classList.add('is-touched');"
      @click.away="if (window.scrollY === 0) { 
        if (!window.matchMedia('(min-width: 768px)').matches) $el.classList.remove('is-touched');
      }"
    {% endif %}
  >
    <header 
      class="header lg:pb-0 section-padding-{{ section.id }} pt-header lg:pb-0{% if section.settings.full_width %} full-width{% else %} x-pgw page-width{% endif %} grid lg:mr-auto lg:ml-auto gap-x-2{% if logo_above %} items-center{% endif %}" :class="{ '{% unless header_top %} lg:pt-5{% endunless %}': !$store.xHeaderMenu.isSticky, 'open-menu': $store.xHeaderMenu.overlay }"
      {% if section.settings.select_motion == 'hover' %}x-on:mouseleave="$store.xHeaderMenu.closeMenu()"{% endif %}
    >
      <div data-breakpoint="tablet" class="x-container-header-mobile-nav [grid-area:drawer] lg:hidden flex items-center w-full{% if section.settings.mobile_header_layout contains 'right' %} justify-end{% endif %}">
        {% comment %} Mobile header layout: logo left, menu right{% endcomment %}
        {% if section.settings.mobile_header_layout == 'left-right' %}
          <div class="flex justify-end lg:order-4 [grid-area:icons] -mr-2{% unless logo_above %} pb-header{% endunless %}">
            {% assign sidebar_blocks = section.blocks | where: 'type', 'sidebar_content' %}
            {% if section.settings.enable_sidebar and sidebar_blocks.size > 0 %}
              <div x-data="{show: false}" class="x-header-sidebar flex items-center">
                {% if section.settings.icon_header_sidebar != 'none' %}
                  {% unless section.settings.custom_image_header_sidebar == blank and section.settings.custom_icon_header_sidebar == blank and section.settings.another_icon_header_sidebar == blank and section.settings.icon_header_sidebar == 'another_icon' %}
                    <span @click="show = true" class="relative w-11 h-10 pt-2.5 pb-2 pl-3 pr-3 cursor-pointer overflow-hidden{% if section.settings.custom_image_header_sidebar != blank %} animate-Xpulse skeleton-image{% endif %}">
                      {% if section.settings.custom_image_header_sidebar != blank %}
                        {% # theme-check-disable ImgLazyLoading %}
                        <img 
                          src="{{ section.settings.custom_image_header_sidebar | image_url: width: 44 }}"
                          alt="{{ section.settings.custom_image_header_sidebar.alt | escape }}"
                          {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                          onload="requestAnimationFrame(() => { this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image'); });"
                          width="{{ section.settings.custom_image_header_sidebar.width }}"
                          height="{{ section.settings.custom_image_header_sidebar.height }}"
                          style="object-position: {{ section.settings.custom_image_header_sidebar.presentation.focal_point }}; transform: scale({{ section.settings.sidebar_image_zoom | divided_by: 100.0 }}); transform-origin: center;"
                          class="object-cover absolute top-0 left-0 w-full h-full"
                        >
                        {% # theme-check-enable ImgLazyLoading %}
                      {% else %}
                        {% if section.settings.custom_icon_header_sidebar == blank %}
                          {% if section.settings.another_icon_header_sidebar != blank and section.settings.icon_header_sidebar == 'another_icon' %}
                            {% render 'icon-new-alls', icon: section.settings.another_icon_header_sidebar %}
                          {% else %}
                            {% render 'icon-labels-bags', icon: section.settings.icon_header_sidebar %}
                          {% endif %}
                        {% else %}
                          {{ section.settings.custom_icon_header_sidebar }}
                        {% endif %}
                      {% endif %}
                    </span>
                  {% endunless %}
                {% else %}
                  <span @click="show = true" class="w-11 h-10 pt-2.5 pb-2 pl-3 pr-3 cursor-pointer">{% render 'icon-alls', icon: 'icon-discount', animation_class: 'icon-animation' %}</span>
                {% endif %}
                <template x-teleport="body">
                  {% render 'header-sidebar', section: section %}
                </template>
              </div>
            {% endif %}
            {%- if settings.search_enabled -%}
              <div class="{% if settings.mobile_search_position == 'header' %}flex{% else %}hidden md:flex{% endif %}{% if section.settings.search_on_header %} hidden{% endif %} items-center justify-center mobile-{{ section.settings.mobile_header_layout }}" 
                @init-run.window="$store.xHeaderMenu.renderAjax($el, 'header-search-block', '#ajax-loading-header-search');"
              >
                <a 
                  id="SearchOpen"
                  href="{{ routes.search_url }}" 
                  aria-label="search"
                  class="flex items-center cursor-pointer justify-center link focus-inset bg-none" 
                  @click.prevent="setTimeout(() => { $store.xModal.setActiveElement('SearchOpen'); }, 0)">
                  <span class="w-11 h-10 pl-3 pr-3 pt-2.5 pb-2">{% render 'icon-alls', icon: 'icon-search', animation_class: 'icon-animation' %}</span>
                </a>
              </div>
            {%- endif -%}
            {%- if shop.customer_accounts_enabled -%}
              <shopify-account class="header-icon-account hidden lg:flex relative items-center justify-center" menu="{{ settings.customer_account_menu }}">
                <div slot="signed-out-avatar">
                  <span style="display:inline-flex;align-items:center;justify-content:center;width:var(--gg-icon-size);height:var(--gg-icon-size);">
                    <span style="display:inline-flex;width:100%;height:100%;transform:scale(var(--gg-account-scale));transform-origin:center;">
                      {%- if section.settings.custom_account_icon_image != blank -%}
                        <img src="{{ section.settings.custom_account_icon_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;">
                      {%- else -%}
                        {% render 'icon-custom-login' %}
                      {%- endif -%}
                    </span>
                  </span>
                </div>
              </shopify-account>
            {%- endif -%}
            {%- unless settings.hide_cart -%}
              <div class="header-icon-cart cursor-pointer relative flex items-center">
                <a 
                  id="cart-icon"
                  href="{{ routes.cart_url }}"
                  class="relative flex items-center"              
                  {% if settings.cart_type != 'page' %}
                    @click.prevent="setTimeout(() => { $store.xModal.setActiveElement('cart-icon'); $store.xMiniCart.openCart(); }, 0)"
                    :class="$store.xMiniCart.open && 'pointer-events-none'"
                  {% endif %}
                  aria-controls="CartDrawer"
                  aria-expanded="false"
                  aria-label="icon-cart"
                >
                  <span style="display:inline-flex;align-items:center;justify-content:center;width:var(--gg-icon-size);height:var(--gg-icon-size);">
                    <span style="display:inline-flex;width:100%;height:100%;transform:scale(var(--gg-cart-scale));transform-origin:center;">
                      {%- if section.settings.custom_cart_icon_image != blank -%}
                        <img src="{{ section.settings.custom_cart_icon_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;">
                      {%- else -%}
                        {% render 'icon-custom-cart' %}
