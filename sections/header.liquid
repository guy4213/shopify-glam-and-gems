              type="search"
              name="q"
              class="gg-search-input w-full border border-solid py-2 pl-4 pr-10 outline-none"
              placeholder="{{ section.settings.search_placeholder_text }}"
              aria-label="{{ section.settings.search_placeholder_text }}"
            >
            <button
              type="submit"
              class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center opacity-70 bg-transparent border-0 cursor-pointer"
              aria-label="Search"
            >
              {%- if section.settings.custom_search_icon != blank -%}
                {{ section.settings.custom_search_icon }}
              {%- else -%}
                {%- render 'icon-alls', icon: 'icon-search', animation_class: 'icon-animation' -%}
              {%- endif -%}
            </button>
          </form>
          {%- if section.settings.consultation_text != blank -%}
