            .mobile-navigation-modern-icon-bg {
              background: transparent;
            }
            .is-sticky #sticky-header-content.background-header .mobile-navigation-modern-icon-bg,
            .is-scrolled #sticky-header-content.background-header .mobile-navigation-modern-icon-bg,
            #sticky-header-content.background-header:has(.open-menu) .mobile-navigation-modern-icon-bg,
            #sticky-header-content.background-header.is-touched .mobile-navigation-modern-icon-bg,
            #sticky-header-content:hover .mobile-navigation-modern-icon-bg {
              background: rgba(var(--colors-line-header),1);
            }
            .is-sticky #sticky-header-content.background-header .mobile-navigation-modern-icon-bg,
            .is-scrolled #sticky-header-content.background-header .mobile-navigation-modern-icon-bg,
            #sticky-header-content.background-header:has(.open-menu) .mobile-navigation-modern-icon-bg,
            #sticky-header-content.background-header.is-touched .mobile-navigation-modern-icon-bg,
            #sticky-header-content:hover .mobile-navigation-modern-icon-bg {
