              {% render 'header-sidebar', section: section %}              
            </template>
          </div>
        {% endif %}
        {%- unless section.settings.show_custom_left_section -%}
        {%- if settings.search_enabled -%}
          {% style %}
            {% if settings.icon_options == "modern" %}
              @media (max-width: 767px) {
                .mobile-center-left #SearchOpen {
                  left: 3.5rem;
                }
                .mobile-center-right #SearchOpen {
                  right: 3.5rem;
                }
              }
            {% endif %}
          {% endstyle %}
          <div class="x-header-icon-search{% unless section.settings.search_on_header %} hidden lg:flex{% else %} hidden{% endunless %} items-center justify-center mobile-{{ section.settings.mobile_header_layout }}" @init-run.window="$store.xHeaderMenu.renderAjax($el, 'header-search-block', '#ajax-loading-header-search');">
            <a
              id="SearchOpen"
              href="{{ routes.search_url }}"
              aria-label="search"
              class="flex items-center cursor-pointer justify-center link focus-inset bg-none"
              @click.prevent="setTimeout(() => { $store.xModal.setActiveElement('SearchOpen'); }, 0)">
              <span class="w-11 h-10 pl-3 pr-3 pt-2.5 pb-2">{% render 'icon-alls', icon: 'icon-search', animation_class: 'icon-animation' %}</span>
            </a>
          </div>
        {%- endif -%}
        {%- endunless -%}
        {%- if section.settings.mobile_icon_1_image != blank -%}
          <a
            href="{{ section.settings.mobile_icon_1_link | default: '#' }}"
            class="flex lg:hidden items-center justify-center cursor-pointer"
            style="width:var(--gg-icon-size);height:var(--gg-icon-size);"
            aria-label="Mobile icon 1"
          >
            <img src="{{ section.settings.mobile_icon_1_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;transform:scale(var(--gg-mobile-right-scale));transform-origin:center;">
          </a>
        {%- endif -%}
        {%- if section.settings.mobile_icon_2_image != blank -%}
          <a
            href="{{ section.settings.mobile_icon_2_link | default: '#' }}"
            class="flex lg:hidden items-center justify-center cursor-pointer"
            style="width:var(--gg-icon-size);height:var(--gg-icon-size);"
            aria-label="Mobile icon 2"
          >
            <img src="{{ section.settings.mobile_icon_2_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;transform:scale(var(--gg-mobile-right-scale));transform-origin:center;">
          </a>
        {%- endif -%}
        {%- if section.settings.mobile_icon_3_image != blank -%}
          <a
            href="{{ section.settings.mobile_icon_3_link | default: '#' }}"
            class="flex lg:hidden items-center justify-center cursor-pointer"
            style="width:var(--gg-icon-size);height:var(--gg-icon-size);"
            aria-label="Mobile icon 3"
          >
            <img src="{{ section.settings.mobile_icon_3_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;transform:scale(var(--gg-mobile-right-scale));transform-origin:center;">
          </a>
        {%- endif -%}
        {%- if section.settings.show_wishlist_icon -%}
          <a
            href="{{ section.settings.wishlist_link | default: '/wishlist' }}"
            class="relative hidden lg:flex items-center justify-center"
            aria-label="Wishlist"
          >
            <span class="relative flex items-center justify-center" style="width:var(--gg-icon-size);height:var(--gg-icon-size);">
              <span style="display:inline-flex;width:100%;height:100%;transform:scale(var(--gg-wishlist-scale));transform-origin:center;">
                {%- if section.settings.custom_wishlist_icon_image != blank -%}
                  <img src="{{ section.settings.custom_wishlist_icon_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;">
                {%- elsif section.settings.custom_wishlist_icon != blank -%}
                  {{ section.settings.custom_wishlist_icon }}
                {%- else -%}
                  {% render 'icon-custom-wishlist' %}
                {%- endif -%}
              </span>
            </span>
          </a>
        {%- endif -%}
        {%- if shop.customer_accounts_enabled -%}
          <shopify-account class="header-icon-account hidden lg:flex relative items-center justify-center" style="align-self:center;" menu="{{ settings.customer_account_menu }}">
            <div slot="signed-out-avatar" style="display:flex;align-items:center;justify-content:center;">
              <span style="display:inline-flex;align-items:center;justify-content:center;width:var(--gg-icon-size);height:var(--gg-icon-size);transform:translateY({{ section.settings.header_account_icon_offset | default: 0 }}px);">
                <span style="display:inline-flex;width:100%;height:100%;transform:scale(var(--gg-account-scale));transform-origin:center;">
                  {%- if section.settings.custom_account_icon_image != blank -%}
                    <img src="{{ section.settings.custom_account_icon_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;">
                  {%- else -%}
                    {% render 'icon-custom-login' %}
                  {%- endif -%}
                </span>
              </span>
            </div>
          </shopify-account>
        {%- endif -%}
        {%- unless settings.hide_cart -%}
          <a
            id="cart-icon"
            href="{{ routes.cart_url }}"
            class="relative flex items-center header-icon-cart cursor-pointer"
            {% if settings.cart_type != 'page' %}
              @click.prevent="setTimeout(() => { $store.xModal.setActiveElement('cart-icon'); $store.xMiniCart.openCart(); }, 0)"
              :class="$store.xMiniCart.open && 'pointer-events-none'"
            {% endif %}
            aria-controls="CartDrawer"
            aria-expanded="false"
            aria-label="icon-cart"
          >
            <span class="relative inline-flex items-center justify-center" style="width:var(--gg-icon-size);height:var(--gg-icon-size);">
              <span style="display:inline-flex;width:100%;height:100%;transform:scale(var(--gg-cart-scale));transform-origin:center;">
                {%- if section.settings.custom_cart_icon_image != blank -%}
                  <img src="{{ section.settings.custom_cart_icon_image | image_url: width: 128 }}" alt="" style="width:100%;height:100%;object-fit:contain;display:block;">
                {%- else -%}
                  {% render 'icon-custom-cart' %}
                {%- endif -%}
              </span>
              <div id="cart-icon-bubble" >
                <div
                  class="count_item absolute text-center place-content-center -top-0.5{% if settings.theme_mode_enabled %}{% if section.settings.mobile_header_layout == 'center-right' %} left-0{% else %} right-0{% endif %}{% else %}{% if section.settings.mobile_header_layout == 'center-left' %} -right-1.5{% endif %}{% endif %} md:right-0{% if section.settings.mobile_header_layout == 'center-right' %} lg:left-auto lg:right-0 rtl:lg:right-auto rtl:lg:left-0{% endif %} bg-[rgba(var(--colors-cart))] text-[rgba(var(--colors-cart-text))] font-medium h-5 w-5 rounded-full text-[9px]{% if cart == empty %} hidden{% endif %}"
                  data-value="{{ cart.item_count }}"
                >
                  {%- if cart.item_count < 100 -%}{{ cart.item_count }}{%- else -%}99+{%- endif -%}
                </div>
              </div>
            </span>
          </a>
        {%- endunless -%}
        {%- if settings.theme_mode_enabled -%}
          {%- if settings.theme_mode_mode == 'switch' -%}
            <theme-mode x-data
              class="flex items-center lg:justify-center cursor-pointer
                {%- unless show_theme_mode_on_header %} hidden md:flex{% else %} flex{% endunless -%}
                {%- if settings.icon_options == 'classic' %} w-10 lg:ml-2 rtl:lg:ml-0 rtl:lg:mr-2{% else %} md:w-fit lg:ml-5.5 rtl:lg:mr-5.5 lg:border-r-0 lg:border-l rtl:border-l-0 rtl:border-r h-fit self-center border-solid 
                  {%- if section.settings.mobile_header_layout == 'center-right' %} mr-1{% elsif section.settings.mobile_header_layout == 'center-left' %} ml-1{% endif -%}
                  {%- unless settings.hide_cart %}{% if section.settings.mobile_header_layout == 'center-right' %} border-r{% else %} border-l{% endif %}{% endunless -%}
                {%- endif -%}
                {%- if section.settings.mobile_header_layout == 'center-right' %} justify-start{% else %} justify-end{% endif %}"
            >
              <button
                @click.prevent="$store.xDarkMode.toggleThemeMode()"
                class="{% if settings.icon_options == 'classic' %}md:pt-2.5 md:pb-2.5 md:pl-2.5 md:pr-2.5 button button-action pt-2.5 pb-2.5 pl-2.5 pr-2.5 rounded-full {% else %} md:pt-0 pb-0 lg:pl-7 rtl:lg:pl-0 rtl:lg:pr-7 {% endif %} text-sm {% if settings.icon_options == "modern" %}{% if section.settings.mobile_header_layout == 'left-right' %}mr-4 md:mr-0{% elsif section.settings.mobile_header_layout == 'center-right' %}pr-3{% else %}pl-3{% endif %}{% endif %}"
                aria-label="darkmode"
              >
                <span class="block {% if settings.icon_options == 'classic' %} w-4 lg:w-5{% else %} w-6{% endif %}" x-show="$store.xDOM.rePainting === $store.xDarkMode.alias" x-cloak>
                  {% render 'icon-alls', icon: 'icon-loading' %}
                </span>
                <span class="hidden dark:block{% if settings.icon_options == 'classic' %} w-4 lg:w-5{% else %} w-6{% endif %}" x-show="$store.xDOM.rePainting !== $store.xDarkMode.alias">
                  {% if settings.icon_options == 'classic' %}
                    <svg
                      class="svg-icon icon-animation"
                      style="vertical-align: middle;fill: currentColor;overflow: hidden;"
                      viewBox="0 0 1024 1024"
                      version="1.1"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M557.250088 959.028243c-247.490697 0-448.826192-199.306278-448.826192-446.783673 0-244.284679 198.73118-446.636317 443.002556-446.636317 0.119727 0 0.226151 0 0.346901 0 10.354835 0 19.840884 3.807722 24.477484 13.094226 4.688789 9.379625 3.593851 19.61371-2.805906 27.92398-53.604872 69.477374-81.928964 152.101163-81.928964 239.895719 0 217.308281 176.792519 393.82553 394.1008 393.82553l5.051039-0.239454c9.927093-0.134053 20.175505 5.638417 24.864294 15.043624 4.704139 9.379625 3.621481 20.603247-2.804882 28.91454C826.947554 895.269104 697.373453 959.028243 557.250088 959.028243zM497.340627 120.789017c-188.636265 29.113061-334.191338 193.506179-334.191338 389.410987 0 217.294978 176.792519 394.1008 394.1008 394.1008 104.550171 0 202.412013-40.456411 275.696086-112.540146-222.772736-26.1598-396.157645-216.07929-396.157645-445.747063C436.787506 265.754666 457.578018 188.916651 497.340627 120.789017z"  /><path d="M577.719282 865.501126c-179.75806 0-332.640006-128.359436-363.490641-305.211307-1.296529-7.441483 3.687996-14.536065 11.129478-15.833617 7.54893-1.2689 14.537088 3.687996 15.832594 11.130502 28.55229 163.705456 170.09191 282.536888 336.52857 282.536888 7.563256 0 13.682627 6.119371 13.682627 13.681604C591.40191 859.381755 585.281515 865.501126 577.719282 865.501126z"  /><path d="M222.886835 530.788925c-7.255241 0-13.307074-6.734378-13.654998-14.055111-0.306992-6.333242-0.467651-13.267165-0.467651-19.694551 0-7.562233 6.118348-13.935384 13.681604-13.935384s13.681604 5.998621 13.681604 13.560854c0 5.998621 0.160659 12.920264 0.441045 18.839067 0.361227 7.54893-5.464455 15.285125-13.013385 15.285125C223.326856 530.788925 223.112985 530.788925 222.886835 530.788925z"  /><path d="M642.680806 310.140573c4.300956 12.746302-2.566452 26.587542-15.311731 30.890544-12.747325 4.288676-26.588565-2.565429-30.891568-15.325034-4.275373-12.746302 2.565429-26.575262 15.311731-30.877241C624.56317 290.525839 638.377804 297.394271 642.680806 310.140573z"  /><path d="M801.146934 193.09788c4.275373 12.746302-2.565429 26.588565-15.337313 30.890544-12.747325 4.275373-26.561959-2.565429-30.864962-15.325034-4.300956-12.746302 2.566452-26.574239 15.311731-30.877241C783.003715 173.48417 796.844955 180.351578 801.146934 193.09788z"  /><path d="M748.131487 411.503145c4.301979 12.759605-2.565429 26.588565-15.311731 30.890544-12.746302 4.288676-26.587542-2.565429-30.891568-15.311731-4.300956-12.746302 2.566452-26.587542 15.311731-30.890544C729.987245 391.889435 743.829508 398.756843 748.131487 411.503145z"  />
                    </svg>
                  {% else %}
                    <svg class="icon-animation" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none">
                      <path d="M12 2C6.47715 2 2 6.47715 2 12C2 17.5229 6.47715 22 12 22C17.5229 22 22 17.5229 22 12C22 6.47715 17.5229 2 12 2ZM12 20.75C7.1675 20.75 3.25 16.8325 3.25 12C3.25 7.1675 7.1675 3.25 12 3.25C16.8325 3.25 20.75 7.1675 20.75 12C20.75 16.8325 16.8325 20.75 12 20.75Z" fill="currentColor"/>
                      <path d="M12 5.125C11.6548 5.125 11.375 5.4048 11.375 5.75V18.25C11.375 18.5952 11.6548 18.875 12 18.875C15.797 18.875 18.875 15.797 18.875 12C18.875 8.20305 15.797 5.125 12 5.125Z" fill="currentColor"/>
                    </svg>
                  {% endif %}
                </span>
                <span class="block dark:hidden{% if settings.icon_options == 'classic' %} w-4 lg:w-5{% else %} w-6{% endif %}" x-show="$store.xDOM.rePainting !== $store.xDarkMode.alias">
                  {% if settings.icon_options == 'classic' %}
                    <svg class="svg-icon icon-animation" style="fill: currentColor;overflow: hidden;"  viewBox="0 0 1024 1024"  version="1.1" xmlns="http://www.w3.org/2000/svg">
                      <path d="M512 704a192 192 0 1 0 0-384 192 192 0 0 0 0 384z m0 64a256 256 0 1 1 0-512 256 256 0 0 1 0 512zM32 480h128a32 32 0 1 1 0 64H32a32 32 0 1 1 0-64z m832 0h128a32 32 0 1 1 0 64H864a32 32 0 1 1 0-64zM480 992V864a32 32 0 1 1 64 0v128a32 32 0 1 1-64 0z m0-832V32a32 32 0 1 1 64 0v128a32 32 0 1 1-64 0z m348.8 714.027l-90.539-90.496a32 32 0 1 1 45.27-45.227l90.496 90.453a32 32 0 0 1-45.227 45.27zM240.47 285.739L149.972 195.2a32 32 0 1 1 45.227-45.227l90.539 90.496a32 32 0 1 1-45.27 45.227z m633.6-90.539l-90.54 90.539a32 32 0 1 1-45.226-45.27l90.453-90.496a32 32 0 0 1 45.227 45.227zM285.652 783.53L195.2 874.028a32 32 0 0 1-45.27-45.227l90.497-90.539a32 32 0 1 1 45.226 45.27z"  />
                    </svg>
                  {% else %}
                    <svg class="icon-animation" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none">
                      <path d="M12 2C6.47715 2 2 6.47715 2 12C2 17.5229 6.47715 22 12 22C17.5229 22 22 17.5229 22 12C22 6.47715 17.5229 2 12 2ZM12 20.75C7.1675 20.75 3.25 16.8325 3.25 12C3.25 7.1675 7.1675 3.25 12 3.25C16.8325 3.25 20.75 7.1675 20.75 12C20.75 16.8325 16.8325 20.75 12 20.75Z" fill="currentColor"/>
                      <path d="M12.25 5.125C12.5952 5.125 12.875 5.4048 12.875 5.75V18.25C12.875 18.5952 12.5952 18.875 12.25 18.875C8.45305 18.875 5.375 15.797 5.375 12C5.375 8.20305 8.45305 5.125 12.25 5.125Z" fill="currentColor"/>
                    </svg>
                  {% endif %}
                </span>
              </button>
            </theme-mode>
          {%- endif -%}
        {%- endif -%}
      </div>

      {% if search_on_header and enable_compact_menu %}
        {% render 'header-search-item' %}
      {% endif %}

      {% unless section.settings.enable_hamburger_menu %}
        {% if section.settings.enable_drawer_menu %}
          <div tabindex="-1" class="hidden lg:flex{% if section.blocks.size == 0 and section.settings.menu == blank %} invisible{% endif %} pb-header [grid-area:navigation] lg:[grid-area:navigation]">
            <div @click="setTimeout(() => { $store.xMenuDrawer.open() }, 0)"  tabindex="0" class="x-container-header-nav cursor-pointer hidden lg:flex flex-row items-center w-fit gap-1 header__inline-menu">
              <div class="w-5 mt-2.5 mb-2.5 ml-2.5 mr-2.5">
                <span>{% render 'icon-alls', icon: 'icon-hamburger' %}</span>
              </div>
              <span id="drawer-menu-text" class="leading-none">{{ 'header.menu' | t }}</span>
            </div>
          {% if request.design_mode %}
            {% style %}
              body:not(:has(#teaser-menu-drawer)) #teaser-menu-container {
                display: none
              }
            {% endstyle %}
          {% endif %}
        <div {% if request.design_mode %}x-init="document.addEventListener('eurus:teaser-menu:changed', (e) => { if(e.detail.hasTeaserMenu == false) { $el.innerHTML = '' } })"{% endif %} id="teaser-menu-container" class="empty:hidden ml-1 rtl:mr-1 rtl:ml-0 flex items-center"></div>
          </div>
        {% else %}
          {%- render 'header-megamenu-block', logo_above: logo_above, logo_center: logo_center, select_motion: section.settings.select_motion, transparent: transparent, search_on_header: search_on_header, enable_compact_menu: enable_compact_menu -%}
        {% endif %}
      {% else %}
        <div tabindex="-1" class="hidden md:flex{% if section.blocks.size == 0 and section.settings.menu == blank %} invisible{% endif %} pb-header [grid-area:navigation] lg:[grid-area:navigation]">
          <div tabindex="0" @keydown.enter="$store.xHeaderMenu.openHamburgerMenu = !$store.xHeaderMenu.openHamburgerMenu" @click="$store.xHeaderMenu.openHamburgerMenu = !$store.xHeaderMenu.openHamburgerMenu" class="x-container-header-nav cursor-pointer hidden lg:flex flex-row items-center w-fit gap-1 header__inline-menu">
            <div class="w-5 mt-2.5 mb-2.5 ml-2.5 mr-2.5">
              <span x-cloak x-show="!$store.xHeaderMenu.openHamburgerMenu">{% render 'icon-alls', icon: 'icon-hamburger' %}</span>
              <span x-cloak x-show="$store.xHeaderMenu.openHamburgerMenu">{% render 'icon-alls', icon: 'icon-close' , icon_modern: true %}</span>
            </div>
            <span x-cloak x-show="!$store.xHeaderMenu.openHamburgerMenu" class="leading-none">{{ 'header.menu' | t }}</span>
            <span x-cloak x-show="$store.xHeaderMenu.openHamburgerMenu" class="leading-none">Hide menu</span>
          </div>
        </div>
      {% endunless %}
    </header>
    {% if section.settings.enable_hamburger_menu %}
      {%- if transparent -%}
        {% style %}
          #x-header-container:not(.sticky-header) #sticky-header-content:not(:hover) .bg-hamburger {
            background: transparent;
          }
        {% endstyle %}
      {% endif %}
      <div x-cloak x-intersect.once="$el.style.setProperty('--hamburger-menu-height', $el.querySelector('.x-container-header-nav').offsetHeight + 'px');" :class="$store.xHeaderMenu.openHamburgerMenu ? 'h-hamburger' : 'h-0'" {% if section.settings.select_motion == "hover" %}@mouseleave="$store.xHeaderMenu.closeMenu();"{% endif %} :class="!$store.xHeaderMenu.openHamburgerMenu && 'bg-hamburger'" class="hamburger-menu-container transition-all duration-300 ease-in-out absolute background-header flex w-full justify-center">
        <div :class="$store.xHeaderMenu.openHamburgerMenu ? 'overflow-visible pl-5 pr-5' : 'overflow-hidden pl-5 pr-5'" class="w-full{% unless section.settings.full_width %} x-pgw page-width{% endunless %}">
          {%- render 'header-megamenu-block', logo_above: logo_above, logo_center: logo_center, select_motion: section.settings.select_motion, transparent: transparent, enable_hamburger: enable_compact_menu, search_on_header: search_on_header, enable_compact_menu: enable_compact_menu -%}
        </div>
      </div>
    {% endif %}
    {%- if section.settings.show_section_divider or section.settings.show_section_divider_mobile -%}
      {% render 'section-divider', classHeader: ' absolute top-full left-0 w-full' %}
    {%- endif -%}
  </div>
</div>
{% unless settings.show_minicart %}
    {% render 'cart-noti', sticky_header: section.settings.sticky_header_type %}
{% endunless %}
{%- unless template == 'cart' or settings.cart_type == 'page' -%}
  <div id="x-cart-drawer-container" class="z-[70]{% if settings.cart_type == 'popup' %} fixed md:sticky{% if section.settings.sticky_header_type == 'on-scroll-up' %} scroll-sticky-popup-cart{% endif %}{% else %} fixed{% endif %}" @init-run.window="$store.xHeaderMenu.renderAjax($el, 'cart-drawer', '#ajax-loading-cart');"></div>
{%- endunless -%}
<script src="{{ 'search-prompts.js' | asset_url }}" defer></script>                   
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if section.settings.logo %}
      "logo": {{ section.settings.logo | image_url: width: section.settings.logo.width | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>
{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: "?q={search_term_string}" %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}
<script src="{{ 'store-selector.js' | asset_url }}" defer="defer"></script>
{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header z-50",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.user_guide_link.header.header_general"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.mobile-navigation.settings.menu.label",
      "info": "t:sections.mobile-navigation.settings.menu.info"
    },
    {
      "type": "checkbox",
      "id": "enable_hamburger_menu",
      "label": "t:sections.header.settings.enable_hamburger_menu.label",
      "default": false
    },
