            --gg-search-border: {{ section.settings.search_border_color }};
            --gg-search-radius: {{ section.settings.search_border_radius }}px;
            --gg-search-ph-color: {{ section.settings.search_placeholder_color }};
            --gg-search-font-size: {{ section.settings.search_font_size }}px;
            --gg-search-font-weight: {{ section.settings.search_font_weight }};
            --gg-consult-font-size: {{ section.settings.consultation_font_size }}px;
