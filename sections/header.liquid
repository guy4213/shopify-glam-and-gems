            {%- if search_on_header and enable_compact_menu == false %} lg:justify-start lg:mr-0 lg:ml-0 lg:relative lg:left-0 lg:translate-x-0 lg:mt-0 lg:top-0{% else %} lg:mr-auto lg:ml-auto lg:pb-0 lg:justify-center{% endif -%}
          {%- endif %}"
        >
      {% else %}
