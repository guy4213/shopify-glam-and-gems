<script>
(function () {
  var WISHLIST_KEYS = ['shopify-wishlist', 'wishlist', 'swym-wishlist', 'wishlist_items'];

  function updateWishlistBadge(count) {
    var n = parseInt(count, 10) || 0;
    var label = n > 99 ? '99+' : String(n);
    var svgText = document.getElementById('wishlist-badge-text');
    if (svgText) svgText.textContent = label;
  }

  function readFromLocalStorage() {
    try {
      for (var i = 0; i < WISHLIST_KEYS.length; i++) {
        var raw = localStorage.getItem(WISHLIST_KEYS[i]);
        if (!raw) continue;
        var parsed = JSON.parse(raw);
        if (Array.isArray(parsed)) return parsed.length;
        if (parsed && typeof parsed.count === 'number') return parsed.count;
        if (parsed && Array.isArray(parsed.items)) return parsed.items.length;
      }
    } catch (e) {}
    return 0;
  }

  document.addEventListener('DOMContentLoaded', function () {
    updateWishlistBadge(readFromLocalStorage());
  });

  /* Standard Shopify wishlist app event */
  document.addEventListener('wishlist:updated', function (e) {
    var c = e.detail && (e.detail.count != null ? e.detail.count
      : e.detail.items ? e.detail.items.length : null);
    updateWishlistBadge(c != null ? c : readFromLocalStorage());
  });

  /* Cross-tab localStorage sync */
  window.addEventListener('storage', function (e) {
    if (WISHLIST_KEYS.indexOf(e.key) !== -1) {
      updateWishlistBadge(readFromLocalStorage());
    }
  });

  /* Global hook for any wishlist app */
  window.updateWishlistCount = updateWishlistBadge;
})();
</script>
