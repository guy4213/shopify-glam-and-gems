              <span class="flex-shrink-0 flex items-center justify-center" style="width: var(--gg-consult-icon-size); height: var(--gg-consult-icon-size); transform: scale(var(--gg-consult-icon-scale));">
                {%- if section.settings.consultation_icon_image != blank -%}
                  {{ section.settings.consultation_icon_image | image_url: width: 40 | image_tag: loading: 'lazy', class: 'w-full h-full object-contain' }}
                {%- elsif section.settings.custom_consultation_icon != blank -%}
                  {{ section.settings.custom_consultation_icon }}
                {%- else -%}
                  {%- render 'icon-alls', icon: section.settings.consultation_icon, animation_class: 'icon-animation' -%}
                {%- endif -%}
              </span>
              <span class="gg-consult-text">{{ section.settings.consultation_text }}</span>
            </a>
          {%- endif -%}
        </div>
