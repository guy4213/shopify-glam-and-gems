{% doc %}
  @prompt
    Create a "Diamond Shapes" section where each item is a separate block that can be added, duplicated, or removed from the theme editor. Each block contains one image and a text label displayed underneath the image (outside and below, not overlaid on it). The section should display all items in a single row. The number of items per row should be configurable in the section settings. Each block's image and text should be fully customizable from the theme editor. The section should also have an optional section title at the top. This must be built with a blocks-based architecture so merchants can freely add or remove items without touching any code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .gg-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    padding: {{ block.settings.block_padding_top }}px 0 {{ block.settings.block_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    box-sizing: border-box;
  }
  .gg-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }
  .gg-title-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
  }
  .gg-carousel-{{ ai_gen_id }} {
    position: relative;
    padding: 0 56px;
  }
  .gg-track-{{ ai_gen_id }} {
    overflow: hidden;
  }
  .gg-inner-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.grid_gap }}px;
    transition: transform 0.4s ease;
  }
  .gg-item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.grid_gap }}px * ({{ block.settings.items_per_row }} - 1)) / {{ block.settings.items_per_row }});
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.image_text_spacing }}px;
    max-width: {{ block.settings.max_item_width }}px;
  }
  .gg-img-wrap-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background: #f5f5f5;
  }
  .gg-img-wrap-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center;
  }
  .gg-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #ffffff;
    border: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    z-index: 10;
    padding: 0;
  }
  .gg-arrow-{{ ai_gen_id }}:hover {
    background: #f0f0f0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.22);
  }
  .gg-prev-{{ ai_gen_id }} { left: 0; }
  .gg-next-{{ ai_gen_id }} { right: 0; }
  @media screen and (max-width: 989px) {
    .gg-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.grid_gap }}px * ({{ block.settings.items_per_row_tablet }} - 1)) / {{ block.settings.items_per_row_tablet }});
    }
  }
  @media screen and (max-width: 749px) {
    .gg-carousel-{{ ai_gen_id }} { padding: 0; }
    .gg-arrow-{{ ai_gen_id }} { display: none !important; }
    .gg-track-{{ ai_gen_id }} { overflow: visible; }
    .gg-inner-{{ ai_gen_id }} {
      flex-wrap: wrap;
      transform: none !important;
    }
    .gg-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.grid_gap }}px * ({{ block.settings.items_per_row_mobile }} - 1)) / {{ block.settings.items_per_row_mobile }});
    }
  }
  {% unless block.settings.show_arrows_desktop %}
    @media screen and (min-width: 990px) {
      .gg-arrow-{{ ai_gen_id }} { display: none !important; }
      .gg-carousel-{{ ai_gen_id }} { padding: 0 !important; }
    }
  {% endunless %}
  {% unless block.settings.show_arrows_tablet %}
    @media screen and (min-width: 750px) and (max-width: 989px) {
      .gg-arrow-{{ ai_gen_id }} { display: none !important; }
      .gg-carousel-{{ ai_gen_id }} { padding: 0 !important; }
    }
  {% endunless %}
{% endstyle %}

<div class="gg-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="gg-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="gg-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    {% liquid
      assign ppv      = block.settings.items_per_row
      assign ppv_tab  = block.settings.items_per_row_tablet
      assign ppv_mob  = block.settings.items_per_row_mobile
      assign gap_px   = block.settings.grid_gap
    %}

    <div class="gg-carousel-{{ ai_gen_id }}"
      x-data="{
        cur: 0,
        get ppv() {
          return window.innerWidth <= 749 ? {{ ppv_mob }} : (window.innerWidth <= 989 ? {{ ppv_tab }} : {{ ppv }});
        },
        get gap() { return {{ gap_px }}; },
        get total() { return {{ block.settings.mobile_max_items | default: 8 }}; },
        get maxCur() { return Math.max(0, this.total - this.ppv); },
        itemW() {
          const el = this.$refs.inner.firstElementChild;
          return el ? el.offsetWidth : 280;
        },
        slide() {
          this.$refs.inner.style.transform = 'translateX(calc(-' + this.cur + ' * (' + this.itemW() + 'px + ' + this.gap + 'px)))';
        },
        prev() { if(this.cur > 0){ this.cur--; this.slide(); } },
        next() { if(this.cur < this.maxCur){ this.cur++; this.slide(); } }
      }"
    >
      <button class="gg-arrow-{{ ai_gen_id }} gg-prev-{{ ai_gen_id }}" @click="prev()" aria-label="Previous" x-show="window.innerWidth > 749">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 12L6 8L10 4" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="gg-track-{{ ai_gen_id }}">
        <div class="gg-inner-{{ ai_gen_id }}" x-ref="inner">
          {% for i in (1..8) %}
            {% liquid
              assign image_key = 'image_'  | append: i
              assign label_key = 'label_'  | append: i
              assign url_key   = 'url_'    | append: i
              assign scale_key = 'scale_'  | append: i
              assign image     = block.settings[image_key]
              assign label     = block.settings[label_key]
              assign item_url  = block.settings[url_key]
              assign img_scale = block.settings[scale_key] | default: 100
            %}
            {% if image != blank or label != blank %}
              <div class="gg-item-{{ ai_gen_id }}">
                <div class="gg-img-wrap-{{ ai_gen_id }}">
                  {% if image %}
                    <img
                      src="{{ image | image_url: width: 600 }}"
                      alt="{{ image.alt | escape }}"
                      loading="lazy"
                      width="{{ image.width }}"
                      height="{{ image.height }}"
                      style="transform:scale({{ img_scale | divided_by: 100.0 }});transform-origin:center;"
                    >
                  {% else %}
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f0f0f0;">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                {% if label != blank %}
                  <a
                    {% if item_url != blank %}href="{{ item_url }}"{% else %}role="link" aria-disabled="true"{% endif %}
                    class="button button-solid inline-block pl-4 pr-4 lg:pl-6 lg:pr-6 pt-2.5 pb-2.5 leading-normal md:pt-3 md:pb-3 cursor-pointer"
                  >
                    <div class="flex justify-center">
                      <span class="button-text is-focus-button:opacity-0">{{ label }}</span>
                    </div>
                  </a>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <button class="gg-arrow-{{ ai_gen_id }} gg-next-{{ ai_gen_id }}" @click="next()" aria-label="Next" x-show="window.innerWidth > 749">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 4L10 8L6 12" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Diamond shapes",
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "label": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Space below title",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "items_per_row",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Items per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "items_per_row_tablet",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Items per row (tablet)",
      "default": 3
    },
    {
      "type": "range",
      "id": "items_per_row_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Items per row (mobile)",
      "default": 2
    },
    {
      "type": "range",
      "id": "mobile_max_items",
      "min": 1,
      "max": 8,
      "step": 1,
      "label": "Max items to show (mobile)",
      "default": 8
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Space between items",
      "default": 24
    },
    {
      "type": "range",
      "id": "max_item_width",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "label": "Maximum item width",
      "default": 300
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Arrows"
    },
    {
      "type": "checkbox",
      "id": "show_arrows_desktop",
      "label": "Show arrows on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows_tablet",
      "label": "Show arrows on tablet",
      "default": true
    },
    {
      "type": "header",
      "content": "Image style"
    },
    {
      "type": "range",
      "id": "fixed_image_height",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Image height (Fixed)",
      "default": 250
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "image_text_spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Space below image",
      "default": 12
    },
    {
      "type": "header",
      "content": "Label style"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Label size",
      "default": 16
    },
    {
      "type": "select",
      "id": "label_alignment",
      "label": "Label alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#525151"
    },
    {
      "type": "header",
      "content": "Block style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "block_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "block_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    { "type": "header", "content": "Item 1" },
    { "type": "image_picker", "id": "image_1", "label": "Image" },
    { "type": "text", "id": "label_1", "label": "Label", "default": "Round" },
    { "type": "url", "id": "url_1", "label": "Button link" },
    { "type": "range", "id": "scale_1", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Item 2" },
    { "type": "image_picker", "id": "image_2", "label": "Image" },
    { "type": "text", "id": "label_2", "label": "Label", "default": "Princess" },
    { "type": "url", "id": "url_2", "label": "Button link" },
    { "type": "range", "id": "scale_2", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Item 3" },
    { "type": "image_picker", "id": "image_3", "label": "Image" },
    { "type": "text", "id": "label_3", "label": "Label", "default": "Emerald" },
    { "type": "url", "id": "url_3", "label": "Button link" },
    { "type": "range", "id": "scale_3", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Item 4" },
    { "type": "image_picker", "id": "image_4", "label": "Image" },
    { "type": "text", "id": "label_4", "label": "Label", "default": "Oval" },
    { "type": "url", "id": "url_4", "label": "Button link" },
    { "type": "range", "id": "scale_4", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Item 5" },
    { "type": "image_picker", "id": "image_5", "label": "Image" },
    { "type": "text", "id": "label_5", "label": "Label" },
    { "type": "url", "id": "url_5", "label": "Button link" },
    { "type": "range", "id": "scale_5", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Item 6" },
    { "type": "image_picker", "id": "image_6", "label": "Image" },
    { "type": "text", "id": "label_6", "label": "Label" },
    { "type": "url", "id": "url_6", "label": "Button link" },
    { "type": "range", "id": "scale_6", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Item 7" },
    { "type": "image_picker", "id": "image_7", "label": "Image" },
    { "type": "text", "id": "label_7", "label": "Label" },
    { "type": "url", "id": "url_7", "label": "Button link" },
    { "type": "range", "id": "scale_7", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 },
    {
      "type": "header",
      "content": "Item 8"
    },
    { "type": "image_picker", "id": "image_8", "label": "Image" },
    { "type": "text", "id": "label_8", "label": "Label" },
    { "type": "url", "id": "url_8", "label": "Button link" },
    { "type": "range", "id": "scale_8", "label": "Image scale", "min": 50, "max": 200, "step": 5, "unit": "%", "default": 100 }
