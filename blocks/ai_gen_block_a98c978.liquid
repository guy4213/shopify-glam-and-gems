{% doc %}
  @prompt
    Create a section with two equal columns (50% each) side by side. One column contains a full-height image, and the other contains text content including a heading, a description paragraph, and a button.
    
    The text column content must be vertically centered. Ensure there is generous padding inside the text column so the content never touches the screen edges or the image.
    
    The section settings should include a checkbox or dropdown to reverse/flip the layout layout (Image on left vs. Image on right). On mobile screens (under 750px), the columns should automatically stack vertically (100% width each), with an option or default to show the image first.
    
    All elements (image, heading text/color/size, description text/color/size, button label/link/colors, and section background color) must be fully customizable from the theme editor settings. The design should be clean, modern, and minimal, matching the provided layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    display: inline-block;
    vertical-align: top;
    width: calc(100% / {{ block.settings.items_per_row }});
    background-color: {{ block.settings.section_background_color }};
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {% if block.settings.layout == 'image_left' %}row{% else %}row-reverse{% endif %};
    width: 100%;
    min-height: {{ block.settings.desktop_image_height }}px;
  }

  .ai-image-text-column-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-image-text-img-col-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_column_width }}%;
    width: {{ block.settings.image_column_width }}%;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.desktop_image_height }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale({{ block.settings.image_scale | divided_by: 100.0 }});
    transform-origin: center center;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: {{ block.settings.content_padding }}px;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-image-text-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  /* קונטיינר לכפתורים כדי שיעמדו בשורה */
  .ai-image-text-buttons-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 15px; /* רווח בין שני הכפתורים */
    width: 100%;
  }

  /* כפתור ראשון */
  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 28px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease, color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  /* כפתור שני */
  .ai-image-text-button-2-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 28px;
    background-color: {{ block.settings.button_2_background_color }};
    color: {{ block.settings.button_2_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease, color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-image-text-button-2-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_2_hover_background_color }};
    color: {{ block.settings.button_2_hover_text_color }};
  }

  .ai-image-text-mobile-overlay-{{ ai_gen_id }} {
    display: none;
  }

  .ai-desc-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-email-form-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    width: 100%;
  }

  .ai-email-form-{{ ai_gen_id }} input[type="email"] {
    flex: 1;
    min-width: 180px;
    padding: 12px 16px;
    font-size: {{ block.settings.email_font_size }}px;
    border: 1px solid {{ block.settings.email_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    background-color: {{ block.settings.email_input_bg }};
    color: {{ block.settings.email_input_text_color }};
    outline: none;
  }

  .ai-email-form-{{ ai_gen_id }} input[type="email"]::placeholder {
    color: {{ block.settings.email_placeholder_color }};
  }

  .ai-email-form-{{ ai_gen_id }} button[type="submit"] {
    padding: 12px 24px;
    font-size: {{ block.settings.email_font_size }}px;
    background-color: {{ block.settings.email_btn_bg }};
    color: {{ block.settings.email_btn_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .ai-email-form-{{ ai_gen_id }} button[type="submit"]:hover {
    background-color: {{ block.settings.email_btn_hover_bg }};
  }

  .ai-email-form-{{ ai_gen_id }} .form-message {
    width: 100%;
    font-size: 14px;
    padding: 8px 0;
  }

  .ai-email-form-{{ ai_gen_id }} .form-message--success {
    color: #2d6a2d;
  }

  .ai-email-form-{{ ai_gen_id }} .form-message--error {
    color: #b00020;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-section-{{ ai_gen_id }} {
      display: block;
      width: 100%;
    }

    .ai-image-text-container-{{ ai_gen_id }} {
      flex-direction: {% if block.settings.mobile_layout == 'image_first' %}column{% else %}column-reverse{% endif %};
      min-height: auto;
    }

    .ai-image-text-column-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-image-text-img-col-{{ ai_gen_id }} {
      flex: none;
      width: 100%;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_image_height }}px;
      min-height: {{ block.settings.mobile_image_height }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
      align-items: {% if block.settings.mobile_text_alignment == 'center' %}center{% elsif block.settings.mobile_text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
      text-align: {{ block.settings.mobile_text_alignment }};
      background-color: {{ block.settings.mobile_content_bg }};
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-text-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_size }}px;
      color: {{ block.settings.mobile_description_color }};
    }

    .ai-desc-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-desc-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-image-text-buttons-wrapper-{{ ai_gen_id }} {
      justify-content: {% if block.settings.mobile_text_alignment == 'center' %}center{% elsif block.settings.mobile_text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    }

    .ai-email-form-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-email-form-{{ ai_gen_id }} input[type="email"],
    .ai-email-form-{{ ai_gen_id }} button[type="submit"] {
      width: {{ block.settings.email_mobile_width }}rem;
      min-width: unset;
      flex: none;
    }

    .ai-image-text-mobile-overlay-{{ ai_gen_id }} {
      display: block;
      position: absolute;
      bottom: {{ block.settings.mobile_overlay_bottom_spacing }}px;
      left: 0;
      right: 0;
      text-align: center;
      color: {{ block.settings.mobile_overlay_title_color }};
      font-size: {{ block.settings.mobile_overlay_title_size }}px;
      z-index: 2;
      padding: 0 20px;
      line-height: 1.3;
      font-weight: 600;
    }
  }
{% endstyle %}

<image-text-section-{{ ai_gen_id }} class="ai-image-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-column-{{ ai_gen_id }} ai-image-text-img-col-{{ ai_gen_id }}">
      <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1500 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-image-text-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.mobile_overlay_title != blank %}
          <div class="ai-image-text-mobile-overlay-{{ ai_gen_id }}">
            {{ block.settings.mobile_overlay_title }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-image-text-column-{{ ai_gen_id }}">
      <div class="ai-image-text-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-image-text-description-{{ ai_gen_id }}{% if block.settings.mobile_description != blank %} ai-desc-desktop-{{ ai_gen_id }}{% endif %}">{{ block.settings.description }}</div>
        {% endif %}
        {% if block.settings.mobile_description != blank %}
          <div class="ai-image-text-description-{{ ai_gen_id }} ai-desc-mobile-{{ ai_gen_id }}">{{ block.settings.mobile_description }}</div>
        {% endif %}

        {% comment width_check %} בודק אם לפחות אחד מהכפתורים מולא בקסטומייזר {% endcomment %}
        {% if block.settings.button_label != blank or block.settings.button_2_label != blank %}
          <div class="ai-image-text-buttons-wrapper-{{ ai_gen_id }}">

            {% comment %} כפתור 1 {% endcomment %}
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="ai-image-text-button-{{ ai_gen_id }}">
                {{ block.settings.button_label }}
              </a>
            {% endif %}

            {% comment %} כפתור 2 {% endcomment %}
            {% if block.settings.button_2_label != blank %}
              <a href="{{ block.settings.button_2_link }}" class="ai-image-text-button-2-{{ ai_gen_id }}">
                {{ block.settings.button_2_label }}
              </a>
            {% endif %}

          </div>
        {% endif %}

        {% if block.settings.show_email_form %}
          {% form 'customer' %}
            <div class="ai-email-form-{{ ai_gen_id }}">
              <input type="hidden" name="contact[tags]" value="newsletter">

              {% if form.posted_successfully? %}
                <p class="form-message form-message--success">{{ block.settings.email_success_message }}</p>
              {% elsif form.errors %}
                <p class="form-message form-message--error">{{ block.settings.email_error_message }}</p>
              {% else %}
                <input
                  type="email"
                  name="contact[email]"
                  placeholder="{{ block.settings.email_placeholder }}"
                  autocomplete="email"
                  required
                >
                <button type="submit">{{ block.settings.email_btn_label }}</button>
              {% endif %}
            </div>
          {% endform %}
        {% endif %}
      </div>
    </div>
  </div>
</image-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('image-text-section-{{ ai_gen_id }}', ImageTextSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "items_per_row",
      "label": "Items per row (desktop)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1,
      "info": "Set to 2 or 3 to show multiple blocks side by side"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "image_left",
          "label": "Image left"
        },
        {
          "value": "image_right",
          "label": "Image right"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first"
    },
    {
      "type": "header",
      "content": "Mobile Design"
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "label": "Image height (mobile)",
      "min": 200,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 350
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Heading size (mobile)",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "mobile_heading_color",
      "label": "Heading color (mobile)",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "mobile_description_size",
      "label": "Description size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "mobile_description_color",
      "label": "Description color (mobile)",
      "default": "#525151"
    },
    {
      "type": "color",
      "id": "mobile_content_bg",
      "label": "Text section background (mobile)",
      "default": "#FFFEF3"
    },
    {
      "type": "header",
      "content": "Mobile - Overlay on Image"
    },
    {
      "type": "text",
      "id": "mobile_overlay_title",
      "label": "Overlay title (mobile only)",
      "info": "Appears on top of the image, bottom center. Leave blank to hide."
    },
    {
      "type": "color",
      "id": "mobile_overlay_title_color",
      "label": "Overlay title color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "mobile_overlay_title_size",
      "label": "Overlay title size",
      "min": 14,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "mobile_overlay_bottom_spacing",
      "label": "Overlay title position from bottom",
      "min": 8,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background",
      "default": "#FFFEF3"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_scale",
      "label": "Image zoom",
      "min": 50,
      "max": 130,
      "step": 5,
      "unit": "%",
      "default": 100,
      "info": "100% = מקורי, פחות = זום אאוט, יותר = זום אין"
    },
    {
      "type": "range",
      "id": "desktop_image_height",
      "label": "Image height (desktop)",
      "min": 200,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "image_column_width",
      "label": "Image column width (desktop)",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50,
      "info": "Controls how wide the image column is. The text column fills the rest."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Desktop padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Mobile padding",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Spacing between elements",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#525151"
    },
    {
      "type": "richtext",
      "id": "mobile_description",
      "label": "Description (mobile override)",
      "info": "If filled, this text replaces the description above on mobile screens. Leave blank to use the same description on all devices."
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button 1 Label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button 1 Link"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button 1 Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button 1 Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Button 1 Hover Background",
      "default": "#FB8500"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button 1 Hover Text",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
