{% liquid
  assign cart_amount = 0
  assign cart_qty = 0

  if block.settings.calculation_method == 'product'
    for item in cart.items
      if item.product_id == product.id
        assign cart_amount = cart_amount | plus: item.original_line_price
        assign cart_qty = cart_qty | plus: item.quantity
      endif
    endfor
  else
    if block.settings.applied_products != blank
      assign applied_product_ids = block.settings.applied_products | map: 'id' | join: ','
      for item in cart.items
        if applied_product_ids contains item.product_id
          assign cart_amount = cart_amount | plus: item.original_line_price
          assign cart_qty = cart_qty | plus: item.quantity
        endif
      endfor
    elsif block.settings.applied_collections != blank
      assign applied_collection_ids = block.settings.applied_collections | map: 'id' | join: ','
      for item in cart.items
        for collection in item.product.collections
          if applied_collection_ids contains collection.id
            assign cart_amount = cart_amount | plus: item.original_line_price
            assign cart_qty = cart_qty | plus: item.quantity
            break
          endif
        endfor
      endfor
    else
      for item in cart.items
        assign cart_amount = cart_amount | plus: item.original_line_price
        assign cart_qty = cart_qty | plus: item.quantity
      endfor
    endif
  endif
  assign is_rtl = false
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  endif
%}
{% liquid
  assign goal_value_str = ''
  assign goal_num = 0

  for i in (1..5)
    assign goal_config = 'goal_' | append: i
    assign goal_raw = block.settings[goal_config]
    assign goal_resolved = ''

    if block.settings.discount_type == 'amount' and goal_raw != blank
      assign goal_lines = goal_raw | newline_to_br | strip_newlines | split: '<br />'
      assign goal_all = ''
      assign goal_currency = ''
      assign goal_country = ''

      for gl in goal_lines
        assign glt = gl | strip
        if glt == blank
          continue
        endif
        unless glt contains ':'
          assign goal_all = glt
        else
          assign goal_part = glt | split: ':'
          assign goal_part0 = goal_part[0] | strip
          if goal_part.size == 2
            if goal_part0 == cart.currency.iso_code
              assign goal_currency = goal_part[1] | strip
            endif
          elsif goal_part.size == 3
            assign goal_part1 = goal_part[1] | strip
            if goal_part0 == localization.country.iso_code and goal_part1 == cart.currency.iso_code
              assign goal_country = goal_part[2] | strip
            endif
          endif
        endunless
      endfor

      if goal_country != blank
        assign goal_resolved = goal_country | plus: 0 | times: 100
      elsif goal_currency != blank
        assign goal_resolved = goal_currency | plus: 0 | times: 100
      elsif goal_all != blank
        assign goal_resolved = goal_all | plus: 0 | times: 100
      endif
    elsif block.settings.discount_type != 'amount' and goal_raw != blank
      assign goal_resolved = goal_raw | plus: 0
    endif

    if goal_resolved != blank
      assign goal_num = goal_num | plus: 1
    endif
    assign goal_value_str = goal_value_str | append: goal_resolved
    unless forloop.last
      assign goal_value_str = goal_value_str | append: '|'
    endunless
  endfor

  assign goal_values = goal_value_str | split: '|'
%}
{% style %}
  #discount-progress-bar-{{ section.id }} {
    {% if block.settings.color_marker.alpha != 0.0 %}
      --color-highlight: {{ block.settings.color_marker.red }}, {{ block.settings.color_marker.green }}, {{ block.settings.color_marker.blue }};
    {% else %}
      --color-highlight: {{ settings.colors_heading_highlight.red }}, {{ settings.colors_heading_highlight.green }}, {{ settings.colors_heading_highlight.blue }};
    {% endif %}
  }
  .dark #discount-progress-bar-{{ section.id }} {
    {% if block.settings.color_marker_dark.alpha != 0.0 %}
      --color-highlight: {{ block.settings.color_marker_dark.red }}, {{ block.settings.color_marker_dark.green }}, {{ block.settings.color_marker_dark.blue }};
    {% else %}
      --color-highlight: {{ settings.colors_dark_heading_highlight.red }}, {{ settings.colors_dark_heading_highlight.green }}, {{ settings.colors_dark_heading_highlight.blue }};
    {% endif %}
  }
  .size-icon-{{ block.id }} {
    width: calc({{ block.settings.icon_size }} * 0.9px);
    height: calc({{ block.settings.icon_size }} * 0.9px);
  }
  @media (min-width: 768px) {
    .size-icon-{{ block.id }} {
      width: {{ block.settings.icon_size }}px;
      height: {{ block.settings.icon_size }}px;
    }
  }
  #discount-progress-bar-{{ section.id }}:after {
    width: calc((var(--quantity) / var(--max-goal) * 100)%);
    max-width: 100%;
  }
  .progress-bar-item-container-{{ section.id }}:before {
    content: var(--tw-content);
    position: absolute;
    width: 100%;
    z-index: 0;
    top: calc(50% - 4px);
