            {% endif %}
          </div>
          <div class="pregoal-message pt-3 pb-3">{{ block.settings[pregoal_message] | replace: '[x]', to_next_goal_display | replace: '[goal_label]', label_goal }}</div>
        </div>
      {% endif %}
      {% if to_next_goal >= 0 %}
        {% break %}
      {% endif %}
    {% endfor %}
  </div>
  {% if block.settings.show_table %}
    <div class="x-block-table w-full flex flex-col mt-0.5">
      <div class="w-full">
        <div class="w-full flex justify-between gap-4 pl-2 pr-2 pt-2.5 pb-2.5">
          <div class="empty:hidden font-normal text-left max-w-[50%] rte">{{ block.settings.left_col_label }}</div>
          <div class="empty:hidden font-normal text-right max-w-[50%] rte">{{ block.settings.right_col_label }}</div>
        </div>
      </div>
      <div class="progress-bar-table-{{ block.id }} w-full grid grid-cols-1 gap-x-10 gap-y-2">
        {%- for i in (1..5) -%}
          {% liquid
            assign goal_index = forloop.index0
            assign goal_index_next = goal_index | plus: 1
            assign goal_value = goal_values[goal_index]
            assign goal_value_num = goal_value | plus: 0
            assign goal_value_next = goal_values[goal_index_next]
            assign goal_value_next_num = goal_value_next | plus: 0

            assign goal_config = 'goal_' | append: i
            assign label = 'goal_' | append: i | append: '_label'
            assign icon = 'icon_' | append: i
            assign icon_reached = 'icon_' | append: i | append: '_reached'
            assign another_icon_reached = 'another_icon_' | append: i | append: '_reached'
            assign custom_image_reached = 'custom_image_' | append: i | append: '_reached'
            assign custom_icon_reached = 'custom_icon_' | append: i | append: '_reached'

            assign label_goal = block.settings[label] | remove: '[' | remove: ']'
            assign goal_display = ''
            assign total_save = ''
            assign goal_qty = 0
            assign active = false

            if block.settings.discount_type == 'amount'
              if goal_value != blank
                assign goal_display = goal_value_num | money | append: '+'
                if goal_value_next != blank
                  if cart_amount >= goal_value_num and cart_amount < goal_value_next_num
                    assign active = true
                  endif
                else
                  if cart_amount >= goal_value_num
                    assign active = true
                  endif
                endif
              endif
            else
              assign goal_qty = goal_value | plus: 0
              assign goal_display = goal_qty | append: '+ items'
              if goal_value_next != blank
                if cart_qty >= goal_qty and cart_qty < goal_value_next_num
                  assign active = true
                endif
              else
                if cart_qty >= goal_qty
                  assign active = true
                endif
              endif
              if block.settings[label] contains '[' and block.settings[label] contains ']'
                assign total_save = block.settings[label] | split: '[' | last | split: ']' | first | times: block.settings[goal_config] | times: 100 | money | append: '+'
              endif
            endif
          %}
          {% if goal_value != blank and goal_display != blank %}
            <div class="flex justify-between pl-2 pr-2 pt-2.5 pb-2.5 border-transparent rounded-lg {% if active %} bg-[rgba(var(--color-highlight),0.2)] {% endif %}">
              <div class="flex max-w-[50%] items-center gap-1">
                {% if active %}
                  <span class="inline-block w-3.5 h-3.5 text-[rgba(var(--color-highlight))]">
                    {% if block.settings[custom_image_reached] != blank %}
                      {% # theme-check-disable ImgLazyLoading %}
                      <img
                        src="{{ block.settings[custom_image_reached] | image_url: width: block.settings.icon_size }}"
                        alt="{{ block.settings[custom_image_reached].alt | escape }}"
                        {% if settings.enable_lazy_loading_image %}
                          loading="lazy"
                        {% else %}
                          loading="eager"
                        {% endif %}
                        width="{{ block.settings[custom_image_reached].width }}"
                        height="{{ block.settings[custom_image_reached].height }}"
                        style="object-position: {{ block.settings[custom_image_reached].presentation.focal_point }}"
                        class="object-cover top-0 left-0 w-full h-full rounded-full"
                      >
                      {% # theme-check-enable ImgLazyLoading %}
                    {% else %}
                      {% if block.settings[custom_icon_reached] == blank %}
                        {% if block.settings[another_icon_reached] != blank
                          and block.settings[icon_reached] == 'another_icon'
                        %}
                          {% render 'icon-new-alls', icon: block.settings[another_icon_reached] %}
                        {% else %}
                          {% render 'icon-labels-bags', icon: block.settings[icon_reached] %}
                        {% endif %}
                      {% else %}
                        {{ block.settings[custom_icon_reached] }}
                      {% endif %}
                    {% endif %}
                  </span>
                {% endif %}
                <div
                  class="text-center {% if block.settings.discount_type == 'quantity' %} cursor-pointer {% endif %} {% if active %} text-[rgba(var(--color-highlight))]{% endif %}"
                  {% if block.settings.discount_type == 'quantity' %}
                    @click="
                      document.dispatchEvent(new CustomEvent(`eurus:product:quantity-changed-{{ section.id }}`, {
                        detail: {
                          quantity: {{ goal_qty }}
                        }
                      }));
                    "
                  {% endif %}
                >
                  {{ goal_display }}
                </div>
              </div>
              <div class="flex max-w-[50%] items-center justify-end gap-3 justify-items-end">
                {% if total_save != blank %}
                  <span class="text-[90%] text-end text-[rgb(var(--colors-text),0.7)]">
                    {{ 'products.product.price.total_save' | t | append: ': ' | append: total_save }}
                  </span>
                {%- endif %}
                <span class="text-end {% if active %} text-[rgba(var(--color-highlight))]{% endif %}">
                  {{ label_goal }}
                </span>
                {% if active %}
                  <span class="self-center justify-center border border-transparent rounded-xl bg-[rgba(var(--color-highlight),0.8)] text-white pl-3 pr-3 pt-1 pb-1 text-center text-[80%] shrink">
                    {{- 'products.product.price.active' | t -}}
                  </span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>
<script src="{{ 'discount-progress-bar.js' | asset_url }}" defer></script>
