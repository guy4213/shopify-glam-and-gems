      --tw-translate-x: 100%;
    {% else %}
      --tw-translate-x: -100%;
    {% endif %}
    transform: translate(var(--tw-translate-x), var(--tw-translate-y)) rotate(var(--tw-rotate)) skewX(var(--tw-skew-x)) skewY(var(--tw-skew-y)) scaleX(var(--tw-scale-x)) scaleY(var(--tw-scale-y));
  }
  .dark .discount-progress-bar-item-{{ block.id }}:before {
    {% if block.settings.color_line_and_border_dark.alpha != 0.0 %}
      --colors-line-and-border: {{ block.settings.color_line_and_border_dark.red }}, {{ block.settings.color_line_and_border_dark.green }}, {{ block.settings.color_line_and_border_dark.blue }};
    {% else %}
      --colors-line-and-border: {{ settings.colors_dark_line_and_borders.red }}, {{ settings.colors_dark_line_and_borders.green }}, {{ settings.colors_dark_line_and_borders.blue }};
    {% endif %}
  }
  .discount-progress-bar-item-{{ block.id }}:after {
    content: var(--tw-content);
    position: absolute;
    width: var(--after-width);
    z-index: 10;
    {% if is_rtl %}
      right: 50%;
    {% else %}
      left: 50%;
    {% endif %}
    top: calc(50% - 4px);
    border-top-width: 8px;
    border-radius: 1rem;
    border-color: rgba(var(--color-highlight));
    {% if is_rtl %}
      --tw-translate-x: 100%;
    {% else %}
      --tw-translate-x: -100%;
    {% endif %}
    transform: translate(var(--tw-translate-x), var(--tw-translate-y)) rotate(var(--tw-rotate)) skewX(var(--tw-skew-x)) skewY(var(--tw-skew-y)) scaleX(var(--tw-scale-x)) scaleY(var(--tw-scale-y));
  }
  .discount-progress-bar-item-{{ block.id }}.partial:after {
    {% if is_rtl %}
      right: var(--after-left);
    {% else %}
      left: var(--after-left);
    {% endif %}
  }
  .discount-progress-bar-item-{{ block.id }} .icon-progress {
    display: flex;
  }
  .discount-progress-bar-item-{{ block.id }} .icon-reached {
    display: none;
  }
  .discount-progress-bar-item-{{ block.id }}.passed-goal .icon-progress {
    display: none;
  }
  .discount-progress-bar-item-{{ block.id }}.passed-goal .icon-reached {
    display: flex;
  }
{% endstyle %}
{% if block.settings.heading != blank %}
  <div class="h2 x-block-heading leading-normal font-medium rte">{{ block.settings.heading }}</div>
  <p class= "leading-tight rte">{{ block.settings.subheading }}</p>
  <div class="pb-4">({{ 'discount_progress_bar.click_to_apply_qty' | t }})</div>
{% endif %}
<div
  id="discount-progress-bar-{{ section.id }}"
  class="mt-4"
  x-data="xDiscountBar([{% for i in (1..5) %}{{ goal_values[forloop.index0] | plus: 0 }}{% unless forloop.last %},{% endunless %}{% endfor %}])"
  x-init="(() => {
    setOrder();
    document.addEventListener('eurus:cart:items-changed', () => {
      updateProgressBar('{{ section.id }}', '{{ product.url }}', '{{ product.selected_or_first_available_variant.id }}');
    });
  })
  " 
>
  <div x-init="setGoal({% if block.settings.discount_type == 'amount'  %}{{ cart_amount }}{% else %}{{ cart_qty }}{% endif %})" class="progress-bar-item-container-{{ section.id }}{% if block.settings.show_table %} mt-4{% else %} mt-1{% endif %} relative grid grid-cols-{{ goal_num }} overflow-hidden">
    {%- for i in (1..5) -%}
      {% liquid
        assign goal_index = forloop.index0
        assign goal_value = goal_values[goal_index]
        assign goal_value_num = goal_value | plus: 0
        assign goal_config = "goal_" | append: i
        assign label = "goal_" | append: i | append: "_label"
        assign icon = "icon_" | append: i
        assign another_icon = "another_icon_" | append: i
        assign custom_image = "custom_image_" | append: i
        assign custom_icon = "custom_icon_" | append: i
        assign icon_reached = "icon_" | append: i | append: '_reached'
        assign another_icon_reached = "another_icon_" | append: i | append: '_reached'
        assign custom_image_reached = "custom_image_" | append: i | append: '_reached'
        assign custom_icon_reached = "custom_icon_" | append: i | append: '_reached'
        assign label_goal = block.settings[label] | remove: '[' | remove: ']'
        if block.settings[label] contains '[' and block.settings[label] contains ']'
          assign label_passed = block.settings[label] | split: '[' | last | split: ']' | first | times: 100 | money | prepend: '-'
        else
          assign label_passed = label_goal
        endif
        assign is_passed = false
        if block.settings.discount_type == 'amount'
          assign goal_display = goal_value_num | money
          if cart_amount >= goal_value_num
            assign is_passed = true
          endif
        else
          assign goal_display = goal_value
          if cart_qty >= goal_value_num
            assign is_passed = true
          endif
        endif
      %}
      {% if goal_value != blank %}
        <div 
          x-init="$nextTick(() => { 
            calculateWidth($el, {% if block.settings.discount_type == 'amount' %}{{ cart_amount }}, {{ goal_value_num }}{% else %}{{ cart_qty }}, {{ goal_value_num }}{% endif %}, index[{{ i }}]{% if is_rtl %}, true{% endif %});
            if (!window[`_dpbResize_{{ block.id }}_{{ i }}`]) {
              window[`_dpbResize_{{ block.id }}_{{ i }}`] = true;
              window.addEventListener('resize', () => {
                calculateWidth($el, {% if block.settings.discount_type == 'amount' %}{{ cart_amount }}, {{ goal_value_num }}{% else %}{{ cart_qty }}, {{ goal_value_num }}{% endif %}, index[{{ i }}]{% if is_rtl %}, true{% endif %});
              });
            }
          });"
          :class="`order-${index[{{ i }}]} bar-item-${index[{{ i }}]}`" 
          class="discount-progress-bar-item-{{ block.id }} flex flex-col items-center gap-y-1.5 grow justify-between relative"
        >
          <div class="flex items-center w-full h-full shrink whitespace-nowrap overflow-hidden text-ellipsis">
            {% if is_passed == false %}
              <span class="line-clamp-2 text-center w-full h-full text-[rgb(var(--colors-text),0.7)] text-[80%]">
                {{- label_goal -}}
              </span>
            {% else %}
              <span class="line-clamp-2 text-center w-full h-full text-[rgb(var(--colors-text),0.7)] text-[80%]">
                {{- label_passed -}}
              </span>
            {% endif %}
          </div>
          {% if block.settings.show_progress_bar_icons and block.settings[icon] != 'none' %}
            {% unless block.settings[custom_image] == blank
              and block.settings[custom_icon] == blank
              and block.settings[another_icon] == blank
              and block.settings[icon] == 'another_icon'
            %}
              <div class="icon-progress flex justify-center w-full{% if block.settings.show_table %} h-full items-center{% endif %}">
                <span class="z-20 inline-block relative size-icon-{{ block.id }} pt-1 pb-1 pl-1 pr-1 rounded-full text-[rgba(var(--color-highlight))] border border-[rgba(var(--color-highlight))] bg-[rgba(var(--colors-background-secondary))]">
                  {% if block.settings[custom_image] != blank %}
                    {% # theme-check-disable ImgLazyLoading %}
                    <img 
                      src="{{ block.settings[custom_image] | image_url: width: block.settings.icon_size }}"
                      alt="{{ block.settings[custom_image].alt | escape }}"
                      {% if settings.enable_lazy_loading_image %}
                        loading="lazy"
                      {% else %}
                        loading="eager"
                      {% endif %}
                      width="{{ block.settings[custom_image].width }}"
                      height="{{ block.settings[custom_image].height }}"
                      style="object-position: {{ block.settings[custom_image].presentation.focal_point }}"
                      class="object-cover absolute top-0 left-0 pt-1 pb-1 pl-1 pr-1 w-full h-full rounded-full"
                    >
                    {% # theme-check-enable ImgLazyLoading %}
                  {% else %}
                    {% if block.settings[custom_icon] == blank %}
                      {% if block.settings[another_icon] != blank and block.settings[icon] == 'another_icon' %}
                        {% render 'icon-new-alls', icon: block.settings[another_icon] %}
                      {% else %}
                        {% render 'icon-labels-bags', icon: block.settings[icon] %}
                      {% endif %}
                    {% else %}
                      {{ block.settings[custom_icon] }}
                    {% endif %}
                  {% endif %}
                </span>
              </div>
            {% endunless %}
          {% else %}
            <div class="icon-progress flex w-full justify-center {% if block.settings.show_table %} h-full items-center{% endif %}">
              <span class="z-20 inline-block relative h-0 w-0 pt-2 pb-2 pl-2 pr-2 rounded-full border-2 bg-[#acacac] border-[rgba(var(--background-color))]">
              </span>
            </div>
          {% endif %}
          {% if block.settings.show_progress_bar_icons and block.settings[icon_reached] != 'none' %}
            {% unless block.settings[custom_image_reached] == blank
              and block.settings[custom_icon_reached] == blank
              and block.settings[another_icon_reached] == blank
              and block.settings[icon_reached] == 'another_icon'
            %}
              <div class="icon-reached flex justify-center w-full{% if block.settings.show_table %} h-full items-center{% endif %}">
                <span class="z-20 inline-block relative size-icon-{{ block.id }} pt-1 pb-1 pl-1 pr-1 rounded-full text-[rgba(var(--background-color))] border border-[rgba(var(--color-highlight))] bg-[rgba(var(--color-highlight))]">
                  {% if block.settings[custom_image_reached] != blank %}
                    {% # theme-check-disable ImgLazyLoading %}
                    <img 
                      src="{{ block.settings[custom_image_reached] | image_url: width: block.settings.icon_size }}"
                      alt="{{ block.settings[custom_image_reached].alt | escape }}"
                      {% if settings.enable_lazy_loading_image %}
                        loading="lazy"
                      {% else %}
                        loading="eager"
                      {% endif %}
                      width="{{ block.settings[custom_image_reached].width }}"
                      height="{{ block.settings[custom_image_reached].height }}"
                      style="object-position: {{ block.settings[custom_image_reached].presentation.focal_point }}"
                      class="object-cover absolute top-0 left-0 pt-1 pb-1 pl-1 pr-1 w-full h-full rounded-full"
                    >
                    {% # theme-check-enable ImgLazyLoading %}
                  {% else %}
                    {% if block.settings[custom_icon_reached] == blank %}
                      {% if block.settings[another_icon_reached] != blank
                        and block.settings[icon_reached] == 'another_icon'
                      %}
                        {% render 'icon-new-alls', icon: block.settings[another_icon_reached] %}
                      {% else %}
                        {% render 'icon-labels-bags', icon: block.settings[icon_reached] %}
                      {% endif %}
                    {% else %}
                      {{ block.settings[custom_icon_reached] }}
                    {% endif %}
                  {% endif %}
                </span>
              </div>
            {% endunless %}
          {% else %}
            <div class="icon-reached flex w-full justify-center{% if block.settings.show_table %} h-full items-center{% endif %}">
              <span class="z-20 inline-block relative h-0 w-0 pt-2 pb-2 pl-2 pr-2 rounded-full border-2 bg-[rgba(var(--color-highlight))] border-[rgba(var(--background-color))]">
              </span>
            </div>
          {% endif %}          
          <div class="{% if is_passed %} text-[rgba(var(--color-highlight))] {% else %} text-[rgb(var(--colors-text),0.7)] {% endif %} text-[80%]">
            {{ goal_display }}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div>
    {%- for i in (1..5) -%}
      {% liquid 
        assign goal_index = forloop.index0
        assign goal_value = goal_values[goal_index]
        assign goal_value_num = goal_value | plus: 0
        assign pregoal_message = "goal_" | append: i | append: "_pregoal_message"
        assign postgoal_message = "goal_" | append: i | append: "_postgoal_message"
        assign label = "goal_" | append: i | append: "_label"
        assign icon = 'icon_' | append: i
        assign custom_image = 'custom_image_' | append: i
        assign custom_icon = 'custom_icon_' | append: i
        assign icon_reached = 'icon_' | append: i | append: '_reached'
        assign another_icon_reached = 'another_icon_' | append: i | append: '_reached'
        assign custom_image_reached = 'custom_image_' | append: i | append: '_reached'
        assign custom_icon_reached = 'custom_icon_' | append: i | append: '_reached'
        assign label_goal = block.settings[label] | remove: '[' | remove: ']'

        if block.settings.discount_type == 'amount'
          assign to_next_goal = goal_value_num | minus: cart_amount
          assign to_next_goal_display = to_next_goal | money          
        else
          assign to_next_goal = goal_value_num | minus: cart_qty
          assign to_next_goal_display = to_next_goal
        endif
      %}
      {% if goal_value == blank %}{% continue %}{% endif %}
      {% if to_next_goal < 0 and forloop.last == false %}
        {% continue %}
      {% endif %}
      {% if to_next_goal <= 0 %}
        <div class="bg-[rgba(var(--colors-background-secondary))] pl-2 pr-2 rounded-lg w-full mt-3 mb-3 flex flex-row items-center gap-3">
          <div class="inline-block w-3.5 h-3.5 flex-shrink-0">
            {% if block.settings[custom_image_reached] != blank %}
              {% # theme-check-disable ImgLazyLoading %}
              <img
                src="{{ block.settings[custom_image_reached] | image_url: width: icon_size }}"
                src="{{ block.settings[custom_image_reached] | image_url: width: block.settings.icon_size }}"
                alt="{{ block.settings[custom_image_reached].alt | escape }}"
                {% if settings.enable_lazy_loading_image %}
                  loading="lazy"
                {% else %}
                  loading="eager"
                {% endif %}
                width="{{ block.settings[custom_image_reached].width }}"
                height="{{ block.settings[custom_image_reached].height }}"
                style="object-position: {{ block.settings[custom_image_reached].presentation.focal_point }}"
                class="object-cover top-0 left-0 pt-1.5 pb-1.5 pl-1.5 pr-1.5 w-full h-full "
                class="object-cover top-0 left-0 w-full h-full "
              >
              {% # theme-check-enable ImgLazyLoading %}
            {% else %}
              {% if block.settings[custom_icon_reached] == blank %}
                {% if block.settings[another_icon_reached] != blank and block.settings[icon] == 'another_icon' %}
                  {% render 'icon-new-alls', icon: block.settings[another_icon_reached] %}
                {% else %}
                  {% render 'icon-labels-bags', icon: block.settings[icon_reached] %}
                {% endif %}
              {% else %}
                {{ block.settings[custom_icon_reached] }}
              {% endif %}
            {% endif %}
          </div>
          <div class="postgoal-message pt-3 pb-3">{{ block.settings[postgoal_message] | replace: '[x]', to_next_goal_display | replace: '[goal_label]', label_goal }}</div>
        </div>
      {% else %}
        <div class="bg-[rgba(var(--colors-background-secondary))] pl-2 pr-2 rounded-lg w-full mt-3 mb-3 flex flex-row items-center gap-3">
          <div class="inline-block w-3.5 h-3.5 flex-shrink-0">
            {% if block.settings[custom_image] != blank %}
              {% # theme-check-disable ImgLazyLoading %}
              <img
                src="{{ block.settings[custom_image] | image_url: width: icon_size }}"
                src="{{ block.settings[custom_image] | image_url: width: block.settings.icon_size }}"
                alt="{{ block.settings[custom_image].alt | escape }}"
                {% if settings.enable_lazy_loading_image %}
                  loading="lazy"
                {% else %}
                  loading="eager"
                {% endif %}
                width="{{ block.settings[custom_image].width }}"
                height="{{ block.settings[custom_image].height }}"
                style="object-position: {{ block.settings[custom_image].presentation.focal_point }}"
                class="object-cover top-0 left-0 pt-1.5 pb-1.5 pl-1.5 pr-1.5 w-full h-full "
                class="object-cover top-0 left-0 w-full h-full "
              >
              {% # theme-check-enable ImgLazyLoading %}
            {% else %}
              {% if block.settings[custom_icon] == blank %}
                {% if block.settings[another_icon] != blank and block.settings[icon] == 'another_icon' %}
                  {% render 'icon-new-alls', icon: block.settings[another_icon] %}
