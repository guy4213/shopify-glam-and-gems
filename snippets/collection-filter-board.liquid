                          <input type="checkbox" id="{{ vo_input_id }}" class="sr-only" name="{{ vo_matched_fv.param_name }}" value="{{ vo_matched_fv.value }}" form="FacetFiltersForm" {% if vo_is_active %}checked{% endif %} @change="onSubmit()">
