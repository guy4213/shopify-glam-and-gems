            comment
              Shopify reports range_min/max in cents — convert to whole dollars for the slider + URL.
            endcomment
            if cfb_price_filter != nil
              assign _raw_abs_min  = cfb_price_filter.range_min | plus: 0
              assign _raw_abs_max  = cfb_price_filter.range_max | plus: 0
              assign cfb_pr_abs_min = _raw_abs_min | divided_by: 100
              assign cfb_pr_abs_max = _raw_abs_max | divided_by: 100
              if _raw_abs_max != 0 and cfb_pr_abs_max == 0
                assign cfb_pr_abs_max = 1
              endif
              assign cfb_pr_param_min = cfb_price_filter.min_value.param_name
              assign cfb_pr_param_max = cfb_price_filter.max_value.param_name
              if cfb_price_filter.min_value.value != blank
                assign _raw_cur_min  = cfb_price_filter.min_value.value | plus: 0
                assign cfb_pr_cur_min = _raw_cur_min | divided_by: 100
              else
                assign cfb_pr_cur_min = cfb_pr_abs_min
              endif
              if cfb_price_filter.max_value.value != blank
                assign _raw_cur_max  = cfb_price_filter.max_value.value | plus: 0
                assign cfb_pr_cur_max = _raw_cur_max | divided_by: 100
              else
                assign cfb_pr_cur_max = cfb_pr_abs_max
              endif
            else
              assign cfb_pr_abs_min   = 0
              assign cfb_pr_abs_max   = 5000
              assign cfb_pr_param_min = 'filter.v.price.gte'
              assign cfb_pr_param_max = 'filter.v.price.lte'
              assign cfb_pr_cur_min   = cfb_pr_abs_min
              assign cfb_pr_cur_max   = cfb_pr_abs_max
            endif
            assign cfb_pr_input_min = ''
            unless cfb_pr_cur_min == cfb_pr_abs_min
              assign cfb_pr_input_min = cfb_pr_cur_min
            endunless
            assign cfb_pr_input_max = ''
            unless cfb_pr_cur_max == cfb_pr_abs_max
              assign cfb_pr_input_max = cfb_pr_cur_max
            endunless
          -%}
          <div class="cfb-price-slider"
            data-abs-min="{{ cfb_pr_abs_min }}"
            data-abs-max="{{ cfb_pr_abs_max }}"
            data-cur-min="{{ cfb_pr_cur_min }}"
            data-cur-max="{{ cfb_pr_cur_max }}"
            data-param-min="{{ cfb_pr_param_min }}"
            data-param-max="{{ cfb_pr_param_max }}"
          >
            <input type="number" class="sr-only cfb-price-input cfb-price-input--min" name="{{ cfb_pr_param_min }}" value="{{ cfb_pr_input_min }}" form="FacetFiltersForm" aria-hidden="true" tabindex="-1" @change="onSubmit()">
            <input type="number" class="sr-only cfb-price-input cfb-price-input--max" name="{{ cfb_pr_param_max }}" value="{{ cfb_pr_input_max }}" form="FacetFiltersForm" aria-hidden="true" tabindex="-1" @change="onSubmit()">
            <div class="cfb-price-track cfb-price-track--live">
              <div class="cfb-price-fill"></div>
              <button type="button" class="cfb-price-thumb cfb-price-thumb--min" aria-label="Minimum price" role="slider"></button>
              <button type="button" class="cfb-price-thumb cfb-price-thumb--max" aria-label="Maximum price" role="slider"></button>
            </div>
            <div class="cfb-price-display">
              <span class="cfb-pval cfb-pval--min"></span>
              <span>–</span>
              <span class="cfb-pval cfb-pval--max"></span>
            </div>
          </div>
        </div>

        {%- comment -%} Quick Filters — right-pinned, hidden when bottom row has 4+ columns {%- endcomment -%}
        {%- if cfb_has_quick and cfb_quick_fits -%}
          <div class="cfb-quick-section">
            <p class="cfb-group-heading">Quick Filters</p>
            {%- assign cfb_quick_arr = cfb_quick_1 | append: '~' | append: cfb_quick_2 | append: '~' | append: cfb_quick_3 | append: '~' | append: cfb_quick_4 | split: '~' -%}
            <div class="cfb-quick-grid">
              {%- for cfb_qv in cfb_quick_arr -%}
                {%- if cfb_qv != blank -%}
                  {%- liquid
                    assign cfb_quick_found = nil
                    for qf in collection.filters
                      for qfv in qf.values
                        if qfv.label == cfb_qv
                          assign cfb_quick_found = qfv
                          break
                        endif
                      endfor
                      if cfb_quick_found != nil
                        break
                      endif
                    endfor
                  -%}
                  {%- if cfb_quick_found != nil -%}
                    <label
                      for="cfb-q-{{ cfb_qv | handle }}"
                      class="cfb-quick-block{% if cfb_quick_found.active %} cfb-active{% endif %}{% if cfb_quick_found.count == 0 and cfb_quick_found.active == false %} cfb-disabled{% endif %}{% if settings.edges_type == 'rounded_corners' %} rounded{% endif %}"
                    >
                      <input
                        type="checkbox"
                        id="cfb-q-{{ cfb_qv | handle }}"
                        class="sr-only"
                        name="{{ cfb_quick_found.param_name }}"
                        value="{{ cfb_quick_found.value }}"
                        form="FacetFiltersForm"
                        {% if cfb_quick_found.active %}checked{% endif %}
                        {% if cfb_quick_found.count == 0 and cfb_quick_found.active == false %}disabled{% endif %}
                        @change="onSubmit()"
                      >
                      {{ cfb_qv | escape }}
                    </label>
                  {%- else -%}
                    <span class="cfb-quick-block cfb-disabled{% if settings.edges_type == 'rounded_corners' %} rounded{% endif %}" aria-hidden="true">{{ cfb_qv | escape }}</span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</div>

<script>
(function () {
  'use strict';

  function cfbSubmit() {
    var form = document.getElementById('FacetFiltersForm');
    if (!form) return;
    if (window.Alpine) {
      var xEl = form.closest('[x-data]') || document.querySelector('[x-data*="xFiltersAndSortby"]');
      if (xEl) {
        try {
          var d = Alpine.$data(xEl);
          if (typeof d.onSubmit === 'function') { d.onSubmit(); return; }
        } catch (e) {}
      }
    }
    var url = new URL(window.location.href);
    var del = [];
    url.searchParams.forEach(function(v, k) { if (k.indexOf('filter.') === 0) del.push(k); });
    del.forEach(function(k) { url.searchParams.delete(k); });
    new FormData(form).forEach(function(val, key) {
      if (key.indexOf('filter.') === 0 && val !== '') url.searchParams.append(key, val);
    });
    url.searchParams.delete('page');
    window.location.href = url.toString();
  }

  function syncActiveClasses(board) {
    board.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
      var label = cb.closest('label');
      if (!label) return;
      if (cb.checked) {
        label.classList.add('is-active');
      } else {
        label.classList.remove('is-active');
      }
    });
  }

  function bindBoard(board) {
    syncActiveClasses(board);

    board.addEventListener('change', function(e) {
      var el = e.target;
      if (el.tagName === 'INPUT' && el.type === 'checkbox') {
        var label = el.closest('label');
        if (label) {
          if (el.checked) { label.classList.add('is-active'); }
          else { label.classList.remove('is-active'); }
        }
        cfbSubmit();
      } else if (el.tagName === 'SELECT') {
        cfbSubmit();
      }
    });

    board.querySelectorAll('[data-cfb-clear]').forEach(function(btn) {
      if (btn.dataset.cfbClearBound) return;
      btn.dataset.cfbClearBound = '1';
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var type = btn.dataset.cfbClear || '';
        var changed = false;
        document.querySelectorAll('input[type="checkbox"][name]').forEach(function(cb) {
          var n = cb.name || '';
          if (type === 'stone' && /stone[_-]?type/i.test(n) && cb.checked) {
            cb.checked = false;
            var lbl = cb.closest('label');
            if (lbl) lbl.classList.remove('cfb-active', 'is-active');
            changed = true;
          }
        });
        if (changed) cfbSubmit();
      });
    });
  }

  function initCfbSlider(widget) {
    /* All values are in WHOLE DOLLARS — never cents, never floats. */
    var absMin = parseInt(widget.dataset.absMin, 10);
    var absMax = parseInt(widget.dataset.absMax, 10);
    if (isNaN(absMin) || absMin < 0) absMin = 0;
    if (isNaN(absMax) || absMax <= absMin) absMax = absMin + 5000;

    var curMin = parseInt(widget.dataset.curMin, 10);
    var curMax = parseInt(widget.dataset.curMax, 10);
    if (isNaN(curMin) || curMin < absMin) curMin = absMin;
    if (isNaN(curMax) || curMax > absMax) curMax = absMax;

    var pMin     = widget.dataset.paramMin;
    var pMax     = widget.dataset.paramMax;
    var track    = widget.querySelector('.cfb-price-track--live');
    var fill     = widget.querySelector('.cfb-price-fill');
    var thumbMin = widget.querySelector('.cfb-price-thumb--min');
    var thumbMax = widget.querySelector('.cfb-price-thumb--max');
    var inputMin = widget.querySelector('.cfb-price-input--min');
    var inputMax = widget.querySelector('.cfb-price-input--max');
    var lblMin   = widget.querySelector('.cfb-pval--min');
    var lblMax   = widget.querySelector('.cfb-pval--max');

    function fmt(dollars) {
      return '$' + Math.round(dollars).toLocaleString('en-US');
    }
    function toPct(v)  { return ((v - absMin) / (absMax - absMin)) * 100; }
    function fromPct(p){ return absMin + (p / 100) * (absMax - absMin); }

    function render() {
      var lo = toPct(curMin), hi = toPct(curMax);
      thumbMin.style.left = lo + '%';
      thumbMax.style.left = hi + '%';
      fill.style.left     = lo + '%';
      fill.style.width    = (hi - lo) + '%';
      if (lblMin) lblMin.textContent = fmt(curMin);
      if (lblMax) lblMax.textContent = fmt(curMax);
    }

    function submitPrice() {
      /* Whole dollars only — write to hidden inputs then trigger Alpine onSubmit (no reload). */
      if (inputMin) inputMin.value = curMin > absMin ? String(Math.round(curMin)) : '';
      if (inputMax) inputMax.value = curMax < absMax ? String(Math.round(curMax)) : '';
      cfbSubmit();
    }

    render();

    function makeDraggable(thumb, isMin) {
      var active = false;
      var gap    = Math.max(1, Math.round((absMax - absMin) * 0.005));

      function getVal(e) {
        var r   = track.getBoundingClientRect();
        var cx  = e.touches ? e.touches[0].clientX : e.clientX;
        return Math.round(fromPct(Math.min(1, Math.max(0, (cx - r.left) / r.width)) * 100));
      }
      function onStart(e) {
        active = true; thumb.classList.add('is-dragging'); e.preventDefault();
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup',   onEnd);
        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('touchend',  onEnd);
      }
      function onMove(e) {
        if (!active) return; if (e.cancelable) e.preventDefault();
        var v = getVal(e);
        if (isMin) curMin = Math.max(absMin, Math.min(v, curMax - gap));
        else       curMax = Math.min(absMax, Math.max(v, curMin + gap));
        render();
      }
      function onEnd() {
        if (!active) return; active = false; thumb.classList.remove('is-dragging');
        document.removeEventListener('mousemove', onMove); document.removeEventListener('mouseup', onEnd);
        document.removeEventListener('touchmove', onMove); document.removeEventListener('touchend', onEnd);
        submitPrice();
      }
      thumb.addEventListener('mousedown',  onStart);
      thumb.addEventListener('touchstart', onStart, { passive: false });
      thumb.addEventListener('keydown', function(e) {
        var step = Math.max(1, Math.round((absMax - absMin) * 0.01));
        if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
          if (isMin) curMin = Math.max(absMin, curMin - step);
          else       curMax = Math.max(curMin + gap, curMax - step);
          render(); submitPrice();
        } else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
          if (isMin) curMin = Math.min(curMax - gap, curMin + step);
          else       curMax = Math.min(absMax, curMax + step);
          render(); submitPrice();
        }
      });
    }

    track.addEventListener('click', function(e) {
      if (e.target === thumbMin || e.target === thumbMax) return;
      var r   = track.getBoundingClientRect();
      var v   = Math.round(fromPct(((e.clientX - r.left) / r.width) * 100));
      var gap = Math.max(1, Math.round((absMax - absMin) * 0.005));
      if (Math.abs(v - curMin) <= Math.abs(v - curMax))
        curMin = Math.max(absMin, Math.min(v, curMax - gap));
      else
        curMax = Math.min(absMax, Math.max(v, curMin + gap));
      render(); submitPrice();
    });

    makeDraggable(thumbMin, true);
    makeDraggable(thumbMax, false);
  }

  function applyCfbShapeImages() {
    var el = document.querySelector('[id^="CfbShapeImages-"]');
    if (!el) return;
    var images;
    try { images = JSON.parse(el.textContent); } catch(e) { return; }
    images.forEach(function(img) {
      if (!img.url) return;
      /* Match by filter value on the hidden checkbox input */
      var input = document.querySelector('.cfb-board input[value="' + CSS.escape(img.filterValue) + '"]');
      /* Also try matching by data-shape attribute on the tile wrap */
      var wrap = input
        ? input.closest('.cfb-tile-label, .cfb-tile-label + *')
          && input.closest('label').querySelector('.cfb-tile-img-wrap')
        : document.querySelector('.cfb-board .cfb-tile-img-wrap[data-shape="' + img.filterValue.toLowerCase() + '"]');
      if (!wrap) {
        wrap = document.querySelector('.cfb-board .cfb-tile-img-wrap[data-shape="' + img.filterValue.toLowerCase() + '"]');
      }
      if (!wrap) return;
      var imgEl = document.createElement('img');
      imgEl.src = img.url;
      imgEl.alt = img.label;
      imgEl.className = 'cfb-tile-img-el';
      imgEl.loading = 'lazy';
      wrap.innerHTML = '';
      wrap.appendChild(imgEl);
    });
  }

  function boot() {
    document.querySelectorAll('.cfb-board').forEach(function(b) {
      if (!b.dataset.cfbBound) {
        b.dataset.cfbBound = '1';
        bindBoard(b);
      } else {
        syncActiveClasses(b);
      }
    });
    document.querySelectorAll('.cfb-price-slider').forEach(function(w) {
      if (!w.dataset.cfbInit) {
        w.dataset.cfbInit = '1';
        initCfbSlider(w);
      }
    });
    applyCfbShapeImages();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  document.addEventListener('x-filter-board-updated', boot);
  document.addEventListener('shopify:section:load',   boot);
})();
</script>

{%- endif -%}
