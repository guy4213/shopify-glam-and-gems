                              {%- elsif only_default_variant or swatch_enabled -%}
                                aria-label="{{ atc_text }}"
                              {%- else -%}
                                aria-label="{{ choose_option_text }}"
                              {%- endif -%}
                              {% unless settings.default_select_available_variant or only_default_variant %}
