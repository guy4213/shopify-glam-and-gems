                                $el.options[$el.selectedIndex].setAttribute('selected', 'selected');
                                updateProductCard('{{ swatch_count }}', '{{ card_product.url }}');
                                loadingEls = '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}';
                              }, 0)"
                            > 
                              {%- liquid
                                assign enable_color_swatches = false
                                if swatch_enabled and settings.swatches_type == 'color' and settings.color_option_name contains option.name
                                  assign enable_color_swatches = true
                                endif
                              -%}
                              {% render 'product-variant-options',
                                product: card_product,
                                option: option,
                                option_index: option_index,
