    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <circle cx="16" cy="12" r="1.6" fill="currentColor" stroke="none"/>
    <circle cx="12.5" cy="14.5" r="1" fill="currentColor" stroke="none"/>
