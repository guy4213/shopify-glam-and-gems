    <path d="M3 21 Q 13 24 23 21" stroke-width="1.5"/>
    <path d="M9 21 Q 19 10 29 21" stroke-width="1.5"/>
    <path d="M9 21 Q 19 24 29 21" stroke-width="1.5"/>
