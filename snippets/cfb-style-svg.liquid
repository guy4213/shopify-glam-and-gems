{%- comment -%}
  Inline SVG icon for collection-filter-board "style" tile.
  Usage: {% render 'cfb-style-svg', name: 'three stone' %}
  `name` should be the lowercased style label.
{%- endcomment -%}
{%- case name -%}
  {%- when 'solitaire' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="12" r="3"/><path d="M7 23c3-3 6-4 9-4s6 1 9 4"/></svg>
  {%- when 'three stone' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="12" r="3"/><circle cx="9" cy="14" r="2"/><circle cx="23" cy="14" r="2"/><path d="M5 24c3-3 6-4 11-4s8 1 11 4"/></svg>
  {%- when 'side stone', 'side stones', 'side diamonds' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="12" r="2.8"/><circle cx="10" cy="14" r="1.4" fill="currentColor"/><circle cx="22" cy="14" r="1.4" fill="currentColor"/><path d="M7 23c3-3 6-4 9-4s6 1 9 4"/></svg>
  {%- when 'halo' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="13" r="2.5"/><circle cx="16" cy="13" r="5" stroke-dasharray="1.5 1.5"/><path d="M8 23c2-2 5-3 8-3s6 1 8 3"/></svg>
  {%- when 'hidden halo' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="11" r="3"/><circle cx="11" cy="17" r="0.7" fill="currentColor" stroke="none"/><circle cx="14" cy="18" r="0.7" fill="currentColor" stroke="none"/><circle cx="18" cy="18" r="0.7" fill="currentColor" stroke="none"/><circle cx="21" cy="17" r="0.7" fill="currentColor" stroke="none"/><path d="M8 24c2-2 5-3 8-3s6 1 8 3"/></svg>
  {%- when 'double halo' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="14" r="2"/><circle cx="16" cy="14" r="4.5" stroke-dasharray="1.5 1.5"/><circle cx="16" cy="14" r="7"/></svg>
  {%- when 'pavé', 'pave' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="16" cy="16" rx="11" ry="3"/><circle cx="9" cy="16" r="0.8" fill="currentColor" stroke="none"/><circle cx="13" cy="16" r="0.8" fill="currentColor" stroke="none"/><circle cx="16" cy="16" r="0.8" fill="currentColor" stroke="none"/><circle cx="19" cy="16" r="0.8" fill="currentColor" stroke="none"/><circle cx="23" cy="16" r="0.8" fill="currentColor" stroke="none"/></svg>
  {%- when 'eternity' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="16" r="8"/><circle cx="16" cy="8" r="0.9" fill="currentColor" stroke="none"/><circle cx="24" cy="16" r="0.9" fill="currentColor" stroke="none"/><circle cx="16" cy="24" r="0.9" fill="currentColor" stroke="none"/><circle cx="8" cy="16" r="0.9" fill="currentColor" stroke="none"/><circle cx="21.7" cy="10.3" r="0.7" fill="currentColor" stroke="none"/><circle cx="21.7" cy="21.7" r="0.7" fill="currentColor" stroke="none"/><circle cx="10.3" cy="21.7" r="0.7" fill="currentColor" stroke="none"/><circle cx="10.3" cy="10.3" r="0.7" fill="currentColor" stroke="none"/></svg>
  {%- when 'half eternity' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="16" r="8"/><path d="M8 16a8 8 0 0 1 16 0" stroke-dasharray="1.5 1.5"/></svg>
  {%- when 'vintage' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="12" r="3"/><path d="M11 12c-1-2-1-5 1-5m9 0c2 0 2 3 1 5"/><path d="M8 23c2-2 5-3 8-3s6 1 8 3"/></svg>
  {%- when 'bezel' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="11" y="8" width="10" height="10" rx="1.5"/><circle cx="16" cy="13" r="2.5"/><path d="M8 23c2-2 5-3 8-3s6 1 8 3"/></svg>
  {%- when 'classic' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="16" cy="16" rx="10" ry="3.5"/></svg>
  {%- when 'contoured' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 18c4-3 7-3 11 0s7 3 11 0"/><path d="M5 14c4-3 7-3 11 0s7 3 11 0"/></svg>
  {%- when 'bridal sets' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="16" rx="7" ry="2.5"/><ellipse cx="20" cy="16" rx="7" ry="2.5"/></svg>
  {%- when 'special' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 6l2.5 5 5.5.8-4 3.9.9 5.4-4.9-2.6-4.9 2.6.9-5.4-4-3.9 5.5-.8z"/></svg>
  {%- when 'tennis' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 16h24"/><path d="M7 16l2-2 2 2-2 2zm6 0l2-2 2 2-2 2zm6 0l2-2 2 2-2 2z" fill="currentColor"/></svg>
  {%- when 'stacking' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="16" cy="11" rx="9" ry="2.5"/><ellipse cx="16" cy="16" rx="9" ry="2.5"/><ellipse cx="16" cy="21" rx="9" ry="2.5"/></svg>
  {%- when 'studs' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4"/><circle cx="20" cy="20" r="4"/></svg>
  {%- when 'chains' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="9" cy="16" rx="4" ry="2.5"/><ellipse cx="16" cy="16" rx="4" ry="2.5"/><ellipse cx="23" cy="16" rx="4" ry="2.5"/></svg>
  {%- when 'drop' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 5v6"/><path d="M16 27c-4-4-7-7-7-11a7 7 0 0 1 14 0c0 4-3 7-7 11z"/></svg>
  {%- when 'hoop' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="16" r="10"/></svg>
  {%- when 'bangles' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="16" r="10"/><circle cx="16" cy="16" r="7.5"/></svg>
  {%- when 'cuff' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 7a10 10 0 1 0 0 18" stroke-linecap="round"/></svg>
  {%- else -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="16" r="9"/></svg>
{%- endcase -%}
