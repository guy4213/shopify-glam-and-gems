{%- comment -%}
  Inline SVG icon for collection-filter-board "style" tile.
  Usage: {% render 'cfb-style-svg', name: 'three stone' %}
  `name` should be the lowercased style label.

  WR styles (classic, side diamonds, bezel, eternity, half eternity,
  contoured, bridal sets, special) are drawn as a band-profile view —
  a curved top half + flat bottom half so the ring looks like a real
  wedding band cross-section.

  ER styles (solitaire, three stone, side stone, halo, hidden halo,
  double halo, pavé, vintage) keep their setting-profile look.

  Jewelry styles (tennis, stacking, studs, chains, drop, hoop, bangles,
  cuff) keep their object-silhouette look.
{%- endcomment -%}
{%- case name -%}
  {%- comment -%} ── WR — wedding-band profile views ── {%- endcomment -%}
  {%- when 'classic' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
    <path d="M5 20 Q 16 9 27 20" stroke-width="1.5"/>
    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <path d="M7 19 Q 16 12 25 19" stroke-width="0.7"/>
  </svg>

  {%- when 'side diamonds' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
    <path d="M5 20 Q 16 9 27 20" stroke-width="1.5"/>
    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <circle cx="10" cy="14.4" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="13" cy="12.1" r="1.1" fill="currentColor" stroke="none"/>
    <circle cx="16" cy="11.3" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="19" cy="12.1" r="1.1" fill="currentColor" stroke="none"/>
    <circle cx="22" cy="14.4" r="1.0" fill="currentColor" stroke="none"/>
  </svg>

  {%- when 'bezel' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
    <path d="M5 20 Q 16 9 27 20" stroke-width="1.5"/>
    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <rect x="11" y="10" width="10" height="8" rx="1" stroke-width="1.2"/>
    <circle cx="16" cy="14" r="1.8" fill="currentColor" stroke="none"/>
    <circle cx="13" cy="14" r="0.5" fill="currentColor" stroke="none"/>
    <circle cx="19" cy="14" r="0.5" fill="currentColor" stroke="none"/>
  </svg>

  {%- when 'eternity' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
    <path d="M5 20 Q 16 9 27 20" stroke-width="1.5"/>
    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <circle cx="8" cy="16.6" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="11" cy="13.6" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="14" cy="11.8" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="17" cy="11.4" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="20" cy="12.3" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="23" cy="14.3" r="1.0" fill="currentColor" stroke="none"/>
    <circle cx="26" cy="17.5" r="1.0" fill="currentColor" stroke="none"/>
  </svg>

  {%- when 'half eternity' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
    <path d="M5 20 Q 16 9 27 20" stroke-width="1.5"/>
    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <circle cx="12" cy="12.6" r="1.1" fill="currentColor" stroke="none"/>
    <circle cx="14.5" cy="11.6" r="1.1" fill="currentColor" stroke="none"/>
    <circle cx="17" cy="11.4" r="1.1" fill="currentColor" stroke="none"/>
    <circle cx="19.5" cy="12.1" r="1.1" fill="currentColor" stroke="none"/>
  </svg>

  {%- when 'contoured' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
    <path d="M5 21 Q 10 21 12 16 Q 16 9 20 16 Q 22 21 27 21" stroke-width="1.5"/>
    <path d="M5 20 Q 16 24 27 20" stroke-width="1.5"/>
    <circle cx="12" cy="16" r="0.9" fill="currentColor" stroke="none"/>
    <circle cx="16" cy="11" r="0.9" fill="currentColor" stroke="none"/>
    <circle cx="20" cy="16" r="0.9" fill="currentColor" stroke="none"/>
  </svg>

  {%- when 'bridal sets' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-linecap="round">
