                        <input type="hidden" aria-hidden="true" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        {{ form | payment_terms }}
                      {%- endform -%}
                    </div>
                  </div>
                {%- when 'description' -%}
                  {% render 'product-description', product: product, block: block, show_content_center: show_content_center %}
                {%- when 'buy_buttons' -%}
                  {%- unless settings.hide_cart -%}
                    {%- liquid
                      assign gift_card_recipient_active = false
                      if block.settings.show_gift_card_recipient and product.gift_card?
                        assign gift_card_recipient_active = true
                      endif
                      
                      if settings.gift_wrapping_product != blank
                        assign gift_wrapping_product = settings.gift_wrapping_product.selected_or_first_available_variant.id
                      endif
                      if settings.engraving_product != blank
                        assign engraving_product = settings.engraving_product.selected_or_first_available_variant.id
                      endif
                    -%}
                    <div 
