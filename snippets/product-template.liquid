                                    .payment-button.button-outline .shopify-payment-button__button--unbranded {
                                      box-shadow: inset 0 0 0 1px rgba(var(--colors-line-secondary-button),0.5);
                                      background: rgba(var(--background-secondary-button),0.7);
                                      transition: 0.3s;
                                    }
                                  }
                                {% else %}
                                  .payment-button.button-solid .shopify-payment-button__button--unbranded:hover:not([disabled]) {
                                    background-color: var(--colors-button-hover);
