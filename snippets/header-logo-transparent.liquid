{% comment %}
    Renders a block logo

    Accepts:
    - logo_above: {Boolean} Logo above
    Usage:
    {% render 'header-logo-block' %}
{% endcomment %}
{%- liquid 
  assign logo_alt = section.settings.logo.alt | default: shop.name | escape
  assign logo_alt_dark = section.settings.logo_dark.alt | default: shop.name | escape
  assign logo_alt_transparent = logo_transparent.alt | default: shop.name | escape

  assign logo_pos = 'left'
  if section.settings.logo_position == 'above-center' or section.settings.logo_position == 'center-left'
    assign logo_pos = 'center'
  endif

  assign enable_compact_menu = false
  if section.settings.enable_hamburger_menu or section.settings.enable_hamburger_menu == false and section.settings.enable_drawer_menu
    assign enable_compact_menu = true
  endif

  if section.settings.logo_position == 'left-left' or enable_compact_menu and logo_pos == 'left'
    if section.blocks.size > 0 
      assign show_border = true
    elsif section.settings.menu != blank
      assign show_border = true
    endif
  endif

  assign class_logo_dark ="header-logo hidden absolute dark:block dark:relative mr-auto ml-auto"
  assign class_logo_light ="header-logo block dark:hidden dark:absolute mr-auto ml-auto"
  if logo_above 
    assign class_logo_dark = class_logo_dark | append: " md:mr-auto md:ml-auto"
    assign class_logo_light = class_logo_light | append: " md:mr-auto md:ml-auto"
  else
    assign class_logo_dark = class_logo_dark | append: " md:ml-0"
    assign class_logo_light = class_logo_light | append: " md:ml-0"
  endif
-%}
{%- capture sizes -%}
  (min-width: 768px) {{ section.settings.logo_width }}px, {{ section.settings.logo_width_mobile }}px
{%- endcapture -%}
{% style %}
  #sticky-header-content .logo-normal,
  #sticky-header-content:hover .logo-transparent,
  #sticky-header-content .open-menu .logo-transparent,
  .is-sticky #sticky-header-content .logo-transparent,
  .is-scrolled #sticky-header-content .logo-transparent,
  #sticky-header-content:has(.hamburger-menu-container.h-hamburger) .logo-transparent {
    visibility: hidden;
  }
  #sticky-header-content .logo-transparent,
  #sticky-header-content:hover .logo-normal,
  #sticky-header-content .open-menu .logo-normal,
  .is-sticky #sticky-header-content .logo-normal,
  .is-scrolled #sticky-header-content .logo-normal,
  #sticky-header-content:has(.hamburger-menu-container.h-hamburger) .logo-normal {
    visibility: visible;
  }
  .header-logo {
    grid-area: 1 / 1;
  }
{% endstyle %}
<div class="flex{% if logo_above %} lg:pt-2 lg:pb-2 items-center{% endif %}{% if show_border %}{% if settings.lang_direction contains request.locale.iso_code %} lg:ml-3 {% if enable_compact_menu %}lg:pl-5 lg:border-l {% else %}lg:pl-110{% endif %}{% else %} lg:mr-3 {% if enable_hamburger %}lg:pr-5 lg:border-r{% else %}lg:pr-11{% endif %}{% endif %}{% endif %}">
  <a href="{{ routes.root_url }}" class="w-logo-header h-auto disable-effect inline-block">
    {%- if section.settings.logo_dark != blank -%}
      <span class="logo-dark hidden dark:grid place-items-center">
        <img
          src="{{ logo_transparent | image_url: width: logo_transparent.width }}"
          alt="{{ logo_alt_transparent }}"
          sizes="{{ sizes }}"
          srcset="{{ logo_transparent | image_url: width: 50 }} 50w,
            {{ logo_transparent | image_url: width: 100 }} 100w,
            {{ logo_transparent | image_url: width: 150 }} 150w,
            {{ logo_transparent | image_url: width: 200 }} 200w,
            {{ logo_transparent | image_url: width: 250 }} 250w,
            {{ logo_transparent | image_url: width: 300 }} 300w,
            {{ logo_transparent | image_url: width: 400 }} 400w,
            {{ logo_transparent | image_url: width: 500 }} 500w,
            {{ logo_transparent | image_url: width: 600 }} 600w"
          width="{{ logo_transparent.width }}"
          height="{{ logo_transparent.height }}"
          class="header-logo logo-transparent hidden dark:block mr-auto ml-auto{% if logo_above %} md:mr-auto md:ml-auto{% else %} md:ml-0{% endif %}"
          loading="lazy"
        />
        <img
          src="{{ section.settings.logo_dark | image_url: width: section.settings.logo_dark.width }}"
          alt="{{ logo_alt_dark }}"
          sizes="{{ sizes }}"
          srcset="{{ section.settings.logo_dark | image_url: width: 50 }} 50w,
            {{ section.settings.logo_dark | image_url: width: 100 }} 100w,
            {{ section.settings.logo_dark | image_url: width: 150 }} 150w,
            {{ section.settings.logo_dark | image_url: width: 200 }} 200w,
            {{ section.settings.logo_dark | image_url: width: 250 }} 250w,
            {{ section.settings.logo_dark | image_url: width: 300 }} 300w,
            {{ section.settings.logo_dark | image_url: width: 400 }} 400w,
            {{ section.settings.logo_dark | image_url: width: 500 }} 500w,
            {{ section.settings.logo_dark | image_url: width: 600 }} 600w"
          width="{{ section.settings.logo_dark.width }}"
          height="{{ section.settings.logo_dark.height }}"
          class="header-logo logo-normal hidden dark:block mr-auto ml-auto{% if logo_above %} md:mr-auto md:ml-auto{% else %} md:ml-0{% endif %}"
          loading="lazy"
          decoding="sync"
        />
      </span>
    {%- else -%}
      <span class="hidden dark:block h-0 dark:h-auto mr-auto ml-auto{% if logo_above %} md:mr-auto md:ml-auto{% else %} md:ml-0{% endif %}">{{ shop.name }}</span>
    {%- endif -%}
    {%- if section.settings.logo != blank -%}
      <span class="logo-light dark:hidden grid place-items-center">
        <img
          src="{{ logo_transparent | image_url: width: logo_transparent.width }}"
          alt="{{ logo_alt_transparent }}"
          sizes="{{ sizes }}"
          srcset="{{ logo_transparent | image_url: width: 50 }} 50w,
            {{ logo_transparent | image_url: width: 100 }} 100w,
            {{ logo_transparent | image_url: width: 150 }} 150w,
            {{ logo_transparent | image_url: width: 200 }} 200w,
            {{ logo_transparent | image_url: width: 250 }} 250w,
            {{ logo_transparent | image_url: width: 300 }} 300w,
            {{ logo_transparent | image_url: width: 400 }} 400w,
            {{ logo_transparent | image_url: width: 500 }} 500w,
            {{ logo_transparent | image_url: width: 600 }} 600w"
          width="{{ logo_transparent.width }}"
          height="{{ logo_transparent.height }}"
          class="header-logo logo-transparent block dark:hidden mr-auto ml-auto{% if logo_above %} md:mr-auto md:ml-auto{% else %} md:ml-0{% endif %}"
          loading="lazy"
        />
        <img
          src="{{ section.settings.logo | image_url: width: section.settings.logo.width }}"
          alt="{{ logo_alt }}"
          sizes="{{ sizes }}"
          srcset="{{ section.settings.logo | image_url: width: 50 }} 50w,
            {{ section.settings.logo | image_url: width: 100 }} 100w,
            {{ section.settings.logo | image_url: width: 150 }} 150w,
            {{ section.settings.logo | image_url: width: 200 }} 200w,
            {{ section.settings.logo | image_url: width: 250 }} 250w,
            {{ section.settings.logo | image_url: width: 300 }} 300w,
            {{ section.settings.logo | image_url: width: 400 }} 400w,
            {{ section.settings.logo | image_url: width: 500 }} 500w,
            {{ section.settings.logo | image_url: width: 600 }} 600w"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
          class="header-logo logo-normal block dark:hidden mr-auto ml-auto{% if logo_above %} md:mr-auto md:ml-auto{% else %} md:ml-0{% endif %}"
          loading="lazy"
          decoding="sync"
        />
      </span>
    {%- else -%}
      <span class="block dark:hidden dark:max-h-0 mr-auto ml-auto{% if logo_above %} md:mr-auto md:ml-auto{% else %} md:ml-0{% endif %}">{{ shop.name }}</span>
    {%- endif -%}
  </a>
</div>