    <div
      id="choose-options-{{ section_id }}-{{ card_product_id }}-{{ block_id }}"
      class="hidden md:block absolute w-full min-h-full h-full left-0 top-0 bg-[rgba(var(--background-color))] z-[15] md:list-layout:w-3/5 list-layout:lg:w-3/4{% if is_rtl %} md:list-layout:right-auto md:list-layout:left-0{% else %} md:list-layout:left-auto md:list-layout:right-0{% endif %}"
      x-show="showOptions"
      x-transition:enter="transition-all ease-in-out duration-300"
      x-transition:enter-start="opacity-0 transform translate-y-full"
      x-transition:enter-end="opacity-100 transform translate-y-0"
      x-transition:leave="transition-all ease-in-out duration-300"
      x-transition:leave-start="opacity-100 transform translate-y-0"
      x-transition:leave-end="opacity-0 transform translate-y-full"
      x-cloak
    >
      <div class="choose-options relative w-full min-h-full h-full"></div>
      <div class="icon-loading hidden absolute top-0 left-0 right-0 h-full w-full z-20 bg-[rgba(var(--background-color))]">
        <div
          class="lg:inline-block w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]">
          {% render 'icon-alls', icon: 'icon-loading' %}
        </div>
      </div>
    </div>
  {%- endif -%}
  {% comment %} Show the product details when card product is in list view {% endcomment %}
  <div
    id="x-product-template-{{ card_product_id }}-{{ section_id }}-{{ product_card_id }}"
    class="list-layout:lg:w-3/4 md:list-layout:w-3/5 list-layout:md:pl-0 rtl:list-layout:md:pl-5 rtl:list-layout:md:pr-0 text-{{ content_alignment }}{% if is_rtl %} md:list-layout:text-right{% endif %}"
  >
    {% unless disable_color_swatch %}
      {%- if swatch_enabled and only_default_variant == false -%}
        <div
          class="x-variants-data hover-option-value x-variants-data-js pt-3 {% if settings.show_variant_option %}x-variants-separator{% endif %} x-variants-separator-{{ section.id }}-{{ card_product.id }} relative mt-3"
          x-data='xVariantSelectCard($el,"{{ section_id }}-{{ product_card_id }}", "{{ card_product.id }}", "{{ card_product.url }}", false, false, false, "", "", "", "{{ section.id }}")'
          {% for option in card_product.options_with_values %}
            data-option{{ forloop.index }}="{{ option.selected_value | escape }}"
          {% endfor %}  
          data-url="{{ card_product.url }}"
          x-intersect.once.margin.200px="if (document.getElementById('variant-update-{{ section_id }}-{{ product_card_id }}').innerHTML.trim() == '') $el.classList.add('hidden');"
        >
          <div
            id="current-variant-{{ section_id }}-{{ card_product_id }}-{{ block_id }}" 
            class="current-variant hidden"
          >
            {{ first_variant.id }}
          </div>
          <div
            id="variant-update-{{ section_id }}-{{ product_card_id }}"
            class="variant-update-{{ section_id }}-{{ product_card_id }} list-layout:md:text-left rtl:list-layout:md:text-right options-container"
          >
            {% if swatch_count > 0 %}
              {% style %}
                .x-variants-separator.x-variants-separator-{{ section.id }}-{{ card_product.id }}::before {
                  border-top-width: 1px;
                }
              {% endstyle %}
            {% endif %}
            {%- for option in card_product.options_with_values -%}
              {% if swatch_options contains option.name %}
                {% assign option_index = forloop.index0 %}
                {% liquid 
                  assign quick_add_picker_type = settings.quick_add_picker_type
                  
                  assign is_color = false 
                  if settings.color_option_name contains option.name and settings.swatches_type == 'color' or settings.swatches_type == 'both_text_and_color'
                    assign is_color = true
                  endif
                  
                  if quick_add_picker_type == 'button' and settings.max_swatch != 0 and option.values.size > settings.max_swatch
                    if is_color == false or is_color and settings.swatch_show_by_default == 0
                      assign quick_add_picker_type = 'dropdown'
                    endif
                  endif
                %}
                {%- if quick_add_picker_type == 'button' -%}
                  <fieldset
                    id="Option-{{ section_id }}-{{ product_card_id }}-{{ forloop.index0 }}"
                    class="product-form__input pl-0 pb-2.5 quick-view:pb-2 eurus gap-x-2"
                    x-data="{activeSwatch: false}"
                    @click.capture="activeSwatch = false"
                    @click.outside="activeSwatch = false"
                  >
                    {% if settings.show_variant_option %}<div class="mb-2">{{ option.name }}</div>{% endif %}
                    <div class="inline-flex flex-wrap items-center{% if is_color %} ml-0.5 mr-0.5 gap-2.5{% else %} gap-1.5{% endif %}{% if collage %} justify-{{ info_alignment }} rtl:justify-{% if info_alignment == 'center' %}center{% elsif info_alignment == 'left' %}right{% else %}left{% endif %}{% else %} justify-{{ settings.info_alignment_card_product }} rtl:justify-{% if settings.info_alignment_card_product == 'center' %}center{% elsif settings.info_alignment_card_product == 'left' %}right{% else %}left{% endif %}{% endif %} md:list-layout:justify-start rtl:md:list-layout:justify-end">
                      {%- liquid
                        assign color_option_values = settings.color_option_values | newline_to_br | strip_newlines | split: '<br />'
                        assign text_option_values = settings.text_option_values | newline_to_br | strip_newlines | split: '<br />'
                        if settings.products_color_swatches_style == 'round' 
                          assign class_swatch = ' rounded-full before:rounded-full'
                        elsif settings.edges_type == 'rounded_corners'
                          assign class_swatch = ' rounded-md overflow-hidden'
                        endif
                        if settings.swatch_show_by_default != 0
                          assign count_value = option.values.size
                          if count_value > settings.swatch_show_by_default
                            assign is_count = true
                            assign count_value = count_value | minus: settings.swatch_show_by_default
                          endif
                        endif

                        assign swatch_natural = false     
                        if settings.products_color_swatches_style == 'natural'
                          assign swatch_natural = true
                        endif
                        assign ratio_image = false

                        assign max_swatch = settings.swatch_show_by_default | minus: 1
                      %}
                      {% if is_color and settings.swatch_show_by_default != 0 %}
                        {% capture enable_count %}
                          <div class="relative inline-flex">
                            <div
                              {% unless disable_quickview %}
                                tabindex="0"
                                @click.prevent='$store.xQuickView && $store.xQuickView.open(); $store.xCustomerEvent.fire("product_selected", $el);'
                                @keydown.enter.prevent='$store.xQuickView && $store.xQuickView.open(); $store.xCustomerEvent.fire("product_selected", $el);'
                                x-on:mouseover="$store.xQuickView && $store.xQuickView.load('{{ card_product_url }}', $el, '{{ section_id }}-{{ card_product_id }}-{{ block_id }}')" 
                                x-on:focus="$store.xQuickView && $store.xQuickView.load('{{ card_product_url }}', $el, '{{ section_id }}-{{ card_product_id }}-{{ block_id }}')" 
                                :class="!$store.xQuickView.enabled ? 'pointer-events-none' : 'cursor-pointer'"
                              {% endunless %}
                              class="swatch-count-{{ settings.swatch_size }} color-watches {{ class_swatch }} flex"
                            >
                              <span class="grow pointer-events-none text-center leading-none content-center">+{{ count_value }}</span>
                            </div>
                          </div>
                        {% endcapture %}
                      {% endif %}
                      {%- for value in option.values -%}
                        <div @click="activeSwatch = {{ forloop.index }}" class="relative inline-flex">
                          {% liquid
                            assign variant_value = value.variant
                            assign preview_image = variant_value.featured_media.preview_image | default: card_product.featured_media
                            unless ratio_image
                              assign ratio_image = 100.0 | divided_by: preview_image.aspect_ratio
                            endunless

                            assign color_custom = ''
                            assign swatch_image = false
                            assign color_value = ''
                            if settings.color_option_values contains value
                              for color_option_value in color_option_values reversed
                                if color_option_value contains value
                                  assign color_option_key_value = color_option_value | split: ':'
                                  assign color_option_key = color_option_key_value | first
                                  if value == color_option_key
                                    assign color_custom = color_option_key
                                    assign option_value = color_option_key_value | last | strip
                                    assign color_value = option_value

                                    if option_value contains '.'
                                      assign swatch_image = true
                                    endif

                                    assign multi_colors = option_value | remove_first: '#' | split: '#'
                                    break
                                  endif
                                endif
                              endfor
                            endif
                          %}
                          {% if preview_image and settings.replace_color_with_variant_images %}
                            {% if settings.color_option_name contains option.name %}
                              {%- style %}
                                .color-watches.variant-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}:before {
                                  background-image: var(--bg-image);
                                }
                              {%- endstyle %}
                            {% endif %}
                          {% elsif color_custom != '' %}
                            {%- style %}
                              {% if swatch_image %}
                                [data-swatch="{{ color_custom }}"]:before {
                                  background-image: url({{ color_value | file_img_url: "100x100" }});
                                }
                              {% elsif multi_colors.size == 3 %}
                                [data-swatch="{{ color_custom }}"]:before {
                                  background: linear-gradient(45deg, {{ '#' | append: multi_colors[0] }}, {{ '#' | append: multi_colors[0] }} 33.3%, {{ '#' | append: multi_colors[1] }} 33.3%, {{ '#' | append: multi_colors[1] }} 66.6%, {{ '#' | append: multi_colors[2] }} 66.6%, {{ '#' | append: multi_colors[2] }});
                                }
                              {% elsif multi_colors.size == 2 %}
                                [data-swatch="{{ color_custom }}"]:before {
                                  background: linear-gradient(45deg, {{ '#' | append: multi_colors[0] }}, {{ '#' | append: multi_colors[0] }} 50%, {{ '#' | append: multi_colors[1] }} 50%, {{ '#' | append: multi_colors[1] }});
                                }
                              {% else %}
                                [data-swatch="{{ color_custom }}"]:before {
                                  background: {{ color_value }};
                                }
                              {% endif %}
                            {%- endstyle %}
                          {% endif %}
                          <input 
                            id="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}"
                            data-available="{{ value.available }}"
                            data-product-url="{{ card_product.url }}"
                            data-option-value-id="{{ value.id }}"
                            section-id="{{ section_id }}-{{ product_card_id }}"
                            option-pos="{{ option.position }}"
                            forloop="{{ forloop.index0 }}"
                            type="radio"
                            name="{{ option.name }}-{{ product_card_id }}-{{ section_id }}"
                            value="{{ value | escape | replace: '&lt;', '\u003c' | replace: '&gt;', '\u003e' }}"
                            form="{{ product_form_id }}"
                            class="absolute opacity-0 h-1 w-1 input-radio{% unless value.available %} disabled{% endunless %}"
                            aria-label="{{ value | escape }}"
                            @keydown.enter.prevent="$el.click()"
                            @change="setTimeout(() => {  
                              updateProductCard('{{ swatch_count }}', '{{ value.product_url }}');
                              loadingEls = '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}';
                            }, 0)"
                            {% if settings.default_select_available_variant and value == option.selected_value %}
                              checked
                            {% endif %}
                          >
                          {% if is_color %}
                            <label 
                              :class="activeSwatch == {{ forloop.index }} && 'active-swatch'"
                              class="color-watches hover-option variant-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }} cursor-pointer block{% if swatch_natural and settings.replace_color_with_variant_images and ratio_image %} color-swatch-natural{% endif %} swatch-{{ settings.swatch_size }} relative{{ class_swatch }}" 
                              for="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}" 
                              data-swatch="{{ color_custom }}"
                              data-optionindex="{{ option_index }}"
                              data-optionvalue="{{ value | escape | replace: '&lt;', '\u003c' | replace: '&gt;', '\u003e' }}"
                              data-option-value-id="{{ value.id }}"
                              {% if preview_image == blank or settings.replace_color_with_variant_images == false and color_custom == '' %}
                                {% liquid
                                  if value.swatch.image
                                    assign image_url = value.swatch.image | image_url: width: 50
                                    assign swatch_value = 'url(' | append: image_url | append: ')'
                                  elsif value.swatch.color
                                    assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                                  else
                                    assign swatch_value = value | split: ' ' | last | handle
                                  endif
                                %}
                                style="background: {{ swatch_value }};"
                              {% elsif swatch_natural and ratio_image %}
                                style="--ratio-image: {{ ratio_image }}%; --bg-image: url('{{ preview_image | image_url: width: 100, height: 100 }}')"
                              {% else %}
                                style="--bg-image: url('{{ preview_image | image_url: width: 100, height: 100 }}')"
                              {% endif %}
                              tabindex="0"
                              @keydown.enter.prevent="$el.click()"
                              data-name="{{ value | escape }}"
                              aria-label="{{ value | escape }}"
                            >
                              {% render 'hover-option-value-card-product', value: value %}
                              <div x-cloak x-show="loadingEls === '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}'" class="w-full h-full flex items-center justify-center absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[rgba(var(--colors-background))]">
                                <div class="animate-spin w-4 h-4 border-loading border-[rgba(var(--colors-text))]"></div>
                              </div>
                              <span class="h-full w-full color-watches-disable"></span>
                            </label>
                          {% elsif settings.swatches_type == 'text' or settings.swatches_type == 'both_text_and_color' and settings.text_option_name contains option.name %}
                            {% liquid
                              assign text_custom = blank
                              assign text_value = ''
                              if settings.text_option_values contains value
                                for text_option_value in text_option_values
                                  if text_option_value contains value
                                    assign text_option_key_value = text_option_value | split: ':'
                                    assign text_option_key = text_option_key_value | first

                                    if text_option_key == value
                                      assign text_custom = text_option_key
                                      assign text_value = text_option_key_value | last
                                      break
                                    endif
                                  endif
                                endfor
                              endif
                            %}
                            <label class="flex relative items-center font-medium text-[13px] cursor-pointer{% if settings.info_alignment_card_product == 'right' %} rtl:mr-0{% endif %} pl-3.5 pr-3.5 pt-1.5 pb-1.5 border bg-[rgba(var(--background-color),1)]
                              {% if settings.edges_type == 'rounded_corners' %} rounded-md{% endif %}" 
                              for="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}"
                              data-option-value-id="{{ value.id }}"
                              tabindex="0"
                              @keydown.enter.prevent="$el.click()"
                            >
                              <div x-cloak x-show="loadingEls === '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}'" class="w-4 h-4 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                                <div class="animate-spin w-4 h-4 border-loading"></div>
                              </div>
                              <span :class="loadingEls === '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}' && 'invisible'" class="p-break-words">
                                {% if text_custom != blank %}{{ text_value | escape }}{% else %}{{ value | escape }}{% endif %}
                              </span>
                            </label>
                          {% endif %}
                          <script type="application/json" data-option-value-id="{{ value.id }}" data-resource="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}">
                            {{ value.variant | json }}
                          </script>
                        </div>
                        {% if is_color and settings.swatch_show_by_default != 0 %}
                          {% liquid
                            if forloop.index > max_swatch
                              if is_count
                                echo enable_count
                              endif
                              break
                            endif
                          %}
                        {% endif %}
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {% else %}
                  <div 
                    data-option-name="{{ option.name | handle }}"
                    data-option-index="{{ forloop.index0 }}"
                  >
                    {% if settings.show_variant_option %}
                      <label class="mt-1 mb-1 font-medium text-left rtl:text-right block" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                        {{ option.name }}
                      </label>
                    {% endif %}
                    <div class="select relative outline-none eurus">
                      <select
                        id="Option-{{ section.id }}-{{ forloop.index0 }}"
                        class="product-form__input w-full pt-2.5 pb-2.5 pl-5 pr-8 rtl:pr-5 rtl:pl-8 mt-2 mb-2 bg-transparent focus:border-current border appearance-none outline-none border-solid focus-visible:outline-none cursor-pointer{% if settings.edges_type == 'rounded_corners' %} !rounded-md{% endif %}"
                        name="{{ option.name }}"
                        form="{{ product_form_id }}"
                        @change="setTimeout(() => {
                          Array.from($el.options).forEach(option => { option.removeAttribute('selected') });
                          $el.options[$el.selectedIndex].setAttribute('selected', 'selected');
                          updateProductCard('{{ swatch_count }}', '{{ card_product.url }}');
                          loadingEls = '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}';
                        }, 0)"
                      > 
                        {%- liquid
                          assign enable_color_swatches = false
                          if swatch_enabled and settings.swatches_type == 'color' and settings.color_option_name contains option.name
                            assign enable_color_swatches = true
                          endif
                        -%}
                        {% render 'product-variant-options',
                          product: card_product,
                          option: option,
                          option_index: option_index,
                          product_form_id: product_form_id,
                          input_type: 'select',
                          enable_color_swatches: enable_color_swatches
                        %}
                      </select>
                      <div x-cloak x-show="loadingEls === '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}'" class="w-4 h-4 absolute top-1/2 right-3 rtl:right-auto rtl:left-3 -translate-y-1/2">
                        <div class="animate-spin w-4 h-4 border-loading"></div>
                      </div>
                      <span x-cloak x-show="loadingEls !== '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}'" class="absolute top-1/2 right-4 rtl:right-auto rtl:left-4 -translate-y-1/2 w-2.5 inline-block pointer-events-none">
                        {% render 'icon-alls', icon: 'icon-caret' %}
                      </span>
                    </div>
                  </div>
                {% endif %}
              {% elsif settings.swatches_type == 'both_text_and_color' %}
                {%- assign option_index = forloop.index0 -%}
                <fieldset
                  id="Option-{{ section_id }}-{{ product_card_id }}-{{ forloop.index0 }}"
                  class="product-form__input pl-0{% unless forloop.last %} pb-2{% endunless %} quick-view:pb-2 eurus gap-x-2 hidden"
                >
                  <div class="inline-flex flex-wrap justify-left">
                    {%- for value in option.values -%}
                      {% if forloop.first %}
                        <input 
                          id="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}"
                          data-available="{{ value.available }}"
                          data-product-url="{{ card_product.url }}"
                          data-option-value-id="{{ value.id }}"
                          section-id="{{ section_id }}-{{ product_card_id }}"
                          option-pos="{{ option.position }}"
                          forloop="{{ forloop.index0 }}"
                          type="radio"
                          name="{{ option.name }}-{{ product_card_id }}-{{ section_id }}"
                          value="{{ value | escape | replace: '&lt;', '\u003c' | replace: '&gt;', '\u003e' }}"
                          form="{{ product_form_id }}"
                          class="absolute opacity-0 h-1 w-1 input-radio"
                          aria-label="{{ value | escape }}"
                          @change="setTimeout(() => { 
                            updateProductCard('{{ swatch_count }}', '{{ card_product.url }}');
                            loadingEls = '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}';
                          }, 0)"
                          {% if settings.default_select_available_variant %}
                            checked
                          {% endif %}
                        >  
                        <label class="flex relative items-center outline-none font-medium text-[13px] cursor-pointer mr-[5px]{% if settings.info_alignment_card_product == 'right' %} rtl:mr-0 rtl:ml-1.5{% endif %} pl-3.5 pr-3.5 pt-1.5 pb-1.5 border bg-[rgba(var(--background-color),1)]
                          {% if rounded_corner %} rounded-md{% endif %}" for="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}"
                          data-option-value-id="{{ value.id }}"
                        >
                          <div x-cloak x-show="loadingEls === '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}'" class="w-4 h-4 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                            <div class="animate-spin w-4 h-4 border-loading"></div>
                          </div>
                          <span :class="loadingEls === '{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}' && 'invisible'" class="p-break-words">{{ value | escape }}</span>
                        </label>
                      {% endif %}
                      <script type="application/json" data-option-value-id="{{ value.id }}" data-resource="{{ section_id }}-{{ product_card_id }}-{{ option.position }}-{{ forloop.index0 }}-{{ card_product_id }}">
                        {{ value.variant | json }}
                      </script>
                    {% endfor %}
                  </div>
                </fieldset>
              {% endif %}
            {%- endfor -%}
          </div>
        </div>
      {% else %}
        <div class="hidden" @init-run="document.addEventListener('eurus:cart:items-changed', () => {
          Alpine.store('xUpdateVariantQuanity').updateQuantity('{{ section.id }}', '{{ card_product.url }}');
        });"></div>
        <div
          id="current-variant-{{ section_id }}-{{ card_product_id }}-{{ block_id }}" 
          class="current-variant hidden"
        >
          {{ first_variant.id }}
        </div>
      {%- endif -%}
    {% endunless %}
    {% if show_highlighted_attributes %}
      <div class="card-info x-highlight-icon mt-2.5">
        {% render 'highlight-icon-card-product', card_product: card_product, content_alignment: content_alignment %}
      </div>
    {% endif %}
    {% unless disable_quickview %}
      <template x-if="$store.xQuickView">
        {%- unless settings.hide_cart -%} 
          <div x-data="xProductCart" x-show="$store.xQuickView.show_atc_button && ($store.xQuickView.btn_atc_bottom || !$store.xQuickView.atc_btn_image_desktop)" 
            class="card-info bottom_atc md:list-layout:hidden {% if show_icon_atc %}hide-btn{% else %}hide-icon{% endif %}"
            :class="if($store.xQuickView.show_atc_button){ return ($store.xQuickView.btn_atc_bottom ? '' : 'hidden') + ($store.xQuickView.atc_btn_image_desktop ? ' lg:hidden' : ' lg:block')}"
            x-cloak
          >
            {% if card_product.options_with_values.size == swatch_count or only_default_variant %}
              {%- assign product_form_id = 'product-form-choose-option' | append: card_product_id | append: index_param -%}
              {%- form 'product', card_product, id: product_form_id, class: 'form h-full', novalidate: 'novalidate', data-type: 'add-to-cart-form', x-ref: 'product_form' -%}
                <input type="hidden" aria-hidden="true" name="id" value="{{ first_variant.id }}">
                {% if settings.show_in_cart_items != 'none' %}
                  {% render 'estimate-shipping-cart', product: card_product, message: settings.message_estimate_cart, disable_cart_edt: disable_cart_edt %}
                {% endif %}
                {% if can_show_preorder %}
                  <input name="properties[{{ 'general.preorder.name' | t }}]" aria-label="Preorder" class="hidden" value="{{ message_preorder }}"/>
                {% endif %}
                <button
                  type="submit"
                  name="add"
                  {%- if only_default_variant or variant_available == false or swatch_enabled -%}
                    @click.prevent="errorMessage == false && addToCart($event)"
                  {%- else -%}
                    @click.prevent="setTimeout(() => { $store.xQuickView && (showOptions = !showOptions); $store.xQuickView.showChooseOption('{{ section_id }}-{{ card_product_id }}-{{ block_id }}', $el); }, 0)"
                    x-on:mouseover="setTimeout(() => { $store.xQuickView && $store.xQuickView.loadChooseOptions('{{ card_product_url }}', $el, '{{ section_id }}-{{ card_product_id }}-{{ block_id }}', {{ index_param }}); }, 0)"
                  {%- endif -%}
                  data-id="{{ section_id }}-{{ card_product_id }}-{{ block_id }}"
                  class="button button--quickview button-solid not-icon leading-normal mt-2 w-full pr-5 pl-5 pt-2.5 pb-2.5 lg:pt-3 lg:pb-3 h-full z-[15] text-[12px] lg:text-[14px] lg:-translate-x-0 disabled:cursor-not-allowed disable-action-btn-animation disabled:opacity-60"
                  {% if insurance_enabled and insurance_default and shipping_insurance %}
                    @init-run.window="loadInsurance('{{ shipping_insurance }}')"
                  {% endif %}
                  {% if insurance_enabled and product_insurance != blank and product_insurance.id == card_product_id %}
                    style="display: none;"
                  {% endif %}
                  :class="errorMessage && 'opacity-60 cursor-not-allowed'"
                  {%- if variant_available == false -%}
                    disabled
                    aria-label="{{ sold_out_text }}"
                  {%- elsif only_default_variant or swatch_enabled -%}
                    aria-label="{{ atc_text }}"
                  {%- else -%}
                    aria-label="{{ choose_option_text }}"
                  {%- endif -%}
                  {% unless settings.default_select_available_variant or only_default_variant %}
                    disabled
                  {% endunless %}
                >
                  <span :class="{ 'lg:block opacity-0 is-focus-button' : loading, 'hidden' : errorMessage}">
                    {% if settings.default_select_available_variant or only_default_variant %}
                      {%- if variant_available -%}
                        {% liquid
                          assign button_label = choose_option_text
                          if only_default_variant or swatch_enabled
                            assign button_label = atc_text
                            if can_show_preorder
                              assign button_label = 'products.product.pre_order' | t
                              if settings.card_button_preorder != blank
                                assign button_label = settings.card_button_preorder
                              endif
                            endif
                          endif
                        %}
                        <span class="flex items-center justify-center">
                          {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                        </span>
                      {%- else -%}
                        {% assign button_label = sold_out_text %}
                        <span class="flex items-center justify-center">
                          {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                        </span>
                      {%- endif -%}
                    {% else %}
                      {% liquid
                        assign button_label = atc_text
                      %}
                      <span class="flex items-center justify-center">
                        {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                      </span>
                    {% endif %}
                  </span>
                  <div
                    class="flex gap-x-2 items-center justify-center"
                    role="alert"
                    x-cloak
                    x-show="errorMessage"
                  >
                    {{ sold_out_text }}
                  </div>
                  <div class="lg:inline-block w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="loading" x-cloak>
                    {{ icon_loading }}
                  </div>
                </button>
              {%- endform -%}
            {% else %}
              <button
                type="submit"
                name="add"
                @click.prevent="setTimeout(() => { $store.xQuickView && (showOptions = !showOptions); $store.xQuickView.showChooseOption('{{ section_id }}-{{ card_product_id }}-{{ block_id }}', $el); }, 0)"
                x-on:mouseover="setTimeout(() => { $store.xQuickView && $store.xQuickView.loadChooseOptions('{{ card_product_url }}', $el, '{{ section_id }}-{{ card_product_id }}-{{ block_id }}', {{ index_param }}); }, 0)" 
                data-id="{{ section_id }}-{{ card_product_id }}-{{ block_id }}"
                class="button button--quickview button-solid not-icon leading-normal mt-2 w-full pr-5 pl-5 pt-2.5 pb-2.5 lg:pt-3 lg:pb-3 h-full text-[12px] lg:text-[14px] lg:-translate-x-0 disabled:cursor-not-allowed disable-action-btn-animation disabled:opacity-60"
                :class="errorMessage && 'opacity-60 cursor-not-allowed'"
                {%- if variant_available == false -%}
                  disabled
                  aria-label="{{ sold_out_text }}"
                {% else %}
                  aria-label="{{ choose_option_text }}"
                {% endif %}
              >
                <span :class="{ 'lg:block opacity-0 is-focus-button' : loading, 'hidden' : errorMessage}">
                  {% if variant_available == false %}
                    {% assign button_label = sold_out_text %}
                  {% else %}
                    {% assign button_label = choose_option_text %}
                  {% endif %}
                  <span class="flex items-center justify-center">
                    {% render 'button-label', button_label: button_label, show_button_style: 'primary' %}
                  </span>
                </span>
                <div class="lg:inline-block w-4 h-4 md:w-5 md:h-5 absolute top-[calc(50%-8px)] left-[calc(50%-8px)] md:top-[calc(50%-10px)] md:left-[calc(50%-10px)]" x-show="loading" x-cloak>
                  {{ icon_loading }}
                </div>
              </button>
            {% endif %} 
          </div>
        {%- endunless -%} 
      </template>
    {% endunless %}
  </div>

<style>
.cfb-card-attrs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: #1a1a1a;
  color: #fff;
  padding: 10px 6px;
  margin-top: 12px;
  border-radius: 4px;
  font-family: inherit;
}
.cfb-card-attr {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 4px;
  border-right: 1px solid rgba(255,255,255,0.18);
}
.cfb-card-attr:last-child { border-right: none; }
.cfb-card-attr__value {
  font-size: 0.78rem;
  font-weight: 700;
  line-height: 1.2;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}
.cfb-card-attr__label {
  font-size: 0.62rem;
  font-weight: 400;
  margin-top: 2px;
  color: rgba(255,255,255,0.65);
  letter-spacing: 0.03em;
}
@media (max-width: 480px) {
  .cfb-card-attrs { padding: 8px 4px; }
  .cfb-card-attr__value { font-size: 0.72rem; }
  .cfb-card-attr__label { font-size: 0.58rem; }
}
</style>
</div>