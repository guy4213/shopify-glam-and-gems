{% comment %}
    Renders a product card

    Accepts:
    - card_product: {Object} Product Liquid object (optional)
    - media_aspect_ratio: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
    - show_vendor: {Boolean} Show the product vendor. Default: false
    - show_rating: {Boolean} Show the product rating. Default: false
    - loading: {Boolean} Image should be lazy loaded. Default: lazy (optional)
    - section_id: {String} The ID of the section that contains this card.
    - disable_badges: {Boolean} Don't show labels and badges
    - list_name: {String} The title of collection,
    - collection: {Object} Collection Liquid object (optional),
    - class_slide: {String} The class of slider,
    - index: {Number} The index of the product card in the collection,
    - disable_quickview: {Boolean} Show quick view button. Default: true (optional)
    - block_id: {String} The ID of the block that contains this card.
    - product_featured_image_mtf: {String} The handle of the metafield that contains a featured image for the product
    Usage:
    {% render 'card-product', show_vendor: section.settings.show_vendor %}
{% endcomment %}
{%- liquid
  assign first_variant = card_product.selected_or_first_available_variant
  assign card_product_id = card_product.id
  assign is_rtl = false
  if settings.lang_direction contains request.locale.iso_code
    assign is_rtl = true
  endif
  if column_mobile == blank
    assign column_mobile = 1
  endif
  if media_aspect_ratio == blank
    assign media_aspect_ratio = settings.product_image_ratio
  endif
  assign ratio = 100
  case media_aspect_ratio
    when "portrait"
      assign ratio = 150
    when "landscape"
      assign ratio = 75
    when "wide"
      assign ratio = 56.25
    when "3/4"
      assign ratio = 133
  endcase
  assign content_alignment = settings.info_alignment_card_product
  if info_alignment
    assign content_alignment = info_alignment
  endif
  if is_rtl
    if content_alignment == 'left'
      assign content_alignment = 'right'
    elsif content_alignment == 'right'
      assign content_alignment = 'left'
    endif
  endif
  assign show_rounded_image = false
  if settings.edges_type == 'rounded_corners'
    assign show_rounded_image = true
  endif

  assign can_show_preorder = false
  if settings.preorder_show == 'yes' or settings.preorder_show == 'on_backordered' and first_variant.inventory_policy == 'continue' and first_variant.inventory_quantity < 1 and first_variant.inventory_management != nil
    if settings.applied_products_preorder == blank and settings.applied_collections_preorder == blank
      assign can_show_preorder = true
    else 
      assign list_product = settings.applied_products_preorder | map: 'id'
      if list_product contains card_product_id 
        assign can_show_preorder = true
      endif

      unless can_show_preorder
        assign list_collection = settings.applied_collections_preorder | map: 'id'
        for collection in card_product.collections
          if list_collection contains collection.id
            assign can_show_preorder = true
            break
          endif
        endfor
      endunless
    endif
  endif 

  if can_show_preorder
    assign message_preorder = 'general.preorder.message_preorder' | t
    if settings.message_preorder != blank
      assign message_preorder = settings.message_preorder
    endif 
  endif

  assign disable_cart_edt = false
  if card_product.gift_card? or can_show_preorder and settings.hide_when_pre_order
    assign disable_cart_edt = true
  endif

  assign count_media = card_product.media | size
  if settings.number_of_additional_images < count_media
    assign count_media = settings.number_of_additional_images
  endif
  assign insurance_enabled = settings.enable_shipping_insurance
  assign insurance_default = settings.shipping_insurance_added_by_default
  assign product_insurance = settings.product_shipping_insurance

  assign shipping_insurance = false
  if insurance_enabled and product_insurance != blank and product_insurance.selected_or_first_available_variant.available
    assign shipping_insurance = product_insurance.selected_or_first_available_variant.id
    assign cart_item_ids = cart.items | map: 'variant_id'
    if cart_item_ids contains shipping_insurance
      assign shipping_insurance = false
    endif
  endif

  assign variant_available = first_variant.available
  assign only_default_variant = card_product.has_only_default_variant
  assign swatch_enabled = settings.products_color_swatches_enable_on_collection_page

  assign atc_text = 'products.product.add_to_cart' | t
  assign sold_out_text = 'products.product.sold_out' | t
  assign choose_option_text = 'products.product.choose_options' | t

  assign card_product_url = card_product.url | within: collection | split: "?" | first
-%}
{%- capture data_for_customer_event -%}
  {
    "product": {
      "title": "{{ card_product.title | escape }}",
      "listName": "{{ collection.title | default: list_name | escape }}",
      "sku": "{{ card_product_id }}",
      "currencyCode": "{{ cart.currency.iso_code }}",
      "price": {{ card_product.price }},
      "vendor": "{{ card_product.vendor | escape }}"
    }
  }
{%- endcapture %}
{%- unless disable_badges -%}
  {%- capture data_for_label -%}
    [
    {% assign variant = first_variant %}
    {%- liquid
      assign list_metafield_label = ''
      if settings.metafield_label != blank
        assign metafield_labels = settings.metafield_label | newline_to_br | strip_newlines | split: '<br />'
        for metafield_label in metafield_labels
          assign mtf_key = metafield_label | remove: ' ' | split: '.'
          assign mtf_value = variant.metafields[mtf_key.first][mtf_key.last]
          if mtf_value == blank or mtf_value.type != 'single_line_text_field' and mtf_value.type != 'list.single_line_text_field'
            assign mtf_value = card_product.metafields[mtf_key.first][mtf_key.last]
            if mtf_value != blank and mtf_value.type != 'single_line_text_field' and mtf_value.type != 'list.single_line_text_field'
              assign mtf_value = ''
            endif
          endif
          if mtf_value.list?
            assign first_value = mtf_value.value | first
            assign list_metafield_label = list_metafield_label | append: '"' | append: metafield_label | append: '":"' | append: first_value | append: '",'
          else
            assign list_metafield_label = list_metafield_label | append: '"' | append: metafield_label | append: '":"' | append: mtf_value | append: '",'
          endif
        endfor
        assign list_metafield_label = list_metafield_label | remove_last: ','
      endif

      assign product_created_at = card_product.created_at | date: "%s"
      assign product_published_at = card_product.published_at | date: "%s"
    -%}
    {
      "variant_id": {{ variant.id | default: card_product_id }},
      "product_id": {{ card_product_id }},
      "available": {{ card_product.available }},
      "title": "{{ card_product.title | escape }}",
      "compare_at_price": {{ variant.compare_at_price | default: 0 }},
      "price": {{ variant.price }},
      "price_with_currency": "{% if settings.currency_code_enable %}{{ variant.price | money_with_currency | escape }}{% else %}{{ variant.price | money | escape }}{% endif %}",
      "sale_amount": "{{ variant.compare_at_price | minus: variant.price | money | escape | strip_html }}",
      "collections": "||{{ card_product.collections | map: 'id' | join: '||' }}||",
      "inventory_management": "{{ variant.inventory_management }}",
      "qty": {{ variant.inventory_quantity | default: -1 }},
      "container": "card",
      "can_show_preorder": {{ can_show_preorder }},
      "diff_day_create": {{ product_created_at }},
      "diff_day_publish": {{ product_published_at }}
      {% if settings.metafield_label != blank %}
        ,"metafield_label": { 
          {{ list_metafield_label }}
        }
      {% endif %}
      }
    ]
  {%- endcapture %}
{%- endunless -%}
{% unless disable_quickview %}
  {% capture icon_loading %}
    {% render 'icon-alls', icon: 'icon-loading' %}
  {% endcapture %}
{% endunless %}
<div 
  {% if settings.swatches_type == 'both_text_and_color' or settings.swatches_type == 'color' %}
    x-data="xProductCard('{{ section_id }}-{{ product_card_id }}', '{{ card_product_url }}', '{{ card_product_id }}')"  
  {% else %}
    x-data="{ showOptions: false, options: [] }"
  {% endif %}
  class="card-product {{ anm_class }} overflow-hidden card md:list-layout:flex relative pb-4 md:pb-5
    {%- if is_rtl %} rtl{% endif -%}
    {%- if image_ratio_setting == 'fit_grid_layout' %} flex flex-col md:flex md:flex-col{% else %}{% if mediaGallery %} flex flex-col md:block{% endif %}{% endif -%}
    {%- if class_slide %} {{ class_slide }}{% endif -%}
    {%- unless swiper_on_mobile %} h-full{% endunless -%}
    {%- if extend_height %} flex flex-col{% endif -%}
    {%- if show_rounded_image %} rounded-[10px]{% endif -%}" 
  x-slide-index="{{ index | minus: 1 }}"
>
  <div class="md:list-layout:w-2/5 md:list-layout:lg:w-1/4 relative disable-effect
    {%- if is_rtl %} md:list-layout:pl-8{% else %} md:list-layout:pr-8{% endif -%}
    {%- if extend_height %} flex flex-col{% endif -%}
    {%- if image_ratio_setting == 'fit_grid_layout' %} flex flex-col grow md:flex md:flex-col md:grow {% else %}{% if mediaGallery %} flex flex-col grow md:block{% endif %}{% endif %}"
  >
    {% if mediaGallery %}
      {% style %}
        {% assign title_size_card = settings.title_size_card | times: text_size %}
        {% assign prize_size_card = settings.price_size_card | times: text_size %}
        .full-unstyled-link.link-product-variant.card-product-title-text-{{ block_id }} {
          font-size: {{ title_size_card | times: 0.00009 }}rem;
        }
        .x-card-price.card-product-price-text-{{ block_id }} {
          font-size: {{ prize_size_card | times: 0.00009 }}rem;
        }
        .card-product-vendor-text-{{ block_id }} {
          font-size: {{ title_size_card | times: 0.009 | times: 0.007875 }}rem;
        }
        @media (min-width: 768px) {
          .full-unstyled-link.link-product-variant.card-product-title-text-{{ block_id }} {
            font-size: {{ title_size_card | times: 0.0001 }}rem;
          }
          .x-card-price.card-product-price-text-{{ block_id }} {
            font-size: {{ prize_size_card | times: 0.0001 }}rem;
          }
          .card-product-vendor-text-{{ block_id }} {
            font-size: {{ title_size_card | times: 0.009 | times: 0.00875 }}rem;
          }
        }
        {% if image_ratio_setting != 'fit_grid_layout' and media_aspect_ratio == "natural" and card_product.featured_media and card_product.featured_media.media_type != "model" %}
          .media-gallery-{{ block_id }} {
            height: 0;
            padding-bottom: {{ 100.0 | divided_by: card_product.featured_media.aspect_ratio }}%;
          }
        {% endif %}
      {% endstyle %}
    {% endif %}
    <a 
      {% unless loading == 'eager' %}
        x-intersect.once.margin.-20px.0px.-20px.0px="$el.querySelector('.animate_transition_card__image')?.classList.add('active', 'lazy_active')"
      {% endunless %}
      href="{{ card_product.url | within: collection }}"
      {% unless disable_badges %} 
        x-data="{ lastWindowWidth: 0 }"
        x-intersect.once.margin.200px='$nextTick(() => { $store.xBadges && $store.xBadges.load($el, () => {}, null, true); })'
        x-labels-data="{{ data_for_label | escape }}"
      {% endunless %} 
      aria-label="{{ card_product.title | escape }}"
      id="{{ card_product_id }}-{{ section.id }}"
      class="x-labels-data ltr group link-product-variant overflow-hidden block relative z-[15] cursor-pointer before:h-0 before:block
      {%- if collage %} grow pb-[{{ ratio }}%]{% else %} no-collage{% endif -%}
      {%- if show_rounded_image %} rounded-[10px]{% endif -%}
      {%- if image_ratio_setting == 'fit_grid_layout' %} md:h-full h-full pb-0{% else -%}
      {%- if mediaGallery %} h-full pb-0 md:h-auto media-gallery-{{ block_id }}{% endif -%}
      {%- if media_aspect_ratio == "natural" %}{% if card_product.featured_media.media_type == "model" or card_product.featured_media == blank %} md:pb-[100%]{% endif %}{% else %} pb-[{{ ratio }}%]{% endif -%}
      {%- endif -%}
      {%- if settings.product_image_type == "slide_img" and count_media > 1 and settings.show_arrow == false %} disable-label-hover{% endif -%}"
      {%- unless mediaGallery %}{% if media_aspect_ratio == "natural" and card_product.featured_media and card_product.featured_media.media_type != "model" %} style="height: 0; padding-bottom: {{ 100.0 | divided_by: card_product.featured_media.aspect_ratio }}%;"{% endif %}{% endunless -%}>
      <div
        id="x-slideshow-card-product-{{ section_id }}-{{ product_card_id }}-{{ index | minus: 1 }}{% if product_id and is_cart_upsell %}-{{ product_id }}{% endif %}"
        class="block w-full h-full absolute top-0 left-0 z-0 overflow-hidden x-splide splide visible{% if settings.product_image_type == "slide_img" and count_media > 1 %} visible{% unless media_aspect_ratio == "natural" %} card-product-img{% endunless %} disable-effect-hover cursor-grab group{% endif %}{% if animation_loading and loading != 'eager' %} animate_transition_card__image{% endif %}" 
        @click='$store.xCustomerEvent.fire("product_selected", $el)'
        x-customer-event-data="{{ data_for_customer_event | escape }}"
        x-cloak
        {% if count_media > 1 %}
          x-intersect.once.margin.200px='$store.xSplide.load($el, {
            "drag": true,
            "pagination": true,
            "arrows": false,
            "pauseOnFocus": false,
            "pauseOnHover": false,
            "perMove": 1,
            "perPage": 1,
            "focus": "center",
            "mediaQuery": "min",
            "rewind": true,
            {% if swiper_on_mobile or settings.product_image_type == "none" or is_cart_upsell %}
              "destroy": true,
            {% endif %}
            "breakpoints": {
              1024: {
                {% if settings.product_image_type != "hover_to_reveal_second_image" and count_media > 1 and class_slide != 'recommendations' %}
                  "destroy": false,
                  "drag": false,
                  {% unless settings.show_arrow -%}
                    "arrows": false,
                    "rewind": false,
                    "classes": {
                      "pagination": "splide__pagination pagination-card hidden grid-cols-{{ count_media }} pointer-events-none absolute gap-1 top-5 pl-5 pr-5 w-full z-0",
                      "page": "button none_border btn-pagination flex items-center w-full h-1"
                    }
                  {% else %}
                    {% if settings.change_slides_speed > 0 %}
                      "rewind": true,
                      "autoplay": true,
                      "speed": {% if settings.product_card_effect_reveal_image == 'fade' %}{{ settings.change_slides_speed | times: 1000 }}{% else %}1000{% endif %},
                      "interval": {{ settings.change_slides_speed | times: 1000 }},
                      "updateOnMove": true,
                    {% else %}
                      "rewind": false,
                    {% endif %}
                    "pagination": false,
                    "arrows": true
                  {%- endunless %}
                {% else %}
                  "destroy": true
                {% endif %}
              }
            },
            {% if count_media > 1 and class_slide != 'recommendations' and settings.change_slides_speed > 0 %}
              "playOnHover": true,
            {% endif %}
            {% unless settings.show_arrow -%}
              "cardHover": "image-product-{{ section_id }}-{{ product_card_id }}-{{ index | minus: 1 }}{% if product_id and is_cart_upsell %}-{{ product_id }}{% endif %}",
              "maxSlide": "{{ count_media }}",
            {% endunless %}
            "classes": {
              "pagination": "gap-1 flex-nowrap absolute bottom-2 left-2.5 rtl:right-2.5 rtl:left-auto flex",
              "page": "paginate-dots-card-product duration-200 rounded-full w-2 flex items-center h-2"
            },
            "type": "{% if settings.product_card_effect_reveal_image == 'slide' and settings.show_arrow %}slide{% else %}fade{% endif %}",
          })'
        {%- endif -%}
      >
        <div 
          id="image-product-{{ section_id }}-{{ product_card_id }}-{{ index | minus: 1 }}{% if product_id and is_cart_upsell %}-{{ product_id }}{% endif %}"
          class="splide__track overflow-hidden max-h-full h-full w-full"
        >
        <div class="w-full h-full splide__list">
          {%- if card_product.featured_media -%}
            {%- capture sizes -%}
              {%- if collage or mediaGallery -%}
                {%- if full_width -%}
                  (min-width: 768px) {{ columns_desktop | times: 100 | divided_by: max_columns }}vw, {{ columns_mobile | times: 100 | divided_by: min_columns_mobile }}vw
                {%- else -%}
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | times: columns_desktop | divided_by: max_columns }}px, {{ columns_mobile | times: 100 | divided_by: min_columns_mobile }}vw
                {%- endif -%}
              {%- else -%}
                (min-width: {{ settings.page_width }}px) {% if enable_desktop_slider %}{{ settings.page_width | plus: 100 | divided_by: columns_desktop }}px{% else %}calc(100vw / {{ columns_desktop }}){% endif %}, (min-width: 1024px) calc((100vw) / {{ columns_desktop }}), (min-width: 768px) calc((100vw) / 2), calc((100vw /{{ column_mobile }}) {% if spacing_mobile and column_mobile == 2  %}- {{ spacing_mobile | divided_by: column_mobile }}px{% endif %})
              {%- endif -%}
            {%- endcapture -%}
            {% liquid
              if card_product.featured_media
                assign product_featured_image = card_product.featured_media
                if product_featured_image_mtf != blank and card_product.metafields.custom[product_featured_image_mtf]
                  assign product_featured_image = card_product.metafields.custom[product_featured_image_mtf]
                endif
              endif
            %}
            <div class="w-full z-0
              {%- if image_ratio_setting == 'fit_grid_layout' %} 
                md:h-full md:min-h-full h-full min-h-full
              {%- else -%}
                {%- if media_aspect_ratio != "natural" %} h-full min-h-full{% endif -%}
              {%- endif -%} 
              {%- if settings.product_image_type != "slide_img" or count_media <= 1 or class_slide == 'recommendations' %}overflow-hidden splide__slide x-splide-slide max-h-full lg:top-0 lg:left-0 lg:absolute{% else %} overflow-hidden splide__slide x-splide-slide max-h-full{% endif -%}"
            >
              {% # theme-check-disable ImgLazyLoading %}
              <picture>
                <img
                  srcset="
                  {{ product_featured_image | image_url: width: 250 }} 250w,
                  {{ product_featured_image | image_url: width: 350 }} 350w,
                  {{ product_featured_image | image_url: width: 450 }} 450w,
                  {{ product_featured_image | image_url: width: 750 }} 750w,
                  {{ product_featured_image | image_url: width: 900 }} 900w,
                  {{ product_featured_image | image_url: width: 1100 }} 1100w,
                  {{ product_featured_image | image_url: width: 1500 }} 1500w
                  {%- if product_featured_image.width %},{{ product_featured_image | image_url }} {{ product_featured_image.width }}w{% endif %}" 
                  src="{{ product_featured_image | image_url: width: 1500 }}"
                  sizes="{{ sizes }}"
                  alt="{{ product_featured_image.alt | split: "#" | first | escape }}"
                  class="w-full {% unless product_featured_image_mtf != blank and card_product.metafields.custom[product_featured_image_mtf] %} preview-img{% endunless %} motion-reduce aspect-{{ media_aspect_ratio }} relative animate-Xpulse skeleton-image object-cover
                    {%- if image_ratio_setting == 'fit_grid_layout' %} md:h-full md:min-h-full h-full min-h-full
                      {%- else -%} 
                      {%- if media_aspect_ratio != "natural" %} h-full min-h-full{% endif -%}
                    {%- endif -%}
                    {%- if card_product.media[1] != nil and settings.product_image_type == 'hover_to_reveal_second_image' and settings.product_card_effect_reveal_image != 'slide' %} image-first-hover lg:group-hover:opacity-0
                      {%- elsif card_product.media[1] != nil and settings.product_image_type == 'hover_to_reveal_second_image' and settings.product_card_effect_reveal_image == 'slide' %} image-first-slide-anm lg:group-hover:opacity-0 transition-opacity duration-500
                      {%- elsif settings.product_image_type != 'slide_img' %} image-hover
                    {%- endif -%}
                    {%- if animation_loading and loading != 'eager' %} animate_transition_image{% endif -%}
                  "
                  loading="{{ loading | default: 'lazy' }}"
                  width="{% if product_featured_image_mtf != blank and card_product.metafields.custom[product_featured_image_mtf] %}{{ product_featured_image.width }}{% else %}{{ product_featured_image.preview_image.width }}{% endif %}"
                  height="{% if product_featured_image_mtf != blank and card_product.metafields.custom[product_featured_image_mtf] %}{{ product_featured_image.height }}{% else %}{{ product_featured_image.preview_image.height }}{% endif %}"
                  onload="requestAnimationFrame(() => {
                    {% if animation_loading and loading != 'eager' %}this?.classList.add('active');{% endif -%}
                    this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image');
                    setTimeout(() => { this.closest('.animate_transition_card__image')?.classList.add('lazy_active', 'active'); }, 250);
                  })"
                />
              </picture>
              {% # theme-check-enable ImgLazyLoading %}
            </div>
            {%- if card_product.media[1] != nil -%}
              {%- if settings.product_image_type == "hover_to_reveal_second_image" -%}
                {% style %}
                  #image-product-{{ section_id }}-{{ product_card_id }}-{{ index | minus: 1 }}{% if product_id and is_cart_upsell %}-{{ product_id }}{% endif %} .media-slide:not(:first-child) {
                    height: 100%;
                  }
                {% endstyle %}
                <div class="media-slide splide__slide x-splide-slide z-0 transition ease-out duration-300 w-full h-full lg:block">
                  {% # theme-check-disable ImgLazyLoading %}
                  <picture>
                    <img
                      srcset="{{ card_product.media[1] | image_url: width: 250 }} 250w,
                        {{ card_product.media[1] | image_url: width: 350 }} 350w,
                        {{ card_product.media[1] | image_url: width: 450 }} 450w,
                        {{ card_product.media[1] | image_url: width: 750 }} 750w,
                        {{ card_product.media[1] | image_url: width: 900 }} 900w,
                        {{ card_product.media[1] | image_url: width: 1100 }} 1100w,
                        {{ card_product.media[1] | image_url: width: 1500 }} 1500w
                        {%- if card_product.media[1].width %},{{ card_product.media[1] | image_url }} {{ card_product.media[1].width }}w{% endif %}"
                      src="{{ card_product.media[1] | image_url: width: 1500 }}"
                      sizes="{{ sizes }}"
                      alt="{{ card_product.media[1].alt | split: "#" | first | escape }}"
                      class="motion-reduce min-w-full h-full object-cover group-hover:cursor-pointer content-visibility-auto
                        {%- if media_aspect_ratio == "natural" %} aspect-auto{% endif -%}
                        {%- if settings.product_image_type == 'slide_img' -%} animate-Xpulse skeleton-image{% endif -%}
                        {%- if settings.product_card_effect_reveal_image == 'fade' %} image-second-hover lg:opacity-0 lg:group-hover:opacity-100{% endif -%}
                        {%- if settings.product_card_effect_reveal_image == 'slide' %} image-first-hover-slide-anm absolute top-0 lg:-right-[101%]{% endif -%}
                      "
                      {% if settings.enable_lazy_loading_image %}loading="lazy"{% else %}loading="eager"{% endif %}
                      width="{{ card_product.media[1].width }}"
                      height="{{ card_product.media[1].height }}"
                      onload="requestAnimationFrame(() => {
                        this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image');
                        setTimeout(() => { this.closest('.animate_transition_card__image')?.classList.add('lazy_active', 'active'); }, 250);
                      })"
                    />
                  </picture>
                  {% # theme-check-enable ImgLazyLoading %}
                </div>
              {%- elsif settings.product_image_type == "slide_img" and class_slide != 'recommendations' -%}
                {% for media in card_product.media %}
                  {%- if forloop.index > 1 -%}
                    <div 
                      index="{{ forloop.index0 }}" 
                      media="{{ media | image_url }}"
                      class="media-slide w-full splide__slide x-splide-slide z-0 transition ease-out duration-300
                        {%- if media_aspect_ratio != "natural" %} h-full min-h-full{% endif -%}
                        {%- if animation_loading and settings.show_arrow == false %} opacity-0{% endif -%}
                      "
                    >
                      {% # theme-check-disable ImgLazyLoading %}
                      <picture>
                        <img
                          srcset="{{ media | image_url: width: 250 }} 250w,
                            {{ media | image_url: width: 350 }} 350w,
                            {{ media | image_url: width: 450 }} 450w,
