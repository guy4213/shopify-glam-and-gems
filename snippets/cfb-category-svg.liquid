{%- comment -%}
  Inline SVG icon for collection-filter-board "category" tile.
  Usage: {% render 'cfb-category-svg', name: 'engagement rings' %}
  `name` should be the lowercased category label.
{%- endcomment -%}
{%- case name -%}
  {%- when 'engagement rings' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="11" r="3"/><ellipse cx="16" cy="22" rx="9" ry="3"/></svg>
  {%- when 'wedding rings' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="16" rx="7" ry="3"/><ellipse cx="20" cy="17" rx="7" ry="3"/></svg>
  {%- when 'necklaces' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 8c2 7 6 11 11 11s9-4 11-11"/><path d="M14 19l2 6 2-6z"/></svg>
  {%- when 'earrings' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="9" r="2"/><path d="M11 11v3"/><circle cx="11" cy="20" r="5"/><circle cx="22" cy="14" r="2.5"/></svg>
  {%- when 'bracelets' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="16" cy="16" rx="11" ry="6"/></svg>
  {%- when 'fashion rings' -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="11" r="2"/><circle cx="11" cy="13" r="1.5"/><circle cx="21" cy="13" r="1.5"/><ellipse cx="16" cy="22" rx="9" ry="3"/></svg>
  {%- else -%}<svg class="cfb-tile-svg" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="16" cy="16" r="9"/></svg>
{%- endcase -%}
