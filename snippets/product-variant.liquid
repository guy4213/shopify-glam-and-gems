{% liquid
  if picker_type == 'adapt'
    assign picker_type = settings.quick_add_picker_type
    assign max_swatch = settings.max_swatch
  endif

  assign show_size_chart = false
  if block.settings.enable_size_chart
    if block.settings.select_page != blank or block.settings.select_image != blank
      assign show_size_chart = true
    endif
  endif

  assign gg_center_carat_label = ''
  assign gg_center_weight = product.metafields.custom.center_stone_weight.value
  if gg_center_weight != blank
    assign gg_center_int = gg_center_weight | round: 0
    assign gg_center_carat_label = gg_center_int | append: ' Carat'
  endif

  assign gg_center_variant_id = ''
  if gg_center_carat_label != blank
    for v in product.variants
      if gg_center_variant_id != ''
        break
      endif
      for ov in v.options
        if ov == gg_center_carat_label
          assign gg_center_variant_id = v.id
          break
        endif
      endfor
    endfor
  endif
%}

{%- if is_product_page and gg_center_variant_id != '' and product.selected_variant == blank -%}
  <script>
    (function () {
      if (window.location.search.indexOf('variant=') !== -1) return;
      var url = new URL(window.location.href);
      url.searchParams.set('variant', '{{ gg_center_variant_id }}');
      window.location.replace(url.toString());
    })();
  </script>
{%- endif -%}

<style>
  /* Capsule option selectors */
  .gg-capsule { display:flex; align-items:center; border:1px solid #d1d5db; border-radius:999px; overflow:hidden; background:#fff; }
  .gg-capsule-label { padding:0 18px 0 18px !important; font-size:12px; font-weight:600; white-space:nowrap; flex-shrink:0; letter-spacing:0.06em; text-transform:uppercase; }
  .gg-capsule-right { flex:1; position:relative; border-left:1px solid #d1d5db; }
  .gg-capsule-select { width:100%; padding:13px 36px 13px 16px !important; appearance:none; -webkit-appearance:none; background:transparent !important; border:none !important; box-shadow:none !important; font-size:13px; cursor:pointer; outline:none !important; }
  .gg-capsule-caret { position:absolute; top:50%; right:14px; transform:translateY(-50%); pointer-events:none; width:10px; }
  .gg-shown-with { font-size:11px; color:#9ca3af; font-style:italic; margin-top:5px; padding-left:4px; }
  /* Free Gift row */
  .gg-free-gift-row { display:flex; align-items:center; gap:14px; padding:12px 0; border-top:1px solid #EAEAEA; border-bottom:1px solid #EAEAEA; margin-bottom:14px; }
  .gg-free-gift-icon { width:22px; height:22px; flex-shrink:0; opacity:0.45; }
  .gg-free-gift-title { font-size:12px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; }
  .gg-free-gift-desc { font-size:11px; color:#6b7280; margin-top:1px; }
  /* Add to Cart button — force solid black */
  .main-product .add_to_cart_button.button-solid,
  .main-product .add_to_cart_button.button-solid:not(:disabled) {
    background-color: #111111 !important;
    color: #ffffff !important;
    border-color: #111111 !important;
    box-shadow: none !important;
  }
  .main-product .add_to_cart_button.button-solid:hover {
    background-color: #333333 !important;
    color: #ffffff !important;
  }
  .main-product .add_to_cart_button.button-solid .button-text,
  .main-product .add_to_cart_button.button-solid .x-atc-text {
    color: #ffffff !important;
  }
  /* Product badges — single compact row, no wrap */
  .x-block-badges .x-badges-product-detail {
    flex-wrap: nowrap !important;
    overflow-x: auto !important;
    scrollbar-width: none !important;
    min-height: auto !important;
    gap: 5px !important;
    padding-bottom: 2px;
  }
  .x-block-badges .x-badges-product-detail::-webkit-scrollbar { display: none; }
  /* Collapsible tab accordion borders — lighter */
  .main-product [class*="x-block-collapsible-tab"] {
    border-color: #EAEAEA !important;
  }
  .main-product [class*="x-block-collapsible-tab"] button {
    border-color: #EAEAEA !important;
  }
  /* Description accordion */
  .main-product [class*="x-block-description"] {
    border-color: #EAEAEA !important;
  }
</style>

<div
  id="variant-update-{{ section.id }}"
  class="variant-update-{{ section.id }} {% if picker_type == 'button' %}block{% else %}grid grid-cols-2 md:gap-x-5 gap-x-2.5 mt-2 mb-2{% endif %}"
  x-init="initFirstAvailableVariant($el)"
>
  <script type="application/json" data-selected-variant>{{ product.selected_or_first_available_variant | json }}</script>

  {%- comment -%} Non-size options (Metal Type, etc.) — standalone capsule dropdowns {%- endcomment -%}
  {%- for option in product.options_with_values -%}
    {%- assign option_index = forloop.index0 -%}
    {%- if option.name != 'Ring Size' and option.name != 'Carat Size' -%}
      <div
        data-option-name="{{ option.name | handle }}"
        data-option-index="{{ forloop.index0 }}"
        class="col-span-2 w-full mb-4"
        x-data="{ selectedVal: '{{ option.selected_value | escape }}' }"
      >
        <div class="gg-capsule">
          <span class="gg-capsule-label">{{ option.name }}</span>
          <div class="gg-capsule-right">
            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              class="gg-capsule-select product-form__input"
              name="{{ option.name }}"
              form="{{ product_form_id }}"
              @change="selectedVal = $event.target.value"
            >
              {% render 'product-variant-options',
                product: product,
                option: option,
                option_index: option_index,
                product_form_id: product_form_id,
                input_type: 'select',
                enable_color_swatches: block.settings.enable_color_swatches,
                swatch_size: swatch_size
              %}
            </select>
            <div x-cloak x-show="loadingEls === 'Option-{{ section.id }}-{{ forloop.index0 }}'" class="gg-capsule-caret">
              <div class="animate-spin w-4 h-4 border-loading border-[rgba(var(--colors-text))]"></div>
            </div>
            <span x-cloak x-show="loadingEls !== 'Option-{{ section.id }}-{{ forloop.index0 }}'" class="gg-capsule-caret">
              {% render 'icon-alls', icon: 'icon-caret' %}
            </span>
          </div>
        </div>
        <p class="gg-shown-with" x-text="'The product is shown with ' + selectedVal"></p>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} Carat Size — standalone capsule dropdown, only shown if isDiamond = yes {%- endcomment -%}
  {%- assign gg_is_diamond = product.metafields.custom.isDiamond.value -%}
  {%- if gg_is_diamond == 'yes' -%}
    {%- for option in product.options_with_values -%}
      {%- if option.name == 'Carat Size' -%}
        <div
          data-option-name="{{ option.name | handle }}"
          data-option-index="{{ forloop.index0 }}"
          class="col-span-2 w-full mb-4"
          x-data="{ selectedVal: '{{ option.selected_value | escape }}' }"
        >
          <div class="gg-capsule">
            <span class="gg-capsule-label">{{ option.name }}</span>
            <div class="gg-capsule-right">
              <select
                id="Option-{{ section.id }}-{{ forloop.index0 }}"
                class="gg-capsule-select product-form__input"
                name="{{ option.name }}"
                form="{{ product_form_id }}"
                @change="selectedVal = $event.target.value"
              >
                {% render 'product-variant-options',
                  product: product,
                  option: option,
                  option_index: forloop.index0,
                  product_form_id: product_form_id,
                  input_type: 'select',
                  enable_color_swatches: block.settings.enable_color_swatches,
                  swatch_size: swatch_size
                %}
              </select>
              <div x-cloak x-show="loadingEls === 'Option-{{ section.id }}-{{ forloop.index0 }}'" class="gg-capsule-caret">
                <div class="animate-spin w-4 h-4 border-loading border-[rgba(var(--colors-text))]"></div>
              </div>
              <span x-cloak x-show="loadingEls !== 'Option-{{ section.id }}-{{ forloop.index0 }}'" class="gg-capsule-caret">
                {% render 'icon-alls', icon: 'icon-caret' %}
              </span>
            </div>
          </div>
          <p class="gg-shown-with" x-text="'The product is shown with ' + selectedVal"></p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} Free Gift row {%- endcomment -%}
  <div class="gg-free-gift-row col-span-2">
    <svg class="gg-free-gift-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 12v10H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
    </svg>
    <div>
      <p class="gg-free-gift-title">Free Gift</p>
      <p class="gg-free-gift-desc">Orders over $3,000 receive 1.5 Carat Moissanite Hoop Earrings</p>
    </div>
  </div>

  {%- comment -%} Ring Size — standalone capsule dropdown {%- endcomment -%}
  {%- for option in product.options_with_values -%}
    {%- assign option_index = forloop.index0 -%}
    {%- if option.name == 'Ring Size' -%}
      <div
        data-option-name="{{ option.name | handle }}"
        data-option-index="{{ forloop.index0 }}"
        class="mb-4"
        x-data="{ selectedVal: '{{ option.selected_value | escape }}' }"
      >
        <div class="gg-capsule">
          <span class="gg-capsule-label">{{ option.name }}</span>
          <div class="gg-capsule-right">
            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              class="gg-capsule-select product-form__input"
              name="{{ option.name }}"
              form="{{ product_form_id }}"
              @change="selectedVal = $event.target.value"
            >
              {% render 'product-variant-options',
                product: product,
                option: option,
                option_index: option_index,
                product_form_id: product_form_id,
                input_type: 'select',
                enable_color_swatches: block.settings.enable_color_swatches,
                swatch_size: swatch_size
              %}
            </select>
            <div x-cloak x-show="loadingEls === 'Option-{{ section.id }}-{{ forloop.index0 }}'" class="gg-capsule-caret">
              <div class="animate-spin w-4 h-4 border-loading border-[rgba(var(--colors-text))]"></div>
            </div>
            <span x-cloak x-show="loadingEls !== 'Option-{{ section.id }}-{{ forloop.index0 }}'" class="gg-capsule-caret">
              {% render 'icon-alls', icon: 'icon-caret' %}
            </span>
          </div>
        </div>
        <p class="gg-shown-with" x-text="'The product is shown with size ' + selectedVal"></p>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {% if show_size_chart %}
    <template x-teleport="body">
      <div id="VariantPickerSizeChart" x-show="$store.xVariantPickerSizeChart.openSizeChart" x-cloak class="w-full h-full fixed top-0 left-0 z-[60] bg-[#acacac] bg-opacity-30">
        <div x-show="$store.xVariantPickerSizeChart.openSizeChart" @click.away="$store.xVariantPickerSizeChart.openSizeChart = false; $store.xPopup.close()" class="bg-[rgba(var(--background-color))] duration-400 flex flex-col gap-4 pt-4 pb-4 pl-4 rtl:pl-0 rtl:pr-4{% if block.settings.size_chart_type == 'popup' %} max-w-3xl relative md:ml-auto md:mr-auto mt-[25dvh] md:mt-[20dvh] min-h-[calc(75dvh-80px)] md:min-h-[400px] md:max-h-[60dvh] h-[75dvh] md:h-fit{% if settings.edges_type == 'rounded_corners' %} rounded-t-[10px] md:rounded-[10px]{% endif %}{% else %} w-full md:w-96 fixed {% if settings.lang_direction contains request.locale.iso_code %}left-0{% else %}right-0{% endif %} mt-[25dvh] h-[75dvh] md:h-full{% if settings.edges_type == 'rounded_corners' %} rounded-t-[10px] md:rounded-[10px] md:mt-2.5 md:mb-2.5 md:mr-2.5 md:ml-2.5 md:max-h-[calc(100vh-20px)]{% else %} md:mt-0{% endif %}{% endif %}"
          x-transition:enter="transition-all ease-in-out duration-500"
          x-transition:leave="transition-all ease-in-out duration-500"
          {% if block.settings.size_chart_type == 'popup' %}
            x-transition:enter-start="opacity-0 transform translate-y-1/3"
            x-transition:enter-end="opacity-100 transform translate-y-0"
            x-transition:leave-end="opacity-0 transform translate-y-1/3"
          {% else %}
            x-transition:enter-start="opacity-0 transform translate-y-1/3 md:translate-y-0 {% if settings.lang_direction contains request.locale.iso_code %}md:-translate-x-1/3{% else %}md:translate-x-1/3{% endif %}"
            x-transition:enter-end="opacity-100 transform translate-y-0 md:translate-x-0"
            x-transition:leave-end="opacity-0 transform translate-y-1/3 md:translate-y-0 {% if settings.lang_direction contains request.locale.iso_code %}md:-translate-x-1/3{% else %}md:translate-x-1/3{% endif %}"
          {% endif %}
          x-intersect.full="$store.xVariantPickerSizeChart.sizeChartFocus();"
          @keyup.escape="$store.xVariantPickerSizeChart.sizeChartRemoveFocus();">
          <div class="flex justify-end items-center gap-4 pr-4 rtl:pl-4 rtl:pr-0">
            {%- if block.settings.select_page.title != blank and block.settings.select_image == blank -%}
              <h3 class="p-break-words flex-1 line-clamp-2 heading-text-base-h3">{{ block.settings.select_page.title | escape }}</h3>
            {%- endif -%}
            <button id="CloseVariantPickerSizeChart" @click="$store.xVariantPickerSizeChart.sizeChartRemoveFocus();" class="cursor-pointer icon-close-container w-fit rounded-full group-close-btn">
              {%- render 'icon-alls', icon: 'icon-close', animation_class: 'icon-close-animation' -%}
            </button>
          </div>
          <div class="overflow-y-auto scrollbar-body scrollbar-horizontal pr-4 rtl:pl-4 rtl:pr-0 h-full">
            {% if block.settings.select_image != blank %}
              <div class="rte mb-0.5 size-chart">
                {% if block.settings.additional_info != blank %}
                  {{ block.settings.additional_info }}
                {% endif %}
              </div>
              <img
                class="{% if block.settings.size_chart_type == 'popup' %}h-full{% else %}h-fit{% endif %} w-full mt-4 object-cover animate-Xpulse skeleton-image"
                srcset="
                {{ block.settings.select_image | image_url: width: 375 }} 384w,
                {{ block.settings.select_image | image_url: width: 450 }} 450w,
                {{ block.settings.select_image | image_url: width: 768 }} 768w"
                sizes="(min-width: 768px) {% if block.settings.size_chart_type == 'popup' %}768px{% else %}384px{% endif %}, 100vw"
                src="{{ block.settings.select_image | image_url: width: 768 }}"
                alt="{{ block.settings.select_image.alt | escape }}"
                onload="requestAnimationFrame(() => { this.closest('.skeleton-image')?.classList.remove('animate-Xpulse', 'skeleton-image'); });"
                width="{{ block.settings.select_image.width }}"
                height="{{ block.settings.select_image.height }}"
                style="object-position: {{ block.settings.select_image.presentation.focal_point }}"
              />
            {% else %}
              <div class="rte mb-0.5 size-chart">
                {%- if block.settings.select_page.content != blank -%}
                  {{ block.settings.select_page.content }}
                {%- endif -%}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </template>
  {% endif %}
</div>
