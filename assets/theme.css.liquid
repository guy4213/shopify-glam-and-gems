@keyframes effectHover {
  100% {
    left: 125%;
  } 
}
@keyframes fadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}
@keyframes hideMe{
  0%{
    opacity: 1;
  }
  99.99%{
    opacity: 1;
  }
  100%{
    opacity: 0;
    display: none;
  }
}
@keyframes Xpulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: .5;
  }
}
@keyframes fadeInY {
  from {
    opacity: 0;
    transform: translateY(var(--fade-translate-y, 20px));
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}
@keyframes moveUp {
  from {
    opacity: .7;
    transform: translateY(100%);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}
@keyframes slide-move-up {
  from {
    transform: translateY(50px);
    opacity: 0;
  }
  to {
    transform: translateY(0%);
    opacity: 100%;
  }
}
@supports (-webkit-touch-callout: none){
  .input-search, #x-cart-discount-field{
    font-size: 16px;
  }
}
