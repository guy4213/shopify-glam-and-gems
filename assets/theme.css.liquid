  padding-top: 10px;
}
.gpo-container .gpo-app .gpo-label {
  margin-bottom: 12px;
}
.corners-app .gpo-app .gpo-input, 
.corners-app .gpo-app .gpo-color-picker, 
.corners-app .gpo-app .gpo-dropzone, 
.corners-app .gpo-app .gpo-select select, 
